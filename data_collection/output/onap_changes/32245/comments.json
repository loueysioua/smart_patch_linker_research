    },
    {
      "id": "5a93c517_188694db",
      "file_path": "services/activity-spec/activity-spec-web/activity-spec-service/src/test/java/org/openecomp/activityspec/be/dao/impl/ActivitySpecZusammenDaoImplTest.java",
      "patchset_number": 10,
      "line": 74,
      "message": "Please avoid members in tests. They may hold a state that can change depending on the order tests run in - creating flaky tests. Don't take the order of tests, and the fact they run sequentially for granted.",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
        "username": "vempo"
      },
      "updated": "2018-03-06 16:49:05.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "5a93c517_d86b4c1c",
      "file_path": "services/activity-spec/activity-spec-web/activity-spec-service/src/test/java/org/openecomp/activityspec/be/impl/ActivitySpecManagerImplTest.java",
      "patchset_number": 10,
      "line": 70,
      "message": "This may hold state that can break in multi-thread execution. Each test should instantiate everything needed for its execution. Unless the state is initialized once before the class (not before each method).",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
        "username": "vempo"
      },
      "updated": "2018-03-06 16:49:05.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
