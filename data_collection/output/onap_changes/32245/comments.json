    {
      "id": "5a93c517_f8fde86e",
      "file_path": "services/activity-spec/activity-spec-web/activity-spec-service/src/main/java/org/openecomp/activityspec/be/impl/ActivitySpecManagerImpl.java",
      "patchset_number": 10,
      "line": 167,
      "message": "Please give a meaningful message and pass the exception as is. Something like LOGGER.error(\"Failed to get version \" + version + \" of activity \" + activitySpecId, exception);",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
