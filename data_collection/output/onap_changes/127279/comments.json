      "unresolved": true
    },
    {
      "id": "89705b9e_c3393f69",
      "file_path": "components/pm-subscription-handler/pmsh_service/mod/api/services/subscription_service.py",
      "patchset_number": 2,
      "line": 431,
      "message": "As discussed earlier, we are rejecting requests where we get Locking or Filtering states. Also we are ensuring that measurement groups for a subscription will be in one state either locking or Filtering and not both or multiple states at the same time.",
