      {
        "id": "c27552b8d17b214aebe65495511a21a98b0a5efd",
        "author": {
          "account_id": 481,
          "name": "Jessica Wagantall",
          "display_name": null,
          "email": "jwagantall@linuxfoundation.org",
          "username": "jwagantall"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-08-06 21:14:25.000000000",
        "message": "Patch Set 2: Code-Review-2\n\n(1 comment)\n\nLet's not create another copy of a docker daily job. We are working into removing too many docker templates and move the teams to use the ones in global-templates-docker.yaml which should be the globalized version for all projects. \n\nPlease look into my comments in jjb/optf/optf-has.yaml",
        "patchset_number": 2
      },
      {
        "id": "28f7ddb0296bf766aa4d28d93125b67936c88116",
        "author": {
          "account_id": 1361,
          "name": "Dileep Ranganathan",
          "display_name": null,
          "email": "dileep.ranganathan@intel.com",
          "username": "dileep.ranganathan"
        },
        "author_role": "OWNER",
        "timestamp": "2018-08-06 22:58:05.000000000",
        "message": "Patch Set 2: -Code-Review\n\nWe need a docker job which doesn't snip the snapshot tag from pom.xml. The requirement is to read the pom.xml and if it contains a SNAPSHOT keyword in the version the docker build script will build images using 'snapshots' maven artifacts and pushes it to 'snapshots' docker repository. If pom.xml version is with out snapshots (for eg: 1.2.0) it will build from 'releases' maven artifact and pushes to 'releases' docker repository. How can I achieve this using a single job?",
        "patchset_number": 2
      },
      {
        "id": "54c4f66cf612717182f91978e56a8fb1ed0cc58f",
        "author": {
          "account_id": 1361,
          "name": "Dileep Ranganathan",
          "display_name": null,
          "email": "dileep.ranganathan@intel.com",
          "username": "dileep.ranganathan"
        },
        "author_role": "OWNER",
        "timestamp": "2018-08-06 22:59:35.000000000",
        "message": "Patch Set 2:\n\nPlease refer to https://gerrit.onap.org/r/gitweb?p=optf/has.git;a=blob_plain;f=build-dockers.sh;hb=4b3243c48fb977e7a4c4dd1d420ba45e47803e7d",
        "patchset_number": 2
      },
