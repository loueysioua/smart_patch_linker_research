          "username": "sdesbure"
        },
        "author_role": "REVIEWER",
        "timestamp": "2020-03-04 16:34:12.000000000",
        "message": "Patch Set 1:\n\nif it's not maintained anymore, my position would be to remove it from VFC if the vendor is not there anymore to solve the issues.",
        "patchset_number": 1
      },
      {
        "id": "cdae6c94b3929a5505f2aef88e60e476db0215a5",
