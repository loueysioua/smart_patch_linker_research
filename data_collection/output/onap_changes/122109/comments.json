    {
      "id": "51fb2b62_eefaf841",
      "file_path": "models-pdp/src/main/java/org/onap/policy/models/pdp/concepts/PdpMessage.java",
      "patchset_number": 1,
      "line": 63,
      "message": "good point Ajith, I think pdps send it.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
