    {
      "id": "1a76adc5_bb4b5058",
      "file_path": "pom.xml",
      "patchset_number": 6,
      "line": 24,
      "message": "The path produced by the artifact needs to match the name of the repo. For example, the name of the repo is aai-validation and the path to post in Nexus should match:\nhttps://nexus.onap.org/content/repositories/snapshots/org/onap/aai/validation/...\nCurrently it is trying to post these bins to:\nhttps://nexus.onap.org/content/repositories/snapshots/org/onap/aai/validation-service/ which is a path not allowed. \n\nWe can fix this by doing these changes:\n\n\t<groupId>org.onap.aai.validation</groupId>\n\t<artifactId>service</artifactId>",
      "author": {
        "account_id": 481,
        "name": "Jessica Wagantall",
        "display_name": null,
        "email": "jwagantall@linuxfoundation.org",
        "username": "jwagantall"
