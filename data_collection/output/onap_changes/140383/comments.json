    {
      "id": "8316d7e5_966a97ac",
      "file_path": "kubernetes/sdc/components/sdc-be/values.yaml",
      "patchset_number": 9,
      "line": 156,
      "message": "Increase the limits:\n```\n  small:\n    limits:\n      cpu: \"2\"\n      memory: \"3Gi\"\n    requests:\n      cpu: \"1\"\n      memory: \"3Gi\"\n  large:\n    limits:\n      cpu: \"3\"\n      memory: \"6Gi\"\n    requests:\n      cpu: \"1\"\n      memory: \"6Gi\"\n\n```",
      "author": {
        "account_id": 2679,
        "name": "Andreas Geissler",
        "display_name": null,
        "email": "andreas@geisibee.de",
        "username": "andreasgeissler"
      },
