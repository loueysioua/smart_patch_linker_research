      "unresolved": true
    },
    {
      "id": "6b4175a6_c4b3ac27",
      "file_path": "kubernetes/sdc/components/sdc-be/values.yaml",
      "patchset_number": 9,
      "line": 319,
      "message": "Please add the \"jobAnnotations\" section:\n```\n# Annotations to control the execution and deletion of the job\n# Can be used to delete a job before an Upgrade\n#\n# jobAnnotations:\n#   # In case of an ArgoCD deployment this Hook deletes the job before syncing\n#   argocd.argoproj.io/hook: Sync\n#   argocd.argoproj.io/hook-delete-policy: BeforeHookCreation\n#\n#   # In case of an Helm/Flux deployment this Hook deletes the job\n#   # This is what defines this resource as a hook. Without this line, the\n#   # job is considered part of the release.\n#   \"helm.sh/hook\": \"pre-upgrade,pre-rollback,post-install\"\n#   \"helm.sh/hook-delete-policy\": \"before-hook-creation\"\n#   \"helm.sh/hook-weight\": \"1\"\n\n```",
      "author": {
        "account_id": 2679,
        "name": "Andreas Geissler",
        "display_name": null,
        "email": "andreas@geisibee.de",
        "username": "andreasgeissler"
      },
      "updated": "2025-03-12 08:56:57.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
