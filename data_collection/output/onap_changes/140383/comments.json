    {
      "id": "cbcb044a_8b3eebb3",
      "file_path": "kubernetes/sdc/components/sdc-be/resources/config/catalog-be/janusgraph.properties",
      "patchset_number": 22,
      "line": 23,
      "message": "The `.Values.cassandra.db_cache` key is misleading here from my point of view.\nThis is a cache Janusgraph is keeping.\nSince it is a janusgraph specific property, I would propose to name it `.Values.janusgraph.cache.enabled`\n\nI think we should also wrap all these cache.* related options in a\n\n```\n{{- if .Values.janusgraph.cache.enabled }}\n\n{{- end }}\n```\n\nThat would make it easier to reason about what config takes effect",
      "author": {
        "account_id": 7849,
        "name": "Fiete Ostkamp",
        "display_name": null,
