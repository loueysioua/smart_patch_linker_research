    {
      "id": "eb0f3b68_3ccb0ff2",
      "patchset_number": 4,
      "message": "The sdc-cs job ends with \"Succeeded\", although parts of the DB initialization fails (e.g. Janusgraph creation). This causes the SDC-BE pod to fail.\nAfter re-execution of the job and successfull DB init the sdc-be is coming up.\nTo solve the problem, the execution.sh has to fail, if any started sh-script is failing.",
      "author": {
        "account_id": 2679,
        "name": "Andreas Geissler",
        "display_name": null,
        "email": "andreas@geisibee.de",
        "username": "andreasgeissler"
      },
      "updated": "2025-03-10 13:09:56.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
