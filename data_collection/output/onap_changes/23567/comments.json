    {
      "id": "5a4e6583_1e2dfd46",
      "file_path": "openecomp-be/lib/openecomp-sdc-validation-lib/openecomp-sdc-validation-api/src/main/java/org/openecomp/core/validation/errors/ErrorMessagesFormatBuilder.java",
      "patchset_number": 1,
      "line": 48,
      "message": "This way you make the message code portion a part of the format you pass to getErrorWithParameters(String, String...). You have to be very careful not to use formatting symbols in message codes and the enclosing pattern (\"[xxx]:\"). I would first format the message first, and then insert the code portion. This will also allow you to use a formatting pattern for the code-message combination - because code and message will be formatted independently.",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
        "username": "vempo"
      },
