    {
      "id": "1a76adc5_7dd16bfa",
      "file_path": "workflow-designer-be/src/main/java/org/onap/sdc/workflow/api/ExceptionsHandler.java",
      "patchset_number": 3,
      "line": 68,
      "message": "I think a mechanism similar to \"General Error\" should used here, with a unique error identifier. There are several reasons. First, a NullPointer, for instance, returns \"\" from getMessage(). It won't be helpful. Second, you don't know what kind of error may get here. If it's a DB error, for example, the user can do nothing about it and will be confused. Sensitive information may leak through such errors, too. At the same time, you want to be able to quickly find and troubleshoot the root cause of such an error - it's not a client's mistake, but a problem in code or runtime environment. You should also log these type of errors. Otherwise you lose a critical piece of information which is the stack trace. Static analysis should have warned you about it.",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
        "username": "vempo"
      },
      "updated": "2018-08-09 08:13:45.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
