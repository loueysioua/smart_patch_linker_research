    {
      "id": "e39cc764_82652da3",
      "file_path": "robot/resources/demo_preload.robot",
      "patchset_number": 2,
      "line": 56,
      "message": "I'll test it and update",
      "author": {
        "account_id": 5550,
        "name": "Konrad Banka",
        "display_name": null,
        "email": "kbanka.os@gmail.com",
        "username": "kbanka"
