    {
      "id": "342fde9e_8aa5df0d",
      "file_path": "cps-service/src/main/java/org/onap/cps/spi/CpsModulePersistenceService.java",
      "patchset_number": 3,
      "line": 52,
      "message": "persistence layer already does not care. it just behaves as it requested to behave.\ncurrent parameter is allowance flag, and it is required to serve behavior duality.\non API as well. because the service should not care where the method is called from,\nthe service should fulfill the caller expectation. input parameter is a best option. \n\nfor REST service (when it calls the core service) this allowance flag will be \nhard-coded to false, so the auto-deletion will be disabled for REST; but this behavior \nwill be applied for REST requests only. for any other API consumer there will be an option.",
      "author": {
        "account_id": 7362,
        "name": "Ruslan Kashapov",
        "display_name": null,
        "email": "ruslan.kashapov@pantheon.tech",
