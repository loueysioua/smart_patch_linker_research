    {
      "id": "ecbd2701_ff5c1d4d",
      "file_path": "kubernetes/common/certInitializer/templates/_certInitializer.yaml",
      "patchset_number": 5,
      "line": 205,
      "message": "You shouldn't reference certInitializer here directly here. We have two ways of fixing this:\n1) make importCustomCertsEnabled a global flag (whcih means that you enable it everywhere or nowhere)\n2) Use the same concept as above (initRoot) to access this value (which means that you will need to enable it for every components manually)\n\nThe same comment applies to all above templates",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
