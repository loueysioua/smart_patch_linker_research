    },
    {
      "id": "9adffdf1_c55975ff",
      "file_path": "hv-collector-core/src/main/kotlin/org/onap/dcae/collectors/veshv/impl/Router.kt",
      "patchset_number": 2,
      "line": 34,
      "message": "Such logs should be inside reactive stream, eg. `Mono.just(...).doOnNext(log)`. There are 2 reasons:\n\n1. We may loose the rx context (so also MDCs)\n2. Log should be done in rx runtime/subscription phase (not when setting up the stream)",
      "author": {
        "account_id": 2683,
        "name": "Piotr Jaszczyk",
        "display_name": null,
        "email": "piotr.jaszczyk@nokia.com",
        "username": "jaszczur"
      },
      "updated": "2018-11-30 07:17:38.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
