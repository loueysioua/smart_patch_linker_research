    {
      "id": "b945a497_37170417",
      "file_path": "plans/ccsdk-oran/polmansuite/test_env.sh",
      "patchset_number": 1,
      "line": 32,
      "message": "10003 is referred to as \"push registry\" in ONAP while 10001 is for \"pull\", so it might be more appropriate to use the latter here? Also maybe ORAN and ONAP registries could be extracted to their own constants as they are used multiple times around this script",
