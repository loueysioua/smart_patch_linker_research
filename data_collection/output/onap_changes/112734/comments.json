    {
      "id": "8797700a_be59dd07",
      "file_path": "plans/ccsdk-oran/polmansuite/FTC150.sh",
      "patchset_number": 1,
      "line": 54,
      "message": "This probably relates to the two different SDNC image names and tags in test_env.sh, but if this now starts up the ONAP SDNC image, what's start_sdnc_onap function in nonrtric/test/common/testcase_common.sh for? Or have you refactored it out already?",
      "author": {
        "account_id": 3949,
        "name": "Lasse Kaihlavirta",
        "display_name": null,
        "email": "l.kaihlavirt@partner.samsung.com",
