      "unresolved": true
    },
    {
      "id": "ac8718f7_6a0eb65f",
      "file_path": "plans/ccsdk-oran/polmansuite/test_env.sh",
      "patchset_number": 1,
      "line": 33,
      "message": "Keep in mind that \"latest\" is more ambiguous than some specific numbered tag, so you need to remain alert of the related risk of using this. Unfortunately there is no unified strategy in ONAP CSITs for choosing the proper image to be tested (and I've discovered just this week that for many projects this isn't still working properly; they are quite simply not testing their current versions at all!) so I can't point you to any single \"right\" way of doing this that would be unambiguously better than just taking \"latest\"",
      "author": {
        "account_id": 3949,
        "name": "Lasse Kaihlavirta",
        "display_name": null,
        "email": "l.kaihlavirt@partner.samsung.com",
        "username": "kaihlavi"
      },
      "updated": "2020-09-16 12:38:18.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
