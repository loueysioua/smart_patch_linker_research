    {
      "id": "9e98e2f1_a23f2d3e",
      "file_path": "pnfsimulator/src/main/resources/application.properties",
      "patchset_number": 1,
      "line": 14,
      "message": "Mixture of AAF CertMan paths (keystore, password) and CMPv2 paths (password files).\nI propose to put here by default CMPv2 paths to keystore and truststore:\nssl.clientCertificatePath=/app/store/keystore.p12\nssl.trustStorePath=/app/store/truststore.p12\n\nI propose to rename files from store directory to keystore.p12 and truststore.jks and adjust two docker compose files:\n* in Certman version copy all files (cp /app/store/trust.jks /app/store/truststore.p12\n      && cp /app/store/cert.p12 /app/store/keystore.p12 && cp /app/store/p12.pass /apt/store/keystore.pass && cp /app/store/trust.pass /app/store/truststore.pass) \n* don' copy anything in CMPv2 docker compose\n* adjust env file for PNF simulator to request OUTPUT_TYPE=P12",
      "author": {
        "account_id": 5775,
        "name": "Pawel Baniewski",
        "display_name": "Pawel Baniewski",
        "email": "pawel.baniewski@nokia.com",
        "username": "baniewsk"
      },
      "updated": "2020-10-19 13:27:14.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "d726195c_1684d55a",
      "file_path": "pnfsimulator/src/main/resources/application.properties",
      "patchset_number": 1,
      "line": 14,
      "message": "Currently PNF Simulator and VES use same certificates in CMPv2 mode. VES doesn't support p12 format, so we need to request separate certs for these components. It's done in another MR https://gerrit.onap.org/r/c/integration/simulators/pnf-simulator/+/113939. So I will wait till that MR is merged, then I will apply your suggestion here.",
      "author": {
        "account_id": 3771,
        "name": "Adam Wudzinski",
        "display_name": null,
        "email": "adam.wudzinski@nokia.com",
        "username": "adamwudzinski"
      },
      "updated": "2020-10-20 10:29:35.000000000",
