    {
      "id": "2053ab38_a68ae32c",
      "file_path": "kubernetes/contrib/requirements.yaml",
      "patchset_number": 1,
      "line": 26,
      "message": "Seems EJBCA is controlled right now by two flags: global.cmpv2Enabled and global.addTestingComponents instead of global.cmpv2Enabled and global.cmpv2Testing. \n\nSo flag cmpv2Testing must be removed from CertService PR, when EJBCA will be removed and testing configuration to CertService must depend on global.addTestingComponents instead of global.cmpv2Testing",
      "author": {
        "account_id": 5775,
        "name": "Pawel Baniewski",
        "display_name": "Pawel Baniewski",
        "email": "pawel.baniewski@nokia.com",
        "username": "baniewsk"
      },
      "updated": "2020-04-08 09:56:29.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "e6d1f9bd_f5cc8737",
      "file_path": "kubernetes/contrib/components/ejbca/requirements.yaml",
      "patchset_number": 1,
      "line": 22,
      "message": "we use the shared mariadb galera to host EJBCA tables.\nmariadb-init create the \"database\" (in mariadb server) and the \"user\" which can do anything he wants in the database only.\nThen we give the value to EJBCA",
      "author": {
        "account_id": 2319,
        "name": "Sylvain Desbureaux",
        "display_name": null,
        "email": "sylvain.desbureaux@orange.com",
        "username": "sdesbure"
      },
      "updated": "2020-04-08 10:06:16.000000000",
      "in_reply_to": "8c1edce3_feb8ac3a",
      "unresolved": true
    },
