      "file_path": "cps-rest/src/main/java/org/onap/cps/rest/utils/MultipartFileUtil.java",
      "patchset_number": 6,
      "line": 43,
      "message": "gzip assumes single file compression\nmultiple files require tar over gzip\n\nthe logic of extraction differs anyway,\nseems out of scope (extra feature)",
