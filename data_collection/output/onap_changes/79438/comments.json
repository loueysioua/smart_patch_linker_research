    {
      "id": "5f8b19f7_cf048dca",
      "file_path": "datafile-dmaap-client/src/main/java/org/onap/dcaegen2/collectors/datafile/service/DmaapReactiveWebClient.java",
      "patchset_number": 1,
      "line": 72,
      "message": "Here I am using MDC, while in the second file INVOKE is a marker. MDCs contain name-value pairs, while markers contain just the name (or tag).\nINVOKE marker is used when invoking another ONAP component via REST. In our case, we are invoking DMaaP to publish the collected file.",
      "author": {
        "account_id": 5051,
        "name": "Muhammad Rehan Raza",
        "display_name": null,
        "email": "muhammad.rehan.raza@est.tech",
        "username": "RehanRaza"
      },
      "updated": "2019-03-01 13:20:04.000000000",
      "in_reply_to": "12852252_545b149e",
      "unresolved": false
    },
    {
