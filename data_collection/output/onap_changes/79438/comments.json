      "id": "7c858333_d4b012f9",
      "file_path": "datafile-app-server/src/main/java/org/onap/dcaegen2/collectors/datafile/tasks/ScheduledTasks.java",
      "patchset_number": 1,
      "line": 92,
      "message": "The MDC is associated with a thread. Whenever a new thread is executed, we need to copy the MDC from current thread, and pass it on to the new thread.\nIn a single-threaded application, of course we don't need to set the MdcContextMap again. But here we are using multiple threads.",
      "author": {
        "account_id": 5051,
        "name": "Muhammad Rehan Raza",
        "display_name": null,
        "email": "muhammad.rehan.raza@est.tech",
        "username": "RehanRaza"
      },
      "updated": "2019-03-01 13:20:04.000000000",
      "in_reply_to": "d8604eca_ff144cd1",
      "unresolved": false
    },
