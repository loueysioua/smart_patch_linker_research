    {
      "id": "47bb59aa_a8a3ec12",
      "file_path": "kubernetes/onap/requirements.yaml",
      "patchset_number": 1,
      "line": 155,
      "message": "While the A1-Adapter is \"part\" of the controller (SDNC or another controller deployment) ... \nBut the A1 Policy Management Service is a standalone service. It may (and probably shoudld) be deployed at the same time as SDNC, but it is not \"part\" of SDNC and can be deployed/operate independent of SDNC. \n\nWe might need a TLC for \"nonrtric\" - where nonrtric is (will be) more than just A1 control. But nonrtric is a purely logical O-RAN concept and is probably not applicable for ONAP in general since ONAP should be applicable in a non-ORAN scenario.\n\nSylvain's suggestion \"a1policymanagement\" seems best for name.",
      "author": {
        "account_id": 5519,
        "name": "John Keeney",
        "display_name": "John Keeney",
        "email": "john.keeney@est.tech",
        "username": "JohnKeeney"
      },
      "updated": "2020-09-01 08:28:07.000000000",
      "in_reply_to": "c7b6c8b4_e6475e2a",
      "unresolved": true
    },
