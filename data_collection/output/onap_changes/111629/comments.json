    {
      "id": "16d32e94_745b5fb2",
      "file_path": "src/main/java/org/onap/dcaegen2/services/pmmapper/messagerouter/VESPublisher.java",
      "patchset_number": 11,
      "line": 1,
      "message": "The Intent for this class is to remain a publisher for VES to MR.\n\nYou need to move this logic into its own unit, and integrate that unit in the parallel flux in \nthe App class.\nYou shouldn't embed the entire KPI business logic into this class.\n\n\nas an aside if you are not publishing VES then we can look at refactoring this too, since it is already using a string it would probably just be a name change to the class.",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
