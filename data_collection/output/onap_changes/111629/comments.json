    {
      "id": "4900a771_c4ed8ffb",
      "file_path": "pom.xml",
      "patchset_number": 2,
      "line": 246,
      "message": "For production the application is using GSON for JSON, please migrate all of your Jackson code to GSON.\nThe reason for this was at the time of design SECCOM prohibted use of Jackson due to vulnerabilities, https://wiki.onap.org/display/DW/Fixing+Vulnerabilities+in+the+ONAP+Code+Base not sure if they are fixed as of now, if they are then you can either stick with jackson and migrate the entire codebase to Jackson or migrate the new functionality (which I would prefer).",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-08-31 12:38:30.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
