    {
      "id": "5611fc62_2926d48b",
      "file_path": "/COMMIT_MSG",
      "patchset_number": 2,
      "line": 7,
      "message": "Small suggestion here, This is the PM Mapper repo, so its probably fair to assume any commit in here is an enhancement for it.\nI think we should try to keep our git commit first line in the imperative mood so something like:\nAdd KPI Monitoring Enhancements\nMight work a little better, with the Jira revealing the information about the e2e networking slicing, however if you want to work in that this is for E2E networking slicing then:\nAdd KPI Monitoring Enhancements for E2E Network Slicing might be ok too.",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-08-31 12:38:30.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
