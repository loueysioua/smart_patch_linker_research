      "id": "5c541be7_57648fab",
      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/api/impl/NetworkCmProxyDataServiceImpl.java",
      "patchset_number": 8,
      "line": 216,
      "message": "This shouldn't stop after the first failure. I just decided to catch the invalid cm handle exception here using the validator as opposed to the private method below. Also due to the fact I added another validator to the YangModelCmHandle.\n\nThe response will look like this if multiple failures are detected\n{\n    \"failedCreatedCmHandles\": [\n        {\n            \"cmHandle\": \"Bookstore\",\n            \"errorCode\": \"01\",\n            \"errorText\": \"cm-handle already exists\"\n        },\n        {\n            \"cmHandle\": \"Bookstore 1\",\n            \"errorCode\": \"03\",\n            \"errorText\": \"cm-handle has an invalid character(s) in id\"\n        },\n        {\n            \"cmHandle\": \"Bookstore 2\",\n            \"errorCode\": \"03\",\n            \"errorText\": \"cm-handle has an invalid character(s) in id\"\n        }\n    ],\n    \"failedUpdatedCmHandles\": [],\n    \"failedRemovedCmHandles\": []\n}",
      "author": {
        "account_id": 7744,
        "name": "Dylan Byrne",
        "display_name": null,
        "email": "dylan.byrne@est.tech",
        "username": "DylanB95EST"
      },
      "updated": "2022-04-07 14:40:31.000000000",
      "in_reply_to": "ec091a33_2c684ba7",
      "unresolved": true
    },
