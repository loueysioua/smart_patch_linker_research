      "id": "b2c744cd_de8a6c62",
      "file_path": "certService/src/main/java/org/onap/aaf/certservice/certification/configuration/CmpServersConfig.java",
      "patchset_number": 1,
      "line": 73,
      "message": "This kind of implementation can be tricky, cause race condition may happen between K8s and manual configuration reload, which could end up in not desired setting pod in NotReady state during configuration reloading. This of course can happen if readiness probe failureThreshold is set to 1, but because we are not allowing to change failureThreshold via helm chart value and default value is 3 - such implementation has no side effects.\n\n\"failureThreshold: When a Pod starts and the probe fails, Kubernetes will try failureThreshold times before giving up. Giving up in case of liveness probe means restarting the container. In case of readiness probe the Pod will be marked Unready. Defaults to 3. Minimum value is 1.\"",
      "author": {
        "account_id": 5775,
        "name": "Pawel Baniewski",
        "display_name": "Pawel Baniewski",
        "email": "pawel.baniewski@nokia.com",
        "username": "baniewsk"
      },
      "updated": "2020-03-05 12:06:36.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
