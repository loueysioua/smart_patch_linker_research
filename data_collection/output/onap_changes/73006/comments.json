    {
      "id": "9adffdf1_87305f9f",
      "file_path": "docker-compose-dev.yml",
      "patchset_number": 2,
      "line": null,
      "message": "Yes. By specifying multiple files in the compose command \n\ndocker-compose -f docker-compose.yml -f docker-compose-dev.yml up\n\na \"merged\" configuration is achieved where docker-compose.yml contains the base configuration and the dev yaml contains the additional config. \n\nCare has been taken not to override the environment variables (e.g. JAVA_OPTIONS)\n\nRef: https://docs.docker.com/compose/extends/",
      "author": {
        "account_id": 1631,
        "name": "Ojas Dubey",
        "display_name": null,
        "email": "Ojas.Dubey@amdocs.com",
        "username": "ojasdubey"
      },
      "updated": "2018-11-28 12:47:59.000000000",
      "in_reply_to": "9adffdf1_ec5ef044",
      "unresolved": false
    },
