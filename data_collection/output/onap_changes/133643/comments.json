    {
      "id": "51dce23a_6370762e",
      "file_path": "src/main/resources/application.yml",
      "patchset_number": 12,
      "line": 70,
      "message": "from what I remember we had a logic to have this topic name..right ??\nwe also mentioned somewhere ??\nOr am i mixing it with something else ??",
      "author": {
        "account_id": 7965,
        "name": "Priyank Maheshwari",
        "display_name": null,
        "email": "priyank.maheshwari@est.tech",
