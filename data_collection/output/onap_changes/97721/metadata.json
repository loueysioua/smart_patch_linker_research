      {
        "id": "ce7d5534ef5478ead439acbbc68df1cea6b590fd",
        "author": {
          "account_id": 4677,
          "name": "Bengt Thuree",
          "display_name": null,
          "email": "bthuree@linuxfoundation.org",
          "username": "bthuree"
        },
        "author_role": "OWNER",
        "timestamp": "2020-01-06 07:09:00.000000000",
        "message": "Patch Set 13:\n\nthis cron job runs every 6 hours as it is configured, and only calls normal lftools.\nOur deploy scripts can call lftools with the --exact parameter and only copy the just released package for instance.\nBut this will only work with ONAP though.\nPossible to disable the automatic cron function though (or set it to once a week perhaps), and run it manually more frequently when a release is approaching for instance.\n\n(lftools) [bengt@localhost lftools]$ lftools nexus docker releasedockerhub --help\nUsage: lftools nexus docker releasedockerhub [OPTIONS]\n\n  Find missing repos in Docker Hub, Copy from Nexus3.\n\n  Will by default list all missing repos in Docker Hub, compared to Nexus3.\n  If -c (--copy) is provided, it will copy the repos from Nexus3 to Docker\n  Hub.\n\nOptions:\n  -o, --org TEXT   Specify repository organization.  [required]\n  -r, --repo TEXT  Only repos containing this string will be selected. Default\n                   set to blank string, which is every repo.\n  -e, --exact      Match the exact repo name. If used, --repo parameter can\n                   not be empty.\n  -s, --summary    Prints a summary of missing docker tags.\n  -v, --verbose    Prints all collected repo/tag information.\n  -c, --copy       Copy missing tags from Nexus3 repos to Docker Hub repos.\n  -p, --progbar    Display a progress bar for the time consuming jobs.\n  --help           Show this message and exit.",
        "patchset_number": 13
      },
