    {
      "id": "c499729b_9436d5d0",
      "file_path": "kubernetes/cds/charts/cds-ui/values.yaml",
      "patchset_number": 1,
      "line": 127,
      "message": "I am ok to define the variables globally. aaf flag is used to auto-generate AAF certificates/cofniguration by init-container and mounted by all the other containers. sidecar flag is used to run reverse-proxy/forward-proxy container within cds-ui pod. this patch uses hard-coded certifcates/password for reverse-proxy/forward-proxy, so aaf flag is not required. \n\nOnce the reverse-proxy/forward-proxy/cds-ui are using the auto-generated certificates/configuration, aaf flag should be the preliminary flag.",
      "author": {
        "account_id": 5014,
        "name": "Xuefeng Xie",
        "display_name": null,
        "email": "henry.xie@ericsson.com",
        "username": "eeginux"
