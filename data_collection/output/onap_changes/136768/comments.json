      "unresolved": true
    },
    {
      "id": "d55d4e74_e5c7c579",
      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/api/impl/config/NcmpConfiguration.java",
      "patchset_number": 1,
      "line": 76,
      "message": "is taht easy to do ?!",
      "author": {
        "account_id": 6639,
        "name": "Toine Siebelink",
        "display_name": null,
        "email": "toine.siebelink@est.tech",
        "username": "ToineSiebelink"
