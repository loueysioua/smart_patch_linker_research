    {
      "id": "c86b7ba4_11811464",
      "file_path": "openapi/components.yml",
      "patchset_number": 1,
      "line": 193,
      "message": "When I attempted to run this example with the square brackets I get:\njava.lang.IllegalArgumentException: Invalid character found in the request target [/dmi/v1/ch/somCmHandle/data/ds/ncmp-datastore:passthrough-operational?resourceIdentifier=ResourceIdentifier&options=%7B%0A%20%20%22options%22:%20%22(key1=10,key2=value2,key3=[val31,val32])%22%0A%7D ]. The valid characters are defined in RFC 7230 and RFC 3986\n\nHence I removed them, Is there a character that these should be instead?",
      "author": {
        "account_id": 7830,
        "name": "Luke Gleeson",
        "display_name": null,
        "email": "luke.gleeson@est.tech",
        "username": "lukegleeson"
      },
      "updated": "2021-11-30 17:36:18.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
