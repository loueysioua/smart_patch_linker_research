    {
      "id": "34426686_b6ec7f4c",
      "file_path": "adapters/mso-catalog-db-adapter/src/main/resources/db/migration/V8.1__AddControllerActor.sql",
      "patchset_number": 4,
      "line": 4,
      "message": "Hi Steve, controller actor is new property introduced for service, pnf/vnf resource. it could be cds, sdnc, appc, null(so-ref-data), and it tells which controller to use for that resource, avoid hardcoding the execution for appc, cds. It need some other code change to support the actor selection, there are few options,\n1. introduce a new controller interface (https://gerrit.onap.org/r/c/so/+/98668)\n2. Use gateway in BPMN to decide the actor and choose path of execution(https://gerrit.onap.org/r/c/so/+/98814)\n\nIn next SO meeting, we can present the proposal.",
      "author": {
        "account_id": 5014,
        "name": "Xuefeng Xie",
        "display_name": null,
        "email": "henry.xie@ericsson.com",
        "username": "eeginux"
      },
      "updated": "2019-11-26 14:22:17.000000000",
      "in_reply_to": "85d78540_9810d7bd",
      "unresolved": true
    },
