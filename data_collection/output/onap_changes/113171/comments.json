    {
      "id": "3a7cefa7_0d461105",
      "file_path": "src/k8splugin/internal/app/instance.go",
      "patchset_number": 3,
      "line": 255,
      "message": "I am not 100% sure that we should keep helm based resources' status with pods' status in the same place. Maybe we should keep dynamic resources as a separate set in InstanceStatus?",
      "author": {
        "account_id": 2701,
        "name": "Lukasz Rajewski",
        "display_name": null,
        "email": "lukasz.rajewski@t-mobile.pl",
        "username": "rajewluk"
      },
      "updated": "2020-09-30 08:47:05.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "572be23b_3f77ee6d",
      "file_path": "src/k8splugin/internal/app/instance.go",
      "patchset_number": 3,
      "line": 255,
      "message": "I'm fine with either approach. @Ritu, @Eric - what do you think?",
      "author": {
        "account_id": 5550,
        "name": "Konrad Banka",
        "display_name": null,
        "email": "kbanka.os@gmail.com",
        "username": "kbanka"
      },
      "updated": "2020-09-30 13:07:34.000000000",
