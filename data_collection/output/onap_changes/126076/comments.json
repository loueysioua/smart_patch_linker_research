      "updated": "2021-12-12 23:51:10.000000000",
      "in_reply_to": "24c0739f_b836d8f1",
      "unresolved": true
    },
    {
      "id": "54547143_fb0b8c8d",
      "file_path": "adapter/acumos/tests/test_spec.py",
      "patchset_number": 4,
      "line": 35,
      "message": "The value example-model:latest is placed in the uri under the artifact section as also seen in the assert statement. There, the docker registry details have been removed. Earlier while calling this component spec method, the docker uri (registry/model:tag) was passed as an argument. Now, it is replaced by only version as the method also contains model name as the first argument. Hence, the version and modelname are concatenated as modelname:tag and placed as the value.",
      "author": {
        "account_id": 6744,
        "name": "Shabnam Sultana",
        "display_name": null,
        "email": "shabnam.sultana@highstreet-technologies.com",
        "username": "Shabnam"
      },
      "updated": "2021-12-13 08:14:29.000000000",
      "in_reply_to": "3b2f56c0_d1f3cddb",
      "unresolved": true
    },
