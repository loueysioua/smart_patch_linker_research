    {
      "id": "58ff6157_95fc2bd8",
      "file_path": "adapter/acumos/tests/test_docker.py",
      "patchset_number": 4,
      "line": 48,
      "message": "Ok, since the requirements file IS coming from here, why aren't both acumos_dcae_model_runner and pyyaml listed in it?",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2021-12-09 23:42:24.000000000",
