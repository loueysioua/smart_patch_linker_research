    {
      "id": "8a0a877c_436bd173",
      "file_path": "cps-ri/src/test/groovy/org/onap/cps/spi/impl/CpsDataPersistenceServiceIntegrationSpec.groovy",
      "patchset_number": 8,
      "line": 159,
      "message": "NB: We have added the parent relationship as a Long which does not tell hibernate about the relationship when both parent and child are getting created in the same request. \n\nIn this test case, there are three inserts as expected, but the grandchild insert did not have parentId. So, the hibernate had to send another update to set the parent_id of the grandchild. \n\nTo fix it, we need update the FragmentEntity to define the parent_id as FragmentEntity and show a relationship between childFragments and parentId ( parentFragment). If we follow this approach, more changes are required but it may help us to fix the performance issues due to hierarchy in one go.",
      "author": {
        "account_id": 7680,
        "name": "Renu Kumari",
        "display_name": "Renu Kumari",
        "email": "kashi.renu@gmail.com",
        "username": "renukumari"
      },
      "updated": "2022-02-16 06:12:22.000000000",
      "in_reply_to": null,
      "unresolved": true
    }
