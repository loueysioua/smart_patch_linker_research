      {
        "id": "c916fac6611630c3cc851f6461c1f60269152b0d",
        "author": {
          "account_id": 2787,
          "name": "Liam Fallon",
          "display_name": null,
          "email": "liam.fallon@est.tech",
          "username": "liamfallon"
        },
        "author_role": "OWNER",
        "timestamp": "2019-03-07 20:36:50.000000000",
        "message": "Patch Set 1:\n\nI need to do the unit test for this review yet but I wanted to push it up for people to see. There is another review coming with a Java interface/API that the REST API code can work towards.\n\nThe reason for this is to keep the code that maintains database consistency behind the API. I'll explain at the stand up tomorrow.",
        "patchset_number": 1
      },
      {
        "id": "a977ea5d78c327546fbfb90f649bb0521a169713",
        "author": {
          "account_id": 2787,
          "name": "Liam Fallon",
          "display_name": null,
          "email": "liam.fallon@est.tech",
          "username": "liamfallon"
        },
        "author_role": "OWNER",
        "timestamp": "2019-03-07 20:39:34.000000000",
        "message": "Patch Set 1:\n\n@Chenfei\n\nTHe idea with the Java interface/API is that you get the serialized JSON or YAML in the response from the API. So you'll get a string that is already serialized. You just pop that in the body of the REST response.",
        "patchset_number": 1
      },
