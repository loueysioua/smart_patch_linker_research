    {
      "id": "fbb319f0_ce30c05b",
      "file_path": "a1-policy-management/api/pms-api.yaml",
      "patchset_number": 3,
      "line": 103,
      "message": "This parameter represents type name (not type ID). Type ID contains both name and version (and this is only the name). \n\nThere is already a parameter for type ID (policytype_id). One could argue that it should \nbe type_id and type_name, but changing the name policytype_id would break backwards compatibility.\n\nSo, there are \npolicytype_id - type ID\ntype_name - type name",
      "author": {
        "account_id": 5072,
        "name": "Patrik Buhr",
        "display_name": null,
        "email": "patrik.buhr@est.tech",
        "username": "PatrikBuhr"
      },
      "updated": "2021-10-15 12:09:12.000000000",
      "in_reply_to": "6c307d3c_b4c1d19f",
      "unresolved": true
    },
