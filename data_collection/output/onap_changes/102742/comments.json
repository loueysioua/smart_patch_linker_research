    {
      "id": "cb31bcb7_426fea5a",
      "file_path": "certService/src/main/java/org/onap/aaf/certservice/cmpv2client/impl/CmpResponseHelper.java",
      "patchset_number": 3,
      "line": 300,
      "message": "The verify method above is doing a more in-depth verification for each certificate in the chain using bouncy castle tools, which will also includes checking the issuerDn. Since the last certificate in the chain is always going to be the rootCA this works - I don't want to remove the verification code I'm using here, since its doing a thorough verification of the certs, and while I agree that there's probably a cleaner way of adding the cert to the trust store I can't really see a way with the current implementation that won't be messy in a different way, or obfuscates the code in some way. What do you think?",
      "author": {
        "account_id": 4439,
        "name": "Emmett  Cox",
        "display_name": null,
        "email": "emmett.cox@ericsson.com",
        "username": "EmmettCox"
      },
      "updated": "2020-03-03 13:21:22.000000000",
      "in_reply_to": "0dd345f3_2a7ac142",
      "unresolved": true
    },
