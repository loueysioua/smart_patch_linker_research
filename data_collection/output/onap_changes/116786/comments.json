      "file_path": "cps-rest/docs/api/swagger/components.yaml",
      "patchset_number": 5,
      "line": 7,
      "message": "the status is a text representation of a digital value, which is delivered via http header.\nthe actual content/format of an error message returned is a subject to discuss.\nthe requirements requirements are not specified yet.",
