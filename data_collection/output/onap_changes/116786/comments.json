    {
      "id": "0405d8ca_f71db221",
      "file_path": "cps-rest/docs/api/swagger/cpsAdmin.yml",
      "patchset_number": 7,
      "line": 28,
      "message": "It seems inconsistent to me to have 200 and 204 here that are both success codes.\n\nOnce deleted successfully, we still have to choose to return either `200 OK` or `204 No Content`.\n\nSame comment below for deleting an anchor.\n\nIf we already have decided, let's reflect it here. If we don't know yet, as these are draft requests, we can still leave them as is for now until we make the decision.\n\nMy preference is for 204 for successful deletion.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2021-01-15 02:55:26.000000000",
      "in_reply_to": null,
      "unresolved": true
