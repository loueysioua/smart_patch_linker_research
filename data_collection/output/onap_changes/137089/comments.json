      "id": "2957f8ea_ccc4b61b",
      "file_path": "integration-test/pom.xml",
      "patchset_number": 3,
      "line": 99,
      "message": "Yes, it's intentional. Having min = max is better for performance tests, because ResourceMeter class calls System.gc() before every test. Using same min and max avoids delays caused by needing to resize the heap after System.gc",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2024-02-02 15:51:13.000000000",
