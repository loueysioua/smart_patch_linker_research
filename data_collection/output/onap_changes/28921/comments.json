    {
      "id": "5a93c517_0d00fd65",
      "file_path": "bpmn/MSOCoreBPMN/src/main/java/org/openecomp/mso/bpmn/core/json/DecomposeJsonUtil.java",
      "patchset_number": 1,
      "line": 62,
      "message": "Because returning empty object when deserialization fails is bad. You can't easly check if deserialization failed, and here you can't even distinguish correct deserialization of empty object with failure.\n\nThere should be either returning no value (best in form of Optional.empty()) or throwing exception. I chose throwing exception, because failure in decoding json message is abnormal situation, and I can't handle it here.",
      "author": {
        "account_id": 2795,
        "name": "Lukasz Biniek",
        "display_name": null,
        "email": "lukasz.biniek@nokia.com",
        "username": "Biniek"
      },
      "updated": "2018-01-29 12:52:28.000000000",
