    {
      "id": "1a76adc5_90244ab0",
      "file_path": "appc-dg/appc-dg-shared/appc-dg-domain-model-lib/src/test/java/org/onap/appc/domainmodel/TestVnfc.java",
      "patchset_number": 4,
      "line": 206,
      "message": "FYI: None of the above actions, by itself, will remove trailing white space; you have to specifically configure one of them to \"remove trailing whitespace\" - it's an individual checkbox on the configuration pages for in #1 & #3, and it's a separate action in #2.\nCtrl-Shift-F will not remove trailing white space and I don't see a way to get it to do that. For some reason, that particular checkbox is not made available when configuring the Format action, AFAIK, though I could be missing it.  In addition, nobody on the web mentioned that as a possibility, either.",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2018-08-17 11:57:36.000000000",
      "in_reply_to": "1a76adc5_b5b7f8d7",
      "unresolved": false
