          "username": "rtait"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-31 16:21:05.000000000",
        "message": "Patch Set 1:\n\nLInterface, LogicalLink, NetworkPolicy, PhysicalLink, PNF, Port and Pserver should all have POJO test classes similar to the others.\nSome of the other test classes need a few lines added to get/set some new fields.",
        "patchset_number": 1
      },
