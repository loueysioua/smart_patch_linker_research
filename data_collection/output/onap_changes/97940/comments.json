      "id": "11d9a9cd_34fe69ab",
      "file_path": "ui-ci/src/main/java/org/openecomp/sdc/ci/tests/execute/sanity/OnboardingFlowsUI.java",
      "patchset_number": 3,
      "line": 350,
      "message": "Or else new generic method can be created in \"OnboardingDataProviders\" class with name \"Custom_VNF_List\" with below implementation - \n\n private static Object[][] customVnfList(Method m) {\n        final List<String> fileNamesFromFolder = OnboardingUtils.getXnfNamesFileList(XnfTypeEnum.VNF);\n        List<String> fileNames  =  Arrays.asList( ((Test) m.getAnnotation(Test.class)).groups());\n        if (CollectionUtils.isEmpty(fileNames) ) {\n            fail(\"Custom files are not provided in Group parameter \");\n            return new Object[0][];\n        }\n        if (  !fileNamesFromFolder.containsAll(fileNames) ) {\n            fail(\"Custom files are exits in the path\");\n            return new Object[0][];\n        }\n        LOGGER.debug(String.format(\"There are %s package file(s) to test\", fileNames.size()));\n        return provideData(fileNames, VNF_FILE_PATH);\n    }\n\nPlease let us know you input on this.",
      "author": {
        "account_id": 6131,
        "name": "Atul Purohit",
        "display_name": null,
        "email": "atul.purohit1@vodafone.com",
        "username": "atulpurohit"
      },
      "updated": "2019-11-25 11:37:39.000000000",
      "in_reply_to": "627e32d0_070a9d1c",
      "unresolved": true
    },
