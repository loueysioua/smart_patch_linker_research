    {
      "id": "4da579c4_49c0cd57",
      "file_path": "csit/apex-pdp/plans/teardown.sh",
      "patchset_number": 8,
      "line": 26,
      "message": "Agreed, and that will be really useful to just see the logs and understand the problem in Jenkins etc. But do we need logs from all these containers? There will be too much logs this way. Isn't it better to just log only the really relevant containers logs? For.e.g, we can for sure avoid simulator logs from everywhere. In this particular file, I would avoid API logs too, as PAP logs will contain the policy that gets deployed to PDP. \n@Others thoughts?",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
      },
      "updated": "2022-02-16 15:42:05.000000000",
      "in_reply_to": "b026637c_208cf438",
      "unresolved": true
    },
