    {
      "id": "8801daed_f54c6558",
      "file_path": "csit/apex-pdp/plans/teardown.sh",
      "patchset_number": 8,
      "line": 26,
      "message": "I have no preference.  I think displaying the simulator and api logs could have value as they are part of the flow and it may point to a problem with the simulator itself, or if there's any problematic race condition that depends on distribution of the simulator messages.   But I also understand the argument to keep them reduced as those situations that I mentioned will be infrequent.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
