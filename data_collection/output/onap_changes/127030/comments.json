    {
      "id": "57e080a7_d1840458",
      "file_path": "csit/config/api/apiParameters.yaml",
      "patchset_number": 8,
      "line": 4,
      "message": "API by default for CSIT doesn't need any changes, so it's being used only by the docker-compose for grafana.",
