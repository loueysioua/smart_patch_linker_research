      "id": "9a437d4f_c052f512",
      "file_path": "/COMMIT_MSG",
      "patchset_number": 2,
      "line": 7,
      "message": "Commit messages should only talk about the final change committed, its description and relation to code it changes/interacts with. Messages should not discuss the gerrit process. Consider, this will be a permanent part to the git repository after merge. \n\nPer TSC Approved commit message rules: \"Don't include patch set-specific comments like \"Patch set 2: rebased\"\n\nAs asked in previous comment, please see https://wiki.onap.org/display/DW/Commit+Messages#CommitMessages-Don't",
      "author": {
        "account_id": 667,
        "name": "Marcus Williams",
        "display_name": null,
        "email": "marcus.williams@intel.com",
        "username": "mgkwill"
      },
      "updated": "2017-08-24 21:14:15.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
