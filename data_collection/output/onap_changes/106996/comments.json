    {
      "id": "83ed2b0b_ccf99441",
      "file_path": "openecomp-be/api/openecomp-sdc-rest-webapp/vendor-software-products-rest/vendor-software-products-rest-services/src/main/java/org/openecomp/sdcrests/vsp/rest/services/OrchestrationTemplateCandidateImpl.java",
      "patchset_number": 1,
      "line": 87,
      "message": "So by default the constructor is public, so technically, the access modifier has not changed. What do you think?",
      "author": {
        "account_id": 6614,
        "name": "Francis Toth",
        "display_name": null,
        "email": "francis.toth@yoppworks.com",
        "username": "francistoth"
