    {
      "id": "481eae20_ff53cc16",
      "file_path": "kubernetes/oof/charts/oof-cmso/charts/oof-cmso-service/values.yaml",
      "patchset_number": 9,
      "line": 23,
      "message": "If I understand your concern, this sidecar container exists only in Dublin OOM deployment to support a very thin python script mocking of sunny day responses from \"SO\" in support of the integration health check and CSIT testcase. The risk of this failing on a python patch version is very small. \n\nThere are no finer grained python containers in nexus3.onap.org readily available, so mitigating this risk would require building of a custom container.\n\nThere is regular CMSO CSIT robot docker container that runs this mocking service that we use in the regular CSIT job, but this will be changing to support rainy day scenarios. It would seem excessive to run this as a sidecar container for this purpose, but this would address your concern.",
      "author": {
        "account_id": 89,
        "name": "Jerry Flood",
        "display_name": null,
        "email": "jflood@att.com",
        "username": "jf9860"
      },
      "updated": "2019-05-10 00:42:49.000000000",
      "in_reply_to": "287d86fb_f80707e9",
      "unresolved": false
    },
