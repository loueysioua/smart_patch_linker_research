    },
    {
      "id": "5a93c517_8e511e38",
      "file_path": "INFO.yaml",
      "patchset_number": 2,
      "line": 30,
      "message": "@James you're correct it's not specific enough. In fact the TZ database has deprecated US/Michigan and America/Michigan is not a valid TZ.\n\nIt should be America/Detroit for ET or America/Menominee for the Wisconsin border of Michigan. So... what TZ are you in?\n\nSee: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones",
      "author": {
        "account_id": 1,
        "name": "Andrew Grimberg",
        "display_name": null,
        "email": "agrimberg@linuxfoundation.org",
        "username": "agrimberg"
      },
      "updated": "2018-02-24 00:15:00.000000000",
      "in_reply_to": "5a93c517_8e891e77",
      "unresolved": false
    },
