    {
      "id": "10c51d18_7965e1c7",
      "file_path": "models-dao/src/main/java/org/onap/policy/models/dao/impl/DefaultPfDao.java",
      "patchset_number": 2,
      "line": 400,
      "message": "I was thinking an OO approach, using different types of factories based on someClass.  The factory would have createFilter(), setKeyName(), addFilter() methods.  There would be one single set of tests when the appropriate factory is created.  Once it's created, no other \"if\" or \"switch\" statements would be needed; just call factory.xxx() and the factory will do what's appropriate for someClass.  The getFilterType() method wouldn't even be needed - in fact, FilterType could probably go away, altogether.\n\nCould cache the factories based on someClass, so they'd only have to be determined/constructed once.",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2021-04-21 15:18:26.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
