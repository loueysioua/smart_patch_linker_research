    {
      "id": "5a93c517_a09fcb02",
      "file_path": "openecomp-be/lib/openecomp-sdc-translator-lib/openecomp-sdc-translator-core/src/main/java/org/openecomp/sdc/translator/services/heattotosca/UnifiedCompositionUtil.java",
      "patchset_number": 4,
      "line": 46,
      "message": "It's a good practice to specify the size of a new collection. This is especially true with ArrayList. For example, new ArrayList<>(0) if you don't expect new elements (or better yet Collections.newList()). Or if you have a collection, and are mapping its elements to an ArrayList, that list cannot be bigger than the original collection, so it will be new ArrayList<>(collection.size()). You don't want your list to grow several times, on the other hand you don't want to allocate unnecessary memory. See https://docs.oracle.com/javase/7/docs/api/java/util/ArrayList.html#ArrayList(int)",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
        "username": "vempo"
      },
