    {
      "id": "9a437d4f_90d70e4b",
      "file_path": "controlloop/common/actors/actor.vfc/src/main/java/org/onap/policy/controlloop/actor/vfc/VFCActorServiceProvider.java",
      "patchset_number": 2,
      "line": 68,
      "message": "Something that I just noticed, in the event manager, we only do the A&AI queries if vserver.is-closed-loop-disabled is missing. That works for the other use cases but not for VoLTE. If DCAE sends an onset with vserver.is-closed-loop-disabled and other required fields for the VFC request are missing, this vnfResponse object is going to be null and can cause null pointer exceptions.",
      "author": {
        "account_id": 1677,
        "name": "Daniel Cruz",
        "display_name": null,
        "email": "dc443y@att.com",
        "username": "dc443y"
      },
      "updated": "2017-09-27 02:28:44.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
