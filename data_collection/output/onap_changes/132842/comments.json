    {
      "id": "02664109_e74236f9",
      "file_path": "catalog-be/src/main/java/org/openecomp/sdc/be/components/impl/CommonImportManager.java",
      "patchset_number": 15,
      "line": 130,
      "message": "Backend part of comment in service-data-type-reader:\n\n\nCan handle here by adding after line 130:\n            \n            if (toscaJson.containsKey(\"data_types\")){\n                toscaJson = (Map<String, Object>) toscaJson.get(\"data_types\");\n            }",
      "author": {
        "account_id": 5269,
        "name": "Michael Morris",
        "display_name": null,
        "email": "michael.morris@est.tech",
        "username": "MichaelMorris"
      },
