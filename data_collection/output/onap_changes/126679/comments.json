    {
      "id": "30341f98_9f0f1628",
      "file_path": "cps-service/src/main/java/org/onap/cps/api/impl/CpsAdminServiceImpl.java",
      "patchset_number": 16,
      "line": 37,
      "message": "@Team, \nLombok does not copy the field annotation by default. There are two ways of doing it\n1. Add it in the annotation directly. It has local effect and does not impact another class.\n2. Add lombok.copyableAnnotations += org.springframework.context.annotation.Lazy in the lombok.config file and it will impact all the beans constructor.\n\nPlease share your views. I wanted to keep it localized and used the first approach.",
      "author": {
        "account_id": 7680,
        "name": "Renu Kumari",
        "display_name": "Renu Kumari",
        "email": "kashi.renu@gmail.com",
        "username": "renukumari"
      },
      "updated": "2022-02-02 15:56:22.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
