      "file_path": "kubernetes/portal/charts/portal-sdk/resources/config/deliveries/properties/ONAPPORTALSDK/system.properties",
      "patchset_number": 2,
      "line": 88,
      "message": "Sure we can do that, note that these are placeholders and replaced at runtime, so it's not that critical",
