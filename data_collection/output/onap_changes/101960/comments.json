      "unresolved": true
    },
    {
      "id": "fe4d9487_b3635968",
      "file_path": "kubernetes/portal/charts/portal-sdk/resources/server/server.xml",
      "patchset_number": 2,
      "line": 98,
      "message": "I don't see an obvious way to replace this with a secret.\nthis is the generated keystore password retrieved by AAF init container, so it is not known until the init container completes (and changes at each run), i used a trick to pass this through local env variables (and avoid this being written in clear), unless you have a way to dynamically create a secret from the completion of an init container that I don't know (maybe avail in later helm release?).",
      "author": {
        "account_id": 5,
        "name": "Christophe Closset",
        "display_name": null,
        "email": "christophe.closset@intl.att.com",
        "username": "ChrisC"
      },
      "updated": "2020-02-21 14:02:44.000000000",
      "in_reply_to": "16485ad6_0c385be4",
      "unresolved": true
    },
