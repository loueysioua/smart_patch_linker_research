      "file_path": "kubernetes/portal/charts/portal-sdk/resources/server/server.xml",
      "patchset_number": 2,
      "line": 98,
      "message": "Nope it's not good.\n\nThis env variable is set to some value at the deployment time without using a secret;)",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
