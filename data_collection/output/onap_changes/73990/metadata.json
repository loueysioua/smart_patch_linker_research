      {
        "id": "1998223a7db975dca2a51648a1e3bdf364b11944",
        "author": {
          "account_id": 4341,
          "name": "Keong Lim",
          "display_name": null,
          "email": "keong.lim+onap@gmail.com",
          "username": "keong"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-11-30 05:03:14.000000000",
        "message": "Patch Set 1:\n\nWhile I appreciate the wordy descriptions, as a \"release notes\" file, it is typical to include links to the bugs/story cases that were resolved in this release. See also https://www.mozilla.org/en-US/firefox/61.0.2/releasenotes/ for comparison.\n\nimplementors may need/want to track whether specific issues have been resolved, so would need links to those JIRA cases.",
        "patchset_number": 1
      },
      {
        "id": "ab896ef72be30dec0860ca4dbe710f29e9fe29f5",
        "author": {
          "account_id": 219,
          "name": "Gildas Lanilis",
          "display_name": null,
          "email": "gildaslanilis@gmail.com",
          "username": "glanilis"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-11-30 06:01:27.000000000",
        "message": "Patch Set 1: -Code-Review\n\nI tend to avoid presenting to end user bugs that they never materialized in their environment but only during the course of development. I am OK providing a link toward these bugs but not a long flat list in the RN. \nOnly known bugs that are discovered after the release and are significantly impacting end users should be documented in RN.",
        "patchset_number": 1
      },
      {
        "id": "b2f381a82f34921728cd4d6dbffd9ba2cb6a18c6",
        "author": {
          "account_id": 4341,
          "name": "Keong Lim",
          "display_name": null,
          "email": "keong.lim+onap@gmail.com",
          "username": "keong"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-11-30 06:31:39.000000000",
        "message": "Patch Set 1:\n\nIn the ONAP JIRA, is there a way to distinguish customer-raised bugs vs developer-raised bugs?",
        "patchset_number": 1
      },
