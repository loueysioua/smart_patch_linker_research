    },
    {
      "id": "e2d7c984_5d7af935",
      "file_path": "main/src/test/java/org/onap/policy/pap/main/comm/PdpHeartbeatListenerTest.java",
      "patchset_number": 6,
      "line": 243,
      "message": "Is this really a failure case for PdpStatistics?\nBecause as part of heartbeat processing, when the pdpInstance is not found in DB then the heartbeat message is passed to the pdp registration flow. And this will result in no calls being made to PdpStatistics update flow which is kind of known.\n\nFailure cases can be:\n1) having the pdpStatistics null in the heartbeat for already registered pdp\n2) passing different pdpGroup, PdpSubGroup & pdpInstanceId as compared to the one's in PdpStatus message.\n3) having the actual counts null in the pdpStatistics object passed.",
      "author": {
        "account_id": 3239,
        "name": "Ram Krishna Verma",
        "display_name": null,
        "email": "ramkrishna.verma@gmail.com",
        "username": "ramverma"
      },
      "updated": "2020-01-02 10:50:29.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
