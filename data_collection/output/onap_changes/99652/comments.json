      "patchset_number": 6,
      "line": 222,
      "message": "I think we should really populate some statistics in the PdpStatistics object and verify them. May be create a new method called verifyPdpStatistics.",
      "author": {
        "account_id": 3239,
        "name": "Ram Krishna Verma",
        "display_name": null,
