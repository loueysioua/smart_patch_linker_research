    {
      "id": "b12dd9a3_efe9f490",
      "file_path": "kubernetes/so/components/so-admin-cockpit/values.yaml",
      "patchset_number": 1,
      "line": 149,
      "message": "Hi Andreas, I don't know if this answers your question or not - let me know!\nFor now, authorizationpolicy is for each service, and authorizes access to the service to specific client serviceaccounts.\nSo for example here, the goal is that the serviceAccounts portal-db-read and so-read are authorized to access the so-admin-cockpit service.\nIf an so-admin-cockpit serviceAccount requires access to another specific service,that would be specified in the other service authorizationpolicy - e.g., so-bpmn-infra service authorizes the serviceAccount so-admin-cockpit-read.",
      "author": {
        "account_id": 5656,
        "name": "Andrew Lamb",
        "display_name": null,
        "email": "andrew.a.lamb@est.tech",
        "username": "AndrewLamb"
      },
      "updated": "2023-04-17 13:46:04.000000000",
