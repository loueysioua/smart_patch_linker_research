    {
      "id": "1a76adc5_d07d811d",
      "file_path": "kubernetes/aai/charts/aai-graphadmin/templates/create_db_schema.yaml",
      "patchset_number": 7,
      "line": 15,
      "message": "For every installation, the createDBSchema should be run as it will create the required indexes and schema for A&AI. Currently, working concurrently the same code within ecomp controller and the initContainers aren't working there so createDBSchema and other containers will all be connected at the same time which can create a problem. So I configured it so it can be disabled there. This was just a temporary thing so thats why its set to true so in onap it will always be run and can be disabled if chosen to do so.",
      "author": {
        "account_id": 75,
        "name": "Venkata Harish Kajur",
        "display_name": null,
        "email": "vk250x@att.com",
        "username": "vk250x"
      },
      "updated": "2018-09-06 16:59:56.000000000",
