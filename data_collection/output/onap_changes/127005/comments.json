    {
      "id": "4a293e57_c5d07100",
      "file_path": "sources/hv-collector-core/src/main/kotlin/org/onap/dcae/collectors/veshv/impl/adapters/kafka/KafkaSenderOptionsFactory.kt",
      "patchset_number": 8,
      "line": 44,
      "message": "There is a type mismatch between what is in the Map returned by getenv() (a string) and the false value (a boolean). Replace this with\n\n\nprivate Boolean USE_SCRAM = parseBoolean(System.getenv().getOrDefault(\"USE_SCRAM\", \"false\"));",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2022-02-11 21:22:49.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "29441b3f_1c7531de",
      "file_path": "sources/hv-collector-core/src/main/kotlin/org/onap/dcae/collectors/veshv/impl/adapters/kafka/KafkaSenderOptionsFactory.kt",
      "patchset_number": 8,
      "line": 62,
      "message": "Now change this to\n\napplyIf(USE_SCRAM)\n\n(Without the previous change and this one, your code could fail in various ways, such as if the value in USE_SCRAM were \"True\" or \"TRUE\". Using parseBoolean() avoids all of these issues.)",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
