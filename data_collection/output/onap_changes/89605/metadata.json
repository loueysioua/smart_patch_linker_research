          "display_name": null,
          "email": "pd1248@att.com",
          "username": "pdragosh"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-06-11 12:40:13.000000000",
        "message": "Patch Set 1: Code-Review+2\n\nThis is fine for now. No real difference between SNAPSHOT and SNAPSHOT-latest. But we will address that later.",
        "patchset_number": 1
