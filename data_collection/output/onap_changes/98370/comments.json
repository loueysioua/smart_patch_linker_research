    {
      "id": "07bd49a0_b82b2b7d",
      "file_path": "models-examples/src/main/resources/policytypes/onap.policies.native.Drools.yaml",
      "patchset_number": 5,
      "line": 67,
      "message": "Yes get rid of \"sourceTopics\" and \"sinkTopics\" above, and move them here.   A topic source or sink is coupled to a message mapping within the application, otherwise there is no point for them.   Example:\n\n{source, APPC-CL, org.onap.policy.appc.Response, $.CommonHeader.blah}\n{sink, APPC-CL, org.onap.policy.appc.Request, $.CommonHeader.Foo}\n\nThere is no duplication.   There is no much usage to define the topics above (per my previous comment) in the drools_controller section.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2019-11-19 16:53:14.000000000",
      "in_reply_to": "c7e79e00_3ac0ba99",
      "unresolved": false
