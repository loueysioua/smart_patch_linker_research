    {
      "id": "a6497742_636db484",
      "file_path": "cps-rest/src/test/groovy/org/onap/cps/rest/controller/AdminRestControllerSpec.groovy",
      "patchset_number": 4,
      "line": 67,
      "message": "There are two improvements we can do in this test class.\n\n1. To remove extra mocking for the objects used in other controllers by specifying which controller we are testing in @WebMvcTest(AdminRestController). We will be to remove \n`   @SpringBean\n    CpsDataService mockCpsDataService = Mock()\n\n    @SpringBean\n    CpsQueryService mockCpsQueryService = Mock()`\nmocks from this class.\n\n2. To let spring inject the ModelMapper by adding '@Import(ModelMapper)' annotation and remove '@SpringBean ModelMapper modelMapper = Spy()' from the Test class.\n\nThese are just suggestions and not a blocking issue. We can create another story to improve the Test in cps-rest.",
      "author": {
        "account_id": 7680,
        "name": "Renu Kumari",
        "display_name": "Renu Kumari",
        "email": "kashi.renu@gmail.com",
        "username": "renukumari"
      },
      "updated": "2021-06-10 12:54:41.000000000",
      "in_reply_to": "d2a2c001_c1757a1e",
      "unresolved": true
    },
