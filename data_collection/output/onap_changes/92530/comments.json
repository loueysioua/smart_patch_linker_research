    {
      "id": "09c59576_e3f313e9",
      "file_path": "ms/blueprintsprocessor/application/pom.xml",
      "patchset_number": 2,
      "line": 127,
      "message": "AFAIK mockk does not provide a reset() mechanism. See https://github.com/mockk/mockk/issues/292\nMoreover, to have a mocked bean overring a named singleton, Spring already provides @MockBean integrated with Mockito. The mockk equivalent maybe can be acomplished using the additional lib springmockk, but I didn't have a chance to test it.\nmockito-kotlin is just a tiny wrapper library that solves some annoyances when using Mockito directly from Kotlin.",
      "author": {
        "account_id": 5447,
        "name": "Eliezio Oliveira",
        "display_name": null,
        "email": "eliezio.oliveira@est.tech",
        "username": "ebo"
      },
      "updated": "2019-08-07 15:18:04.000000000",
      "in_reply_to": "e10fb36a_29744b04",
      "unresolved": true
    },
