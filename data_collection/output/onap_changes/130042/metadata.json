        "timestamp": "2022-07-28 14:59:48.000000000",
        "message": "Patch Set 2:\n\nFor dialog purposes and reference, this is the runtime generated swagger out of a lab:\n\n  \"swagger\" : \"2.0\",\n  \"info\" : {\n    \"description\" : \"PDP-D Telemetry Services\",\n    \"version\" : \"Swagger Server\",\n    \"title\" : \"\"\n  },\n  \"host\" : \"onap-policy-to-pdp-0:9696\",\n  \"basePath\" : \"/\",\n  \"tags\" : [ {\n    \"name\" : \"pdp-d-telemetry\",\n    \"description\" : \"Drools PDP Telemetry Operations\"\n  } ],\n  \"schemes\" : [ \"http\", \"https\" ],\n  \"consumes\" : [ \"application/json\", \"application/yaml\", \"text/plain\" ],\n  \"produces\" : [ \"application/json\", \"application/yaml\" ],\n  \"paths\" : {\n    \"/policy/pdp/engine/lifecycle/properties\" : {\n      \"get\" : {\n        \"summary\" : \"Retrieves the Lifecycle properties\",\n        \"description\" : \"Lifecycle Properties\",\n        \"operationId\" : \"properties\",\n        \"consumes\" : [ \"application/json\", \"application/yaml\" ],\n        \"produces\" : [ \"application/json\", \"application/yaml\" ],\n        \"parameters\" : [ ],\n        \"responses\" : {\n          \"200\" : {\n            \"description\" : \"successful operation\",\n            \"schema\" : {\n              \"type\" : \"object\",\n              \"additionalProperties\" : {\n                \"type\" : \"string\"\n              }\n            }\n          }\n        }\n      }\n    },\n...",
        "patchset_number": 2
      },
