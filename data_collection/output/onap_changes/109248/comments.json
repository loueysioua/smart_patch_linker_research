      "id": "cda3e496_cc4b756a",
      "file_path": "deployment/noheat/README",
      "patchset_number": 4,
      "line": null,
      "message": "I prefer to keep READMEs, HACKINGs and similar extension-agnostic.\n\nThis way even if selected markup changes (e.g. from reStructuredText to Markdown) track of changes to these files is kept continuously (without a patch `git mv`-ing file to the new extension).\n\nRendering on GitHub mirror and in Sphinx is done with a symlink (like in:\n- https://github.com/onap/integration/tree/master/test/security/k8s\n- https://github.com/onap/integration/tree/master/test/security/sslendpoints)",
      "author": {
        "account_id": 5047,
        "name": "Pawe? Wieczorek",
        "display_name": "Pawel Wieczorek",
        "email": "pawel-wieczorek@outlook.com",
        "username": "pwieczorek"
      },
