    {
      "id": "6f369d14_97405b8f",
      "patchset_number": 1,
      "message": "seems OK but we do need to improve\n1) REST Interface\n2) Combine Modules responses automatically instead of hardcoding\n\n1) should be done shortly (possibly as a separate commit)\n2) can be considered technical debt",
      "author": {
        "account_id": 6639,
        "name": "Toine Siebelink",
        "display_name": null,
        "email": "toine.siebelink@est.tech",
        "username": "ToineSiebelink"
      },
