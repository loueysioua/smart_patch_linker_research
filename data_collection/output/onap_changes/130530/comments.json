      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/event/comm/bus/internal/BusConsumer.java",
      "patchset_number": 4,
      "line": 310,
      "message": "I think you don't need this if and could do \"return messages;\" here, messages will always be instantiated at this point with or without messages.",
