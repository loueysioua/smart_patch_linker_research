    {
      "id": "a97e90c0_1ce2256f",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/event/comm/bus/internal/BusConsumer.java",
      "patchset_number": 4,
      "line": 313,
      "message": "If we get an IOException here, ie. kafka server is unreachable, will be good to invoke similar functionality as in sleepAfterFailure() to await trying to reach the server for a little bit (see other examples) in this file.   This had to be done for dmaap in the past to avoid overwhelming the server with connection requests that could not serve.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2022-09-13 21:56:17.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
