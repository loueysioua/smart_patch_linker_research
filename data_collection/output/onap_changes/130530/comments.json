      "unresolved": false
    },
    {
      "id": "20780cff_55af5fc2",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/properties/PolicyEndPointProperties.java",
      "patchset_number": 8,
      "line": 92,
      "message": "This is what I meant in my previous comment to have in the defaults and use them instead in the code in the previous file:\n\npublic static final String PROPERTY_KAFKA_SINK_ACKS_CONFIG = \"kafka.sink.acks.config\";\npublic static final String PROPERTY_KAFKA_SINK_MS_CONFIG = \"...\";\npublic static final String PROPERTY_KAFKA_SINK_RETRIES_CONFIG = \"...\";",
