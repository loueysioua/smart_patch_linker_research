    {
      "id": "c75230ac_5f54e187",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/event/comm/bus/internal/BusPublisher.java",
      "patchset_number": 1,
      "line": 203,
      "message": "Changed the key to \"key: String = UUID.randomUUID().toString()\", similar to implementation in CDS.\nThis Key is an optional input parameter in ProducerRecord, It can either be null, a randomKey or a fixed value.\nIf no partition is specified but a key is present a partition will be chosen using a hash of the key. If neither key nor partition is present a partition will be assigned in a round-robin fashion. If a fixed key is provided, then records will be sent to the same partition to which the first record is sent, usually for a strict ordering.\n\nThe record also has an associated timestamp. If the user did not provide a timestamp, the producer will stamp the record with its current time.\nwe need to use below constructor for this case, but i think we can leave timestamp for this implementation.\nProducerRecord(String topic, Integer partition, Long timestamp, K key, V value)\nCreates a record with a specified timestamp to be sent to a specified topic and partition",
      "author": {
        "account_id": 7504,
        "name": "Sirisha Manchikanti",
        "display_name": null,
        "email": "sirisha.manchikanti@est.tech",
        "username": "Sirisha_Manchikanti"
      },
      "updated": "2022-09-07 08:11:33.000000000",
      "in_reply_to": "35b5d80d_a1cc4906",
      "unresolved": false
    },
