    {
      "id": "95761d4e_c5bb595c",
      "file_path": "datafile-app-server/src/test/java/org/onap/dcaegen2/collectors/datafile/utils/JsonMessage.java",
      "patchset_number": 2,
      "line": 237,
      "message": "Is this used for anything?\nActually I think it would be more maintainable to just have a textfile with the Json message and to remove this whole class \nWe can look at that later.",
      "author": {
        "account_id": 5072,
        "name": "Patrik Buhr",
        "display_name": null,
        "email": "patrik.buhr@est.tech",
