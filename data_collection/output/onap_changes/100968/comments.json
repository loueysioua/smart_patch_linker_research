    {
      "id": "2d05d850_912e2c83",
      "file_path": "feature-lifecycle/src/main/java/org/onap/policy/drools/domain/models/nativ/rules/NativeDroolsPolicy.java",
      "patchset_number": 3,
      "line": null,
      "message": "Not sure Liam, I don't think I can reuse much from the tosca policy.  ToscaPolicy handles generic structures such as maps of string to objects, strings to strings, and list of these maps.   For example ToscaPolicy contains:\n\nprivate Map<String, Object> properties;  \nprivate Map<String, String> metadata;\n\nand \"Map<String, Object> properties\" at the same time contains nested lists of List<Map<String, Object>> for example, besides inconvenience on dealing with these objects, and lack of validation, easy to make programmatic mistakes as it bypasses much of the compile time type validation that will be more strict with these domain objects.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2020-02-03 17:46:52.000000000",
      "in_reply_to": "3e03b7fd_da26bb8c",
      "unresolved": true
    },
