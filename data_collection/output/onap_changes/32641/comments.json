    {
      "id": "5a93c517_b1d463ec",
      "file_path": "aai-core/src/main/resources/dbedgerules/DbEdgeRules_v12.json",
      "patchset_number": 3,
      "line": 287,
      "message": "This could be done, yes, but then it would not follow the convention of all children having the belongsTo relationship.",
      "author": {
        "account_id": 33,
        "name": "James Forsyth",
        "display_name": null,
        "email": "jf2512@att.com",
        "username": "jimmydot"
      },
      "updated": "2018-03-05 16:05:32.000000000",
