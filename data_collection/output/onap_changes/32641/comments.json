      "file_path": "aai-core/src/main/resources/dbedgerules/DbEdgeRules_v12.json",
      "patchset_number": 3,
      "line": 287,
      "message": "I prefer the relationship between hpa-capability and flavor is \"AssociatedWith\" instead of \"BelongsTo\"",
