    },
    {
      "id": "5a93c517_dac909ad",
      "file_path": "aai-core/src/main/resources/dbedgerules/DbEdgeRules_v12.json",
      "patchset_number": 3,
      "line": 289,
      "message": "Perhaps it is MANY2MANY since one flavor can refer to multiple HPA capability and one HPA capability can be referred by many flavors.",
      "author": {
        "account_id": 1889,
        "name": "Bin Yang",
        "display_name": null,
        "email": "bin.yang@windriver.com",
        "username": "biny993"
      },
      "updated": "2018-03-05 06:14:00.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
