    {
      "id": "650bfa40_bcb23626",
      "file_path": "cps-ncmp-service/src/test/groovy/org/onap/cps/ncmp/api/impl/async/CpsAsyncRequestResponseEventIntegrationSpec.groovy",
      "patchset_number": 4,
      "line": 45,
      "message": "We get the flexibility to provide more configuration or override properties to the kafkaTemplate here like below\n\n  kafkaTemplate.getProducerFactory().updateConfigs(Map<String, Object> updates) or,\n  kafkaTemplate.getProducerFactory().properties.put() or,\n  kafkaTemplate.getProducerFactory().removeConfig(String configKey)",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
      "updated": "2022-06-07 12:12:21.000000000",
      "in_reply_to": "31552fc1_351c27a0",
      "unresolved": true
    },
    {
      "id": "3354bfba_001621e2",
      "file_path": "cps-ncmp-service/src/test/groovy/org/onap/cps/ncmp/api/impl/async/CpsAsyncRequestResponseEventIntegrationSpec.groovy",
      "patchset_number": 4,
      "line": 78,
      "message": "Jackson ObjectMapper performance pitfall :\n\nObjectMapper uses reflection to create the POJO type from the string value, at least to find the constructor annotated with @JsonCreator. To improve performance ObjectMapper keeps some kind of caching per instance so creating a new instance each time requires ObjectMapper to do the expensive work each time.\n\nSolution : Use single instance of ObjectMapper or static can also solve our purpose here as there would be only one thread at a time.\n\nIn general, avoiding unnecessary object creation is generally a good idea.\n\nhttps://theartofdev.com/2014/07/20/jackson-objectmapper-performance-pitfall/",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
      "updated": "2022-06-07 12:12:21.000000000",
      "in_reply_to": "4bb1259a_94b7d0a4",
      "unresolved": true
    },
