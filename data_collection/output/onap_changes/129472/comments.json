      "patchset_number": 4,
      "line": 45,
      "message": "Cool. \nI agree to this now since there is a cleaner way to override the properties.",
      "author": {
        "account_id": 7965,
        "name": "Priyank Maheshwari",
        "display_name": null,
        "email": "priyank.maheshwari@est.tech",
        "username": "mpriyank"
      },
      "updated": "2022-06-07 12:30:24.000000000",
      "in_reply_to": "650bfa40_bcb23626",
      "unresolved": true
    },
