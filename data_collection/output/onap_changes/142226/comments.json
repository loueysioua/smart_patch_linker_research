    {
      "id": "8324d990_f4fea5b9",
      "file_path": "k6-tests/make-logs.sh",
      "patchset_number": 6,
      "line": 113,
      "message": "I think this still looks very much like the Docker version,  I think it can easily be done in a single method with one or 1 more parameter",
      "author": {
        "account_id": 6639,
        "name": "Toine Siebelink",
        "display_name": null,
        "email": "toine.siebelink@est.tech",
        "username": "ToineSiebelink"
      },
