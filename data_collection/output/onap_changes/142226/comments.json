    {
      "id": "5769742a_8ff7ecb8",
      "file_path": "k6-tests/make-logs.sh",
      "patchset_number": 5,
      "line": 29,
      "message": "This name three blocks: deployment name + cps-and-ncmp + service name\n\nAs of now we support only one deployment name that is always: cps (it is a requirement), and the remaining part is mandatory.",
      "author": {
        "account_id": 8063,
        "name": "Halil Cakal",
        "display_name": null,
        "email": "halil.cakal@est.tech",
        "username": "halil.cakal"
      },
      "updated": "2025-10-13 10:24:55.000000000",
      "in_reply_to": "265bf2c3_96433460",
      "unresolved": true
    },
