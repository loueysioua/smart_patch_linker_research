    {
      "id": "f08e3feb_06bc515c",
      "file_path": "models-tosca/src/main/java/org/onap/policy/models/tosca/simple/concepts/JpaToscaServiceTemplate.java",
      "patchset_number": 1,
      "line": 366,
      "message": "Same. What if the referenced policy types are defined in other service template? And also, we might have the case where the referenced policy type has its referenced policy type too until xxx.Root. Do we aim to perform validation against this kind of chain?",
      "author": {
        "account_id": 1441,
        "name": "Chenfei Gao",
        "display_name": null,
        "email": "cgao@research.att.com",
        "username": "cgao"
      },
      "updated": "2020-02-07 18:59:25.000000000",
