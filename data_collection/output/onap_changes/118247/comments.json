      "id": "92b0fd99_d29cf1de",
      "file_path": "kubernetes/common/certInitializer/resources/retrieval_check.sh",
      "patchset_number": 4,
      "line": null,
      "message": "Except if this is something needed and removed at runtime by the underneath framework (k8s?), I think that :\n- the copyright header should be after #!/bin/sh (which should be the first line appended by an empty line). Otherwise bash (or any other default user shell depending on the system) will be called instead of /bin/sh (which is usually system default shell = dash on debian) and that would make this line #!/bin/sh  pointless\n- {//* and */}} should be removed to avoid errors at run time.",
      "author": {
        "account_id": 3685,
        "name": "Guillaume Lambert",
        "display_name": null,
        "email": "guillaume.lambert@orange.com",
        "username": "guillaume.lambert"
      },
      "updated": "2021-03-02 19:10:43.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
