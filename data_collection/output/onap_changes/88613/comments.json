      "file_path": "rest-services/dmaap-client/src/main/java/org/onap/dcaegen2/services/sdk/rest/services/dmaap/client/impl/MessageRouterPublisherImpl.java",
      "patchset_number": 5,
      "line": 83,
      "message": "OK. We may do it in separate MR. But please create a task on the board so we'll have this deal written down ;)",
      "author": {
        "account_id": 2683,
        "name": "Piotr Jaszczyk",
        "display_name": null,
        "email": "piotr.jaszczyk@nokia.com",
        "username": "jaszczur"
      },
      "updated": "2019-05-30 11:02:35.000000000",
      "in_reply_to": "a133b280_6d6e2218",
      "unresolved": false
