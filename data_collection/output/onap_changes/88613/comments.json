      "patchset_number": 5,
      "line": 78,
      "message": "One comment here: It will work (and is working of course :) ), but maybe we should keep these sample data closer to the methods. Just thinking.",
      "author": {
        "account_id": 2683,
        "name": "Piotr Jaszczyk",
        "display_name": null,
        "email": "piotr.jaszczyk@nokia.com",
        "username": "jaszczur"
