    {
      "id": "173df98c_b427f85b",
      "file_path": "models/src/main/java/org/onap/policy/clamp/controlloop/models/messages/dmaap/participant/ParticipantUpdate.java",
      "patchset_number": 1,
      "line": 48,
      "message": "I'll comment on this tomorrow.....There are two types of parameters now. Common parameters like say a timeout value for a microservice to come up that should have the same values for all microservices of a certain type.Instance specific parameters are parameters that can have different values for each instance of a control loop, such as a threshold percentage to cross.\n\nThe CLAMP GUI will set common parameters when the control loop type is imported (A new dialogue but using the existing CLAMP code).\n\nThe CLAMP GUI already sets instance specific parameters when a control loop instance is created.\n\nLet me think some more on how we should represent those separate concepts when we pass them to participants.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2021-07-07 19:20:05.000000000",
      "in_reply_to": "f5602189_93b23479",
      "unresolved": true
    },
