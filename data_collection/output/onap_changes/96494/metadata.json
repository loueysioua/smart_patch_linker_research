      {
        "id": "1a760e3e2446fe8dc9fc48eff6b6c8c602510dc1",
        "author": {
          "account_id": 4886,
          "name": "Petr Ospalý",
          "display_name": null,
          "email": "p.ospaly@email.cz",
          "username": "p.ospaly"
        },
        "author_role": "OWNER",
        "timestamp": "2019-10-02 09:44:22.000000000",
        "message": "Patch Set 2:\n\nI verified locally and tested with HTTPS.\n\nYou can do it like this (adjust to your system):\n\n# download my unmerged change in sdc\nmkdir ~/sdc\ncurl -LR https://gerrit.onap.org/r/changes/96062/revisions/974c7719faa8d35de7b51508fe1160c417840fdb/archive?format=tgz -o ~/sdc/sdc.tgz\ntar -C ~/sdc -xzvf ~/sdc/sdc.tgz\ncd ~/sdc\n\n# delete parent tag\nsed -i '32,37d' pom.xml\n\n# build sdc\nmvn clean install -Pdocker -Dmaven.test.skip=true -X\n\n# install globally (sic) robotframework-onap\npip install --upgrade --extra-index-url=\"https://nexus3.onap.org/repository/PyPi.staging/simple\" 'robotframework-onap==0.5'\n\n# fix robotframework-onap package\nmkdir /tmp/robotframework-onap\ncurl -LR https://gerrit.onap.org/r/changes/94306/revisions/566c583bbfe0b5a4e46af7ac53765a1340d11fc0/archive?format=tgz -o /tmp/robotframework-onap/robotframework-onap.tgz\ntar -C /tmp/robotframework-onap -xvzf /tmp/robotframework-onap/robotframework-onap.tgz\n\n# fix it - this is path on my system, it can differs from yours\ncat /tmp/robotframework-onap/robotframework-onap/ONAPLibrary/RequestsHelper.py > /usr/lib/python2.7/site-packages/ONAPLibrary/RequestsHelper.py\n\n# run csit with local images and https\nmkdir ~/csit\ncurl -LR https://gerrit.onap.org/r/changes/96494/revisions/4c82c28c72cd926f5d075246ab1854fcfa02a465/archive?format=tgz -o ~/csit/csit.tgz\ntar -C ~/csit -xzvf ~/csit/csit.tgz\ncd ~/csit\nenv SDC_TEST_HTTPS=true SDC_LOCAL_IMAGES=true SDC_LOCAL_GITREPO=~/sdc/ ./run-csit.sh plans/sdc-dcae-d/dcaed/",
        "patchset_number": 2
      },
