    {
      "id": "5a93c517_ac26a2cc",
      "file_path": "policy-core/src/main/java/org/onap/policy/drools/util/KieUtils.java",
      "patchset_number": 2,
      "line": 68,
      "message": "If this gets used regularly, perhaps as part of a periodic audit, and the DroolsPDP VM stays up for weeks or months at a time, you might end up with a large collection of files. We see a similar problem with the Maven repository audit -- if Nexus is not configured to empty the trash periodically, we eventually run out of inodes.\n\nIt might be worth it to have a timer clean it up in a minute or so.",
      "author": {
        "account_id": 743,
        "name": "Ralph Straubs",
        "display_name": null,
        "email": "rs8887@att.com",
        "username": "rs8887"
      },
      "updated": "2018-02-01 14:25:38.000000000",
      "in_reply_to": "5a93c517_2c4cd29d",
      "unresolved": false
    },
