    {
      "id": "b5b37f35_35999f7c",
      "file_path": "components/pm-subscription-handler/pmsh_service/mod/policy_response_handler.py",
      "patchset_number": 4,
      "line": 62,
      "message": "You could write this using list comprehension, which would look something like\n\ndata = json.loads(self.mr_sub.get_from_topic('policy_response_consumer'))\n\nfor apt_datum in [datum for datum in data if datum['status']['subscriptionName'] == self.subscription_name]:\n    nf_name = data['status']['nfName']\n    response_message = data['status']['message']\n    self._handle_response(self.subscriptio_name, administrative_state, nf_name, response_message)\n\n\n\nhowever, it's mostly a style change, and won't lead to any real difference in performance, so I leave the decision on whether you would use that here or not down to you.\n\nIt is good to know how they work though.",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-03-10 12:11:43.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
