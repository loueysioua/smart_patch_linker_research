      {
        "id": "8031d2d827555302e95b037428babb34bbb567d6",
        "author": {
          "account_id": 3895,
          "name": "Gareth Roper",
          "display_name": null,
          "email": "gareth.roper@est.tech",
          "username": "rope252"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-22 16:33:02.000000000",
        "message": "Patch Set 1:\n\nThanks Alexis, it seems the port 9091 we are using conflicts with the pap port. Our Ericsson team will change this from 9091 to 9191 as per your edit on https://wiki.onap.org/display/DW/OOM+NodePort+List.",
        "patchset_number": 1
      },
      {
        "id": "41914058ad00e460c26536055cf151b332007880",
        "author": {
          "account_id": 137,
          "name": "Alexis de Talhouet",
          "display_name": null,
          "email": "adetalhouet89@gmail.com",
          "username": "adetalhouet"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-22 16:48:28.000000000",
        "message": "Patch Set 1:\n\n> Thanks Alexis, it seems the port 9091 we are using conflicts with the pap port. Our Ericsson team will change this from 9091 to 9191 as per your edit on https://wiki.onap.org/display/DW/OOM+NodePort+List.\n\nOOops, seing this now. I might a typo in the wiki? Sorry about that. It is fine to have two applications using the same port, as long as the service name is different.",
        "patchset_number": 1
      },
      {
        "id": "75b20df5f19827245ddb469ebd78143a2a813f8d",
        "author": {
          "account_id": 3895,
          "name": "Gareth Roper",
          "display_name": null,
          "email": "gareth.roper@est.tech",
          "username": "rope252"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-23 08:56:33.000000000",
        "message": "Patch Set 1:\n\nOh, that's no problem at all Alexis. We can revert the port change and stay on 9091. However, SO-Monitoring has a UI which interacts with the back-end using \"so-monitoring:9091\". Is it still okay to have this port conflict on 9091?",
        "patchset_number": 1
      },
      {
        "id": "b966c77cfef643939432522e60cf337308ad6f0c",
        "author": {
          "account_id": 137,
          "name": "Alexis de Talhouet",
          "display_name": null,
          "email": "adetalhouet89@gmail.com",
          "username": "adetalhouet"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-23 11:59:21.000000000",
        "message": "Patch Set 1:\n\n> However, SO-Monitoring has a UI which interacts with the back-end using \"so-monitoring:9091\". Is it still okay to have this port conflict on 9091\n\nAs long as \"so-monitoring:9091\" is unique, there is no port conflict.",
        "patchset_number": 1
      },
      {
        "id": "ddaa9f7fe488fc351cd6af66bc28a04a698b1b73",
        "author": {
          "account_id": 35,
          "name": "Gary Wu",
          "display_name": null,
          "email": "gary.wu@gmail.com",
          "username": "gwu"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-23 22:29:39.000000000",
        "message": "Patch Set 1:\n\nLooks like this NodePort 30224 has a conflict with DCAE: https://jira.onap.org/browse/DCAEGEN2-892.  Can we get this changed?",
        "patchset_number": 1
      },
      {
        "id": "186712921fe81c0127129fec313ab08b235103d8",
        "author": {
          "account_id": 3895,
          "name": "Gareth Roper",
          "display_name": null,
          "email": "gareth.roper@est.tech",
          "username": "rope252"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-24 10:12:17.000000000",
        "message": "Patch Set 1:\n\nHi Gary, we set the SO-Monitoring NodePort based on the OOM NodePort List (https://wiki.onap.org/display/DW/OOM+NodePort+List). It says the SO-Monitoring NodePort should be 30224. Alexis, could you verify a NodePort we should use instead or should I just find an available one and update the list?",
        "patchset_number": 1
      },
      {
        "id": "4e7839a83fddb1d68d8ad14dc03a86aa582a4a85",
        "author": {
          "account_id": 137,
          "name": "Alexis de Talhouet",
          "display_name": null,
          "email": "adetalhouet89@gmail.com",
          "username": "adetalhouet"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-10-24 12:22:34.000000000",
        "message": "Patch Set 1:\n\nVijay fixed it for DCAE: https://gerrit.onap.org/r/#/c/71119/",
        "patchset_number": 1
      }
    ]
