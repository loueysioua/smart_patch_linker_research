    {
      "id": "5d928898_bc5576ad",
      "file_path": "ansible/roles/dns/tasks/main.yml",
      "patchset_number": 2,
      "line": 21,
      "message": "Because if for some reason the docker container is not running and above tasks don't report 'changed' on second run the container wouldn't be running. And we don't want to have same docker_container module call to create dns container here and in handlers because if it was here and you altered it then it didn't have any effect because what's in the handlers is run at the end.",
