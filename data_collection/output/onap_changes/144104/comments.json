      "id": "1b2cb41a_30b86e5b",
      "file_path": "docs/api/swagger/ncmp/openapi-inventory.yaml",
      "patchset_number": 1,
      "line": 85,
      "message": "even though the cm-handle path parameter is consistent with the rest of the api the background of the problem is that the cm-handle is not known. Only a DistinguishedName which was used on the ProvMnS API.\nSo the input of this endpoint should be a DistinguishedName and the output should be a cm-handle with its id, alternateId and cmHandleProperties.\n\nI suggest not using a path parameter at all to stay consistent with the rest of the api.\nhow about: /v1/ch?distinguishedName=<fdn>",
      "author": {
        "account_id": 8121,
        "name": "Csaba Kocsis",
        "display_name": null,
        "email": "csaba.kocsis@ericsson.com",
        "username": "ecsakoc"
