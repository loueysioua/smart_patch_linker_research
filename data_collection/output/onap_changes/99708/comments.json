    {
      "id": "319c8550_7be72970",
      "file_path": "components/pm-subscription-handler/pmsh_service/pmsh_service.py",
      "patchset_number": 9,
      "line": 33,
      "message": "This seems like bad practice.\nI'd say its generally accepted when doing TDD that you will end up refactoring production to a degree for testing, however, this sort of change seems like a smell.\nThe point of testing is to test the production code, this block makes it so production does something different in the test environment, which seems to defeat the purpose of testing in the first place.\n\nMaybe it would be better to design some sort of fallback mechanism in logging, to handle the situation when it cannot write to a file.",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-01-07 13:14:00.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
