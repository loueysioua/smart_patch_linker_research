      "file_path": "components/pm-subscription-handler/pmsh_service/mod/aai_client.py",
      "patchset_number": 9,
      "line": 130,
      "message": "You could identify the node-type and store the name beforehand, which should let you re-use the contents of the if and else and reduce some of the nestings.\n\nmaybe something like\n\nname_identifier = 'pnf-name' if xnf['node-type'] == 'pnf' else 'vnf-name'\nif xnf_filter.is_xnf_in_filter(xnf['properties'].get(name_identifier)):\n    xnf_set.add(Xnf(xnf_name=xnf['properties'].get('name_identifier'),\n        orchestration_status=xnf['properties'].get('orchestration-status')))",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-01-07 13:14:00.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
