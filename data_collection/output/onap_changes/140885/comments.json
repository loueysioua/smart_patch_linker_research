      "patchset_number": 4,
      "line": 140,
      "message": "NB: Future Improvment:\n\n private List<String> computeAllParentPaths(final String path, final String separator) {\n        final List<String> paths = new ArrayList<>();\n        String current = path.split(\"#\", 2)[0];\n        while (StringUtils.isNotEmpty(current)) {\n            paths.add(current);\n            current = getParentPath(current, separator);\n        }\n        return paths;\n    }",
