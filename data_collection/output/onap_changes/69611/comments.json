      "file_path": "integrity-monitor/src/main/java/org/onap/policy/common/im/IntegrityMonitor.java",
      "patchset_number": 3,
      "line": 1776,
      "message": "I believe this is why sonar-lint was flagging it as always true. But it wasn't showing up on sonar.onap.org. Do those params @NotNull mean anything runtime wise? they are javax validation constraints, are they not guaranteed?",
      "author": {
        "account_id": 57,
        "name": "Pamela Dragosh",
        "display_name": null,
        "email": "pd1248@att.com",
        "username": "pdragosh"
