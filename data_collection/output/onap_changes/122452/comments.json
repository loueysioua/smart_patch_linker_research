    {
      "id": "aaabda55_c59dd6c1",
      "file_path": "cps-path-parser/src/main/antlr4/org/onap/cps/cpspath/parser/antlr4/CpsPath.g4",
      "patchset_number": 7,
      "line": 23,
      "message": "I know about this, I explained it during previous walkthrough. The problems is that Antlr sometimes throws pretty unreadable errors, in this case if the incorrect prefix wasn't there you would get an index-out-of-bound exception.\nFrom previous project experience I learned sometime sis better to have explicit rules for error detection and give an more meaningful error message like here. This is doen on a bases of how comment the grammar is and/or as encountered (bugs reported) by users. This specific case I think was first asked for buy Aditya and I also have added it in as an example of 'error handling'.",
      "author": {
        "account_id": 6639,
        "name": "Toine Siebelink",
        "display_name": null,
        "email": "toine.siebelink@est.tech",
        "username": "ToineSiebelink"
      },
      "updated": "2021-07-20 09:11:59.000000000",
      "in_reply_to": "94105e6d_15306483",
      "unresolved": true
    },
