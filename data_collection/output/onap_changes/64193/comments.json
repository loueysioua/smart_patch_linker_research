    {
      "id": "1a76adc5_2aa33502",
      "file_path": "lcm/lcm/nf/views/operate_vnf_view.py",
      "patchset_number": 1,
      "line": 55,
      "message": "Hi Jinhua,\nAccording to the table 5.4.10.3.1-2 in ETSI GS NFV-SOL 003\nthe body of the 202 Accepted is n/a. So the body is empty.\nBut now I have updated the header with Location.\nCurrently I am using the job id in URI(of Location) but that would be replaced with lcm operation occurence id in future.\n\nsample header: \nContent-Length: 0\nX-Frame-Options: SAMEORIGIN\nLocation: /vnf_lc_ops/NF-OPERATE-12-2a3be946-b01d-11e8-9302-08002705b121\nVary: Accept, Cookie\nAllow: POST, OPTIONS",
      "author": {
        "account_id": 4247,
        "name": "Shobana Jothi",
        "display_name": null,
        "email": "shobana.jothi@verizon.com",
        "username": "Shobana-vz"
      },
      "updated": "2018-09-04 08:45:56.000000000",
      "in_reply_to": "1a76adc5_6f8b7f68",
      "unresolved": false
    },
