    {
      "id": "ba29321c_9c9b6f4c",
      "file_path": "bin/base/openssldockerfile",
      "patchset_number": 2,
      "line": 42,
      "message": "This copy is required for since the header file implementing one of the main implementation will not be copied to the host's directory upon \"Make install\" command. So we need to specifically copy this file to the library location of TSS and then include it on our functionality implementation. I have raised this as a bug in tss community\n\nNOTE - This step should have been done after installing tss. I have sent out a new patch which will fix this error.",
      "author": {
        "account_id": 3261,
        "name": "Pramod",
        "display_name": null,
        "email": "pramod.raghavendra.jayathirth@intel.com",
        "username": "Pramod"
      },
      "updated": "2019-03-20 22:39:59.000000000",
      "in_reply_to": "a4916422_2001eda9",
      "unresolved": false
    },
