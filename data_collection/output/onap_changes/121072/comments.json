    {
      "id": "08436d53_863b3a2c",
      "file_path": "docs/api/swagger/openapi.yml",
      "patchset_number": 12,
      "line": 53,
      "message": "As an historical list is returned, in case no records are found from the query, I think that the response still should be 200 OK, with an empty records list.\n\nThen, I'm not really sure about 404 Not Found, as CPS Temporal does not have the information about dataspace or anchor existence per say.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2021-05-06 16:24:48.000000000",
      "in_reply_to": "a6723691_7406a105",
      "unresolved": true
    },
    {
      "id": "fecc431a_95194b60",
      "file_path": "docs/api/swagger/openapi.yml",
      "patchset_number": 12,
      "line": 89,
      "message": "For now, I feel that the file is still manageable and all the specification could remain in the same file. Any other advantage to have it split ?",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
