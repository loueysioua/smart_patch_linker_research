    {
      "id": "65a10462_489febc0",
      "file_path": "policy-executor-stub/src/main/java/org/onap/cps/policyexecutor/stub/controller/PolicyExecutorStubController.java",
      "patchset_number": 1,
      "line": 99,
      "message": "Method Extraction: \n \n Extracted handleNcmpDeleteSchema and createPolicyExecutionResponse methods for clarity and single responsibility principle.:\n \n \n return handleNcmpDeleteSchema(firstRequest);\n        }\n\n        return new ResponseEntity<>(HttpStatus.BAD_REQUEST);\n    }\n\n    private ResponseEntity<PolicyExecutionResponse> handleNcmpDeleteSchema(Request firstRequest) {\n        final NcmpDelete ncmpDelete;\n        try {\n            ncmpDelete = objectMapper.readValue((String) firstRequest.getData(), NcmpDelete.class);\n        } catch (final JsonProcessingException e) {\n            return new ResponseEntity<>(HttpStatus.BAD_REQUEST);\n        }\n\n        final String targetIdentifier = ncmpDelete.getTargetIdentifier();\n        if (targetIdentifier == null) {\n            return new ResponseEntity<>(HttpStatus.BAD_REQUEST);\n        }\n\n        final Matcher matcher = ERROR_CODE_PATTERN.matcher(targetIdentifier);\n        if (matcher.find()) {\n            final int errorCode = Integer.parseInt(matcher.group(1));\n            return new ResponseEntity<>(HttpStatusCode.valueOf(errorCode));\n        }\n\n        return createPolicyExecutionResponse(targetIdentifier);\n    }\n\n    private ResponseEntity<PolicyExecutionResponse> createPolicyExecutionResponse(String targetIdentifier) {\n        final String decisionId = String.valueOf(++decisionCounter);\n        final String decision;\n        final String message;\n\n        if (targetIdentifier.toLowerCase(Locale.getDefault()).contains(\"cps-is-great\")) {\n            decision = \"allow\";\n            message = \"All good\";\n        } else {\n            decision = \"deny\";\n            message = \"Only FDNs containing 'cps-is-great' are allowed\";\n        }\n\n        final PolicyExecutionResponse policyExecutionResponse =\n                new PolicyExecutionResponse(decisionId, decision, message);\n\n        return ResponseEntity.ok(policyExecutionResponse);\n    }\n}",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
      "updated": "2024-07-31 11:22:56.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
