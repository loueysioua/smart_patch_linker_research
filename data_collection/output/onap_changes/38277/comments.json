      "file_path": "common/openecomp-tosca-datatype/src/main/java/org/openecomp/sdc/tosca/datatypes/model/Implementation.java",
      "patchset_number": 1,
      "line": 41,
      "message": "do you care about the order of the items in the lists or you just want to make sure that all values from this.dependencies are exists in that.dependencied?\nList.equals will fail if all values in list A exist in list B but in different order. \nplease keep that in mind.\nif the order is not relevant for your comparison, create set of each list and then use set1.equals(set2)",
      "author": {
        "account_id": 1741,
        "name": "Avi Gaffa",
        "display_name": null,
        "email": "avi.gaffa@amdocs.com",
        "username": "avigaffa"
      },
      "updated": "2018-03-26 12:13:26.000000000",
