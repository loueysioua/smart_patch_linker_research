    },
    {
      "id": "5a93c517_39ac568c",
      "file_path": "common/openecomp-tosca-datatype/src/main/java/org/openecomp/sdc/tosca/datatypes/model/InterfaceDefinitionTemplate.java",
      "patchset_number": 1,
      "line": 61,
      "message": "in order to use Objects.equals, you must get familiar with equals function of the first argument class.\n\nObjects.equals(operations, that.operations);\nthis will first do a comparison that all keys from this exist in that keys and for each key it will check if the value is of the same type regardless of the values in the members of OperationDefinitionTemplate.\n\nthis can give you bad behavior.\n\nmaybe you should use compare instead(but the your object should be comparable )",
      "author": {
