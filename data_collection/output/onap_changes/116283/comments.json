      "id": "742f77e3_696e5a2e",
      "file_path": "kubernetes/common/common/templates/_certServiceClient.tpl",
      "patchset_number": 11,
      "line": 33,
      "message": "Really great idea to deliver SANs separately. In this form values could be easily used with CertManager. The ultimate goal is to use the same set of variables in end component and either use CertService client (cmpv2Enabled = true + cmpv2CertManagerIntegration = false) or CertManager integration (cmpv2Enabled = true + cmpv2CertManagerIntegration = true).",
      "author": {
        "account_id": 5775,
        "name": "Pawel Baniewski",
        "display_name": "Pawel Baniewski",
        "email": "pawel.baniewski@nokia.com",
