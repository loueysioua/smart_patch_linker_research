      "file_path": "sms-client/src/java/main/SmsClient.java",
      "patchset_number": 3,
      "line": 118,
      "message": "The API call that sends the data over the wire takes a String anyways. This way user can choose any java object type and convert to String before calling this API. The JSONObject provides toString() method and can be used to convert to String. It's also very common in java to directly use String for small set of value pairs.",
      "author": {
        "account_id": 3087,
        "name": "Manjunath Ranganathaiah",
        "display_name": null,
        "email": "manjunath.ranganathaiah@intel.com",
        "username": "mrangana"
      },
