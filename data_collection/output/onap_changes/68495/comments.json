    {
      "id": "1a76adc5_8dc0f5e1",
      "file_path": "packages/install/src/files/base.conf",
      "patchset_number": 1,
      "line": 41,
      "message": "No, the way the code is setup prior to any of my changes it uses this property to structure the whole username user@policy.onap.org. If the clientAuth value does not have an \"@\" in it, the code appends \"@\" + POLICY_AAF_NAMESPACE property to before sending request to AAF.  The property names could be better named but I don't like changing code that is working.  However, if the team thinks this is a must change I can change and --amend.  Technically POLICY_AAF_RESOURCE is the namespace property and I am not sure why Tarun made it this way originally.",
      "author": {
        "account_id": 805,
        "name": "Michael Mokry",
        "display_name": null,
        "email": "michael.mokry@att.com",
        "username": "mmokry"
      },
      "updated": "2018-09-24 13:40:45.000000000",
