    {
      "id": "b7ca2b35_45dddac7",
      "file_path": "models-base/src/main/java/org/onap/policy/models/base/utils/BeanCopyUtils.java",
      "patchset_number": 2,
      "line": 112,
      "message": "As far as I can make out, this method does not clone fields that are objects, it just sets a reference to the original object field in the new cloned object. This is not the behaviour of the original copyTo method.\n\nThe copyTo method MUST create a fully cloned copied object becasue they are used for reading from the database and, on database reads, the way JPA behaves means that the DAO must clone all objects to new objects if they are to exist outside the JPA transaction context.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2019-08-14 10:13:48.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
