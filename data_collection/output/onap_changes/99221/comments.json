        "account_id": 4027,
        "name": "Lukasz Grech",
        "display_name": null,
        "email": "lukasz.grech@nokia.com",
        "username": "lgrech"
      },
      "updated": "2020-02-13 10:18:51.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
