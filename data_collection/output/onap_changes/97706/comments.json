    {
      "id": "33507c36_2e7869ec",
      "file_path": "pom.xml",
      "patchset_number": 3,
      "line": 37,
      "message": "I guess question was about why two different maven plugins were used i.e. failsafe and surefire.\n\nCorrect me if I am wrong but I believe that failsafe runs all test then shows failed ones whereas surefire will cancel execution after first failed test.\n\nStill no sure if there is particular reason to keep both plugins?",
      "author": {
        "account_id": 2731,
        "name": "KK",
        "display_name": null,
        "email": "krzysztof.kurczewski@nokia.com",
        "username": "kurczews"
      },
      "updated": "2019-11-05 10:35:51.000000000",
      "in_reply_to": "1f0f2711_a4be1c83",
      "unresolved": false
    },
    {
      "id": "86271175_eecb925f",
      "file_path": "pom.xml",
      "patchset_number": 3,
      "line": 37,
      "message": "The failsafe plugin is responsible for running IT tests.\nThe surefire plugin runs only UT tests. (I've checked it)\n\nSo if you want to skip execution of IT tests during verify JJB you should exclude them within a failsafe plugin configuration.",
      "author": {
        "account_id": 2807,
        "name": "Piotr Wielebski",
        "display_name": null,
        "email": "piotr.wielebski@nokia.com",
        "username": "pwielebs"
      },
      "updated": "2019-11-05 10:46:13.000000000",
      "in_reply_to": "33507c36_2e7869ec",
      "unresolved": false
    },
