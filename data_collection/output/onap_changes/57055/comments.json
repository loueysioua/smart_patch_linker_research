    {
      "id": "da7095c5_f15e2312",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/http/client/internal/JerseyClient.java",
      "patchset_number": 3,
      "line": 23,
      "message": "Any chance of keeping Jackson out. It's a red flag for security vulnerabilities.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2018-07-24 14:52:00.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "da7095c5_919b27c9",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/http/server/internal/JettyServletServer.java",
      "patchset_number": 3,
      "line": 23,
      "message": "Jackson again.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2018-07-24 14:52:00.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "da7095c5_71877310",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/http/client/internal/JerseyClient.java",
      "patchset_number": 4,
      "line": 23,
      "message": "I think imports coming from this library should be avoided.  I hope we could get rid of it in POLICY-1006.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2018-07-24 15:56:08.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "da7095c5_91b6c7db",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/http/client/internal/JerseyClient.java",
      "patchset_number": 4,
      "line": 57,
      "message": "The fix is incomplete, it should change the underlying jersey libraries in the pom that use Jackson to something equivalent that encodes gson.   There is also may other occurrences all over the code that uses JsonIgnore and should all be changed once those underlying library changes.   It will also require regression testing of all the APIs.   I don't think is a small task.  It is probably better to open a different JIRA for it, rather than tackling here.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2018-07-24 15:56:08.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "da7095c5_510caf94",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/http/client/internal/JerseyClient.java",
      "patchset_number": 4,
      "line": 57,
      "message": "JIRA created: https://jira.onap.org/browse/POLICY-1007",
      "author": {
        "account_id": 1581,
        "name": "Michael Morris",
        "display_name": null,
        "email": "michael.morris@ericsson.com",
        "username": "mmis"
      },
      "updated": "2018-07-24 16:12:38.000000000",
      "in_reply_to": "da7095c5_91b6c7db",
      "unresolved": false
    },
