    {
      "id": "fb8e8d32_88283cd2",
      "file_path": "packages/policy-pap-docker/src/main/docker/Dockerfile",
      "patchset_number": 2,
      "line": 7,
      "message": "The fabric8.io/docker-maven-plugin has filtering enabled by default. Properties that we want to replace are specified with the ${..} syntax and the replacement properties are specified through maven properties. Hence, in Dockerfile it is better to use ${..} only for ARGS that are supplied through properties for replacement, for all others we want to bypass this filtering hence remove the curly braces.\nFor example: check this patch out: https://gerrit.onap.org/r/#/c/policy/drools-applications/+/89204/8/controlloop/packages/docker-controlloop/src/main/docker/Dockerfile\nProperty BUILD_VERSION_APP_CL is supplied through properties for replacement in the file: https://gerrit.onap.org/r/#/c/policy/drools-applications/+/89204/8/controlloop/packages/docker-controlloop/pom.xml L47.",
      "author": {
        "account_id": 159,
        "name": "Rashmi Pujar",
        "display_name": null,
        "email": "rashmi.c.pujar@gmail.com",
        "username": "rashmi.pujar"
      },
      "updated": "2019-06-19 17:53:11.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
