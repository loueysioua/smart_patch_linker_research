    },
    {
      "id": "9adffdf1_43a48ba5",
      "file_path": "sources/hv-collector-core/src/main/kotlin/org/onap/dcae/collectors/veshv/model/ClientContext.kt",
      "patchset_number": 4,
      "line": 36,
      "message": "If we add more and more mdcs the constructor can grow really big. Wouldn't it be better idea to keep all the context properties in string to object map?",
