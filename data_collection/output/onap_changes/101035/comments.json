    {
      "id": "056c4c44_049af19a",
      "file_path": "datarouter-prov/src/main/java/org/onap/dmaap/datarouter/provisioning/utils/ProvDbUtils.java",
      "patchset_number": 1,
      "line": 69,
      "message": "So in general both login and password are considered to be a secret data in this use case.\nThe less attacker can get for free the safer you are.\nAdditionally if we ever want to migrate towards vault then the username is also generated by the vault service for every access. So allowing to pass both login and password makes us safer, more future proof and introduces very very very negligible code/performance penalty, so why not just do it?",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
