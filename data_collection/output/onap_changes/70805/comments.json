      "patchset_number": 1,
      "line": 57,
      "message": "Question - a String can have two 'empty' representations: null and '' (emptyString) Shouldn't an empty string be also verified here ?",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
