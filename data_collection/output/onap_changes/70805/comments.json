    },
    {
      "id": "bada0100_57279e64",
      "file_path": "bpmn/so-bpmn-infrastructure-common/src/main/java/org/onap/so/bpmn/infrastructure/pnf/delegate/CheckAaiForCorrelationIdDelegate.java",
      "patchset_number": 1,
      "line": 57,
      "message": "Ok, I see that value CAN be set to empty string, in case of no value. I'll change code to reflect that.",
