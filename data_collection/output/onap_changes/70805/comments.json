    },
    {
      "id": "bada0100_17735681",
      "file_path": "bpmn/so-bpmn-infrastructure-common/src/main/java/org/onap/so/bpmn/infrastructure/pnf/delegate/CheckAaiForCorrelationIdDelegate.java",
      "patchset_number": 1,
      "line": 57,
      "message": "Empty string is a value, null is a lack of any value. They are totally different things. All I'm checking here is if someone set correlationId to any value.",
      "author": {
        "account_id": 2795,
        "name": "Lukasz Biniek",
        "display_name": null,
        "email": "lukasz.biniek@nokia.com",
        "username": "Biniek"
      },
      "updated": "2018-10-19 12:42:46.000000000",
