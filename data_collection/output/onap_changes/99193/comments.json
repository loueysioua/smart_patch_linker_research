    {
      "id": "15ee63a2_b728f520",
      "file_path": "packages/policy-pap-tarball/src/main/resources/etc/defaultConfig.json",
      "patchset_number": 1,
      "line": 50,
      "message": "This works when you are running different policy components locally on different ports. But when it comes to kubernetes deployment (oom), or docker-compose(the csit way), each component has its own service.\nAPI and Distribution components have its own service, and all these components have exposed 6969 as their port.\nJust providing the correct service name as host amd 6969 as port should work I believe.",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
