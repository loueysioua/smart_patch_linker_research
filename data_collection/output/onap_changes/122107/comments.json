      "patchset_number": 3,
      "line": 187,
      "message": "This really is here to make it backward compatible. outgoingEventSet is a newly introduced field. Even for already created policy models, this will pick up the outgoingEvent and add it to the set. If outgoingEventSet is already populated, then everything is perfect.",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
      },
