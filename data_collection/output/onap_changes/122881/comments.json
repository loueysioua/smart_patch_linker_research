      "id": "6953cb1b_1331070e",
      "file_path": "cps-ri/src/test/groovy/org/onap/cps/spi/impl/CpsDataPersistenceServiceIntegrationSpec.groovy",
      "patchset_number": 2,
      "line": 416,
      "message": "As per the story, if the list-node xpath is provided like /parent-201/child-204[key=\"A\"], even then the deletion should work as it would for /parent-201/child-204.\nPlease add a scenario to test the same.\n\nAlso add a scenario to test the deletion of a list-node like /parent-201/child-203/grandchild-205[@key=\"A\"]",
      "author": {
        "account_id": 6738,
        "name": "aditya puthuparambil",
        "display_name": null,
        "email": "aditya.puthuparambil@bell.ca",
