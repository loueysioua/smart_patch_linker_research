          "email": "b.grzybowski@partner.samsung.com",
          "username": "bgrzybowski"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-03-28 12:30:45.000000000",
        "message": "Patch Set 1:\n\nPersonally i would call the directory 'ansible/molecule' instead of 'ansible/test'.",
        "patchset_number": 1
      },
