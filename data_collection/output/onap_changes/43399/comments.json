    {
      "id": "5a93c517_e56faa5e",
      "file_path": "policy-utils/src/main/java/org/onap/policy/drools/utils/logging/MDCTransaction.java",
      "patchset_number": 5,
      "line": 568,
      "message": "Sonar complains whenever an implementer of an interface has a member variable that is identical to a variable defined in the interface.",
      "author": {
        "account_id": 1645,
        "name": "Drew Magnusen",
        "display_name": null,
        "email": "dm741q@att.com",
        "username": "dm741q"
      },
      "updated": "2018-04-19 15:25:55.000000000",
