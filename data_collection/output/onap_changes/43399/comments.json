      "unresolved": false
    },
    {
      "id": "5a93c517_45ad3e83",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/drools/event/comm/bus/internal/SingleThreadedDmaapTopicSource.java",
      "patchset_number": 5,
      "line": 40,
      "message": "The right solution in this case is to remove the allowSelfSignedCerts from here if is defined in the base class instead of renaming it.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2018-04-19 15:42:11.000000000",
      "in_reply_to": "5a93c517_45b1beff",
