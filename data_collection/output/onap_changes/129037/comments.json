    {
      "id": "39db9bae_26c20792",
      "file_path": "components/slice-analysis-ms/src/main/java/org/onap/slice/analysis/ms/service/PolicyService.java",
      "patchset_number": 2,
      "line": 178,
      "message": "Right, in regards to line 177,178. The CCVPN closed loop we designed doesn't need to send any AAI info to Policy. In other words, the receiver side of Policy doesn't need that info. However, it appears in our test that Policy has a safe guide checking for this Field. There must be a generic-vnf.vnf-id, generic-vnf.vnf-name, generic-vnf.vnf-status, cannot ignore these fields or giving null value. That's why I put all 0's. To the best of my knowledge.",
      "author": {
        "account_id": 7453,
        "name": "Decheng Zhang",
        "display_name": null,
        "email": "decheng.zhang@huawei.com",
        "username": "dzhang2020huawei"
      },
      "updated": "2022-05-03 01:35:23.000000000",
      "in_reply_to": "8978d479_0fdd9542",
      "unresolved": true
    },
