    },
    {
      "id": "f7d57ab7_0c33bf64",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/comm/PdpMessageGenerator.java",
      "patchset_number": 5,
      "line": 154,
      "message": "Yes, also if the status records are not updates, then someone using the status API will see the policies as deployed into the PDP, whereas the PDP is actually in passive state. There is no field to indicate that PdPGroup is in PASSIVE state. So, I think it makes sense to update the status records.",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
