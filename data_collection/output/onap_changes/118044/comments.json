    {
      "id": "b56b987d_34172ade",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/comm/PdpMessageGenerator.java",
      "patchset_number": 5,
      "line": 154,
      "message": "the question is: should we delete a deployment when a PDP goes PASSIVE?  I guess it's OK, since this only impacts the status records, and they're re-inserted when it goes active.  In addition, deleting them when PASSIVE will prevent CLAMP from seeing records for a passive PDP - that makes sense.",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2021-02-19 14:30:56.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "c8c4bf0f_c2bf1424",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/comm/PdpMessageGenerator.java",
      "patchset_number": 5,
      "line": 155,
      "message": "delete this check - it adds no value and requires additional junit tests to provide full coverage",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2021-02-19 14:30:56.000000000",
