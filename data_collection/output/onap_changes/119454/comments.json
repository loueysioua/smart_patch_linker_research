    {
      "id": "f973ad19_8f5365ae",
      "file_path": "kubernetes/so/components/so-sdnc-adapter/values.yaml",
      "patchset_number": 4,
      "line": 31,
      "message": "This should come from the external secrets. \nFor example:\n  - uid: cnf-adapter-mso-key\n    name: '{{ include \"common.release\" . }}-so-cnf-mso-key'\n    type: password\n    externalSecret: '{{ tpl (default \"\" .Values.mso.msoKeySecret) . }}'\n    password: '{{ .Values.mso.msoKey }}'\n\n\nand then in the deployment.yaml\n\n          env:\n            - name: MSO_KEY\n              {{- include \"common.secret.envFromSecretFast\" (dict \"global\" . \"uid\" \"cnf-adapter-mso-key\" \"key\" \"password\") | indent 14 }}",
      "author": {
        "account_id": 897,
        "name": "Seshu Kumar Mudiganti",
        "display_name": null,
        "email": "seshukumar.mudiganti@windriver.com",
        "username": "seshukm"
      },
