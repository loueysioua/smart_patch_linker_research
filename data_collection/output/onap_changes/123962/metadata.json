      {
        "id": "31ad3a810fd5f25f47e1077a35ad8a15b21d1fe7",
        "author": {
          "account_id": 6070,
          "name": "Ramesh Murugan Iyer",
          "display_name": null,
          "email": "ramesh.murugan.iyer@est.tech",
          "username": "rameshiyer27"
        },
        "author_role": "OWNER",
        "timestamp": "2021-09-13 07:29:42.000000000",
        "message": "Patch Set 4:\n\n> Patch Set 4: Code-Review-1\n> \n> We are in trouble with a 64 character limit on the config map: Let's use\n> \n> policy-clamp-cl-pf-ppnt\n> policy-clamp-cl-http-ppnt\n> policy-clamp-cl-k8s-ppnt\n\nHi Liam, For the character limit issue, we can only change the helm chart name and config map names in oom. The name of docker image can be the same.",
        "patchset_number": 4
      },
      {
        "id": "074246f907e20e15b88a36e0ec5c93af29a294bf",
        "author": {
          "account_id": 2787,
          "name": "Liam Fallon",
          "display_name": null,
          "email": "liam.fallon@est.tech",
          "username": "liamfallon"
        },
        "author_role": "REVIEWER",
        "timestamp": "2021-09-13 08:24:12.000000000",
        "message": "Patch Set 4:\n\n> Patch Set 4:\n> \n> > Patch Set 4: Code-Review-1\n> > \n> > We are in trouble with a 64 character limit on the config map: Let's use\n> > \n> > policy-clamp-cl-pf-ppnt\n> > policy-clamp-cl-http-ppnt\n> > policy-clamp-cl-k8s-ppnt\n> \n> Hi Liam, For the character limit issue, we can only change the helm chart name and config map names in oom. The name of docker image can be the same.\n\nI think its better to fix here as well for consistency.",
        "patchset_number": 4
