    {
      "id": "5a93c517_56fe88af",
      "file_path": "kubernetes/aaf/charts/sms/templates/deployment.yaml",
      "patchset_number": 1,
      "line": 41,
      "message": "I would prefer to use in service .Values.service.name instead of common.fullname in service definition. This will provide a constant service, instead of one prefixed with the name of the helm deployment (Release.Name). It will enable deploying subsets of onap (components A,C,E in one command and B,D,F in another). Otherwise it is impossible, because the Release.Name part of common.fullname is different for each.",
      "author": {
        "account_id": 497,
        "name": "Borislav Glozman",
        "display_name": null,
        "email": "borislav.glozman@amdocs.com",
        "username": "BorislavG"
      },
      "updated": "2018-04-08 06:55:00.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "5a93c517_462fb188",
      "file_path": "kubernetes/aaf/charts/sms/templates/deployment.yaml",
      "patchset_number": 1,
      "line": 41,
      "message": "Understood. I will make the change to use the name. However, this might have one side effect though. Will you be able to create multiple helm deployments with different names? They would have to be differentiated by name space?",
      "author": {
        "account_id": 301,
        "name": "Kiran Kamineni",
        "display_name": null,
        "email": "kiran.k.kamineni@intel.com",
        "username": "kirankamineni"
      },
      "updated": "2018-04-09 17:25:52.000000000",
      "in_reply_to": "5a93c517_56fe88af",
      "unresolved": false
    },
    {
      "id": "5a93c517_c644211d",
      "file_path": "kubernetes/aaf/charts/sms/templates/deployment.yaml",
      "patchset_number": 1,
      "line": 41,
      "message": "Exactly, they would be differentiated by namespace.\nIn the same namespace though, you do not have to specify the namespace implicitly.",
