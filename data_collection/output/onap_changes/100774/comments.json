    {
      "id": "01cd066f_4c597204",
      "file_path": "policy-management/src/main/server-gen/bin/deploy-artifact",
      "patchset_number": 5,
      "line": 234,
      "message": "I dont think the block is needed, it seems to be working for me at least, see below:\n\n--------  Execution -----------\n\n[~/tmp] ./a.sh\ntrying with http_proxy=http://a.proxy.com:8080\n-DproxyHost=a.proxy.com -DproxyPort=8080\n\n\ntrying with http_proxy=http://jhh:abcd@a.proxy.com:8080\n-DproxyHost=a.proxy.com -DproxyPort=8080\n\n--------------------- script -------------\n\n[~/tmp] cat a.sh\n#!/bin/bash\n\nfunction hostPort() {\n\techo \"trying with http_proxy=$http_proxy\"\n\n\tlocal proxy_cred=${http_proxy#*//}\n\tlocal proxy=${proxy_cred##*@}\n\tlocal host=${proxy%%:*}\n\tlocal port=${proxy##*:}\n\n\tMVN_PROXY_SETTINGS=\"-DproxyHost=${host} -DproxyPort=${port}\"\n\techo \"$MVN_PROXY_SETTINGS\"\n}\n\nhttp_proxy=http://a.proxy.com:8080\nhostPort\n\necho\necho\n\nhttp_proxy=http://jhh:abcd@a.proxy.com:8080\nhostPort\n\necho\necho\n\n[~/tmp]",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
