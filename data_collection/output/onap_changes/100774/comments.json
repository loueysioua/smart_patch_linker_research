    {
      "id": "71139d40_3798aada",
      "file_path": "packages/docker/src/main/docker/Dockerfile",
      "patchset_number": 2,
      "line": 11,
      "message": "I think a better name for this would be http_proxy, as the OS env. var.   Linux OS apps typically honor the system variables with this name, so if a proxy is used, this would also solve problems within the Linux OS.   Note that the syntax would be a little different, there would be no http port as the http_proxy would include the port.   In drools tooling downstream would need to be aware of that to separate host and port to pass in to mvn.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2020-01-27 13:40:51.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
