      "file_path": "cps-ri/src/main/java/org/onap/cps/spi/impl/CpsDataPersistenceServiceImpl.java",
      "patchset_number": 7,
      "line": 396,
      "message": "Is this validation good enough? What if an invalid xpath is passed as '/parent/child]'",
