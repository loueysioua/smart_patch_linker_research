    {
      "id": "b89feb78_8790fcd8",
      "file_path": "cps-service/src/main/java/org/onap/cps/spi/exceptions/ListNodeGivenException.java",
      "patchset_number": 1,
      "line": 37,
      "message": "I decided to include this different exception as opposed to the dataNodeNotFound exception because, you could enter an existing data list node, but it would still throw a not found exception. I think specifying that it's a list node gets rid of that confusion.",
      "author": {
        "account_id": 7744,
