    {
      "id": "12dfe7d4_0249c5cd",
      "file_path": "kubernetes/sdnc/templates/statefulset.yaml",
      "patchset_number": 2,
      "line": 36,
      "message": "Instead of providing this mapping in helm charts, it would probably be better to refer to AAF via its advertised k8s service.  However, that assumes that each ONAP environment has a stable AAF instance configured with the necessary credentials.  I think that's why we had this mapping - to map to one AAF instance that we knew had our credentials preinstalled.  Is it safe to remove that mapping now and instead use the AAF service endpoint?",
      "author": {
        "account_id": 87,
        "name": "Dan Timoney",
        "display_name": null,
        "email": "dtimoney@att.com",
        "username": "djtimoney"
      },
      "updated": "2019-12-11 16:08:18.000000000",
      "in_reply_to": "b709e4f3_9eb32c89",
      "unresolved": true
    },
