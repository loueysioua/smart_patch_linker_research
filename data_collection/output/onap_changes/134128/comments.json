    {
      "id": "be0434bd_6d400921",
      "file_path": "integration-test/src/test/groovy/org/onap/cps/integration/performance/cps/CpsDataServiceLimits.groovy",
      "patchset_number": 6,
      "line": 50,
      "message": "This one deletes datanodes by xpaths. It was implemented to throw a DataNodeNotFoundException (batch) if any xpaths don't exist, as NCMP handle de-registration expects the exception to be thrown to report errors in the REST response.\n\nIt throws the exception since the supplied xpaths don't exist:\n /size/of/this/path/does/not/matter/for/limit[@id='1']\n\nSo here we expect a CPS exception, but not a database exception!",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2023-04-24 10:31:59.000000000",
      "in_reply_to": "3bf5a2b3_38aa91a3",
      "unresolved": true
    },
