      {
        "id": "ead52af78aae41397bc109261cd129e536d2f5c8",
        "author": {
          "account_id": 3957,
          "name": "Samuli Silvius",
          "display_name": null,
          "email": "s.silvius@partner.samsung.com",
          "username": "silvius"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-05-14 17:29:47.000000000",
        "message": "Patch Set 6:\n\nwhy destroy.yml is needed? Could we contribute to molecule? What is missing?",
        "patchset_number": 6
      },
      {
        "id": "b600e33f7ba898afef30aa2cedf42ec75d519919",
        "author": {
          "account_id": 5019,
          "name": "Michal Zegan",
          "display_name": null,
          "email": "m.zegan@samsung.com",
          "username": "m.zegan"
        },
        "author_role": "OWNER",
        "timestamp": "2019-05-14 17:35:46.000000000",
        "message": "Patch Set 6:\n\n> why destroy.yml is needed? Could we contribute to molecule? What is\n > missing?\n\nIt is needed because in case of this specific role, the containers have anonymous volumes created with them. The default destroy.yml of molecule does not take them down along with the container.\nThis version of destroy.yml is a verbatim copy of molecule's own, just with added flag to remove volumes during container removal. Othervise we waste really a lot of space.",
        "patchset_number": 6
      },
      {
        "id": "625a1dd7faf8865376408297b1ba4b7bb86f4b03",
        "author": {
          "account_id": 3957,
          "name": "Samuli Silvius",
          "display_name": null,
          "email": "s.silvius@partner.samsung.com",
          "username": "silvius"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-05-14 17:44:01.000000000",
        "message": "Patch Set 6:\n\n> > why destroy.yml is needed? Could we contribute to molecule? What\n > is\n > > missing?\n > \n > It is needed because in case of this specific role, the containers\n > have anonymous volumes created with them. The default destroy.yml\n > of molecule does not take them down along with the container.\n > This version of destroy.yml is a verbatim copy of molecule's own,\n > just with added flag to remove volumes during container removal.\n > Othervise we waste really a lot of space.\n\nso molecule cleanup cannot be used for this?",
        "patchset_number": 6
      },
      {
        "id": "f668d3b61d7c1c2d787610ae06a699efcad2661f",
        "author": {
          "account_id": 5019,
          "name": "Michal Zegan",
          "display_name": null,
          "email": "m.zegan@samsung.com",
          "username": "m.zegan"
        },
        "author_role": "OWNER",
        "timestamp": "2019-05-14 17:46:57.000000000",
        "message": "Patch Set 6:\n\n> > > why destroy.yml is needed? Could we contribute to molecule?\n > What\n > > is\n > > > missing?\n > >\n > > It is needed because in case of this specific role, the\n > containers\n > > have anonymous volumes created with them. The default destroy.yml\n > > of molecule does not take them down along with the container.\n > > This version of destroy.yml is a verbatim copy of molecule's own,\n > > just with added flag to remove volumes during container removal.\n > > Othervise we waste really a lot of space.\n > \n > so molecule cleanup cannot be used for this?\n\nIt can in theory, but ... cleanup is probably called before destroy, so it cannot remove volumes of containers that are running.\nEven in case it would, you would need to either blindly remove all unused volumes or use some unspecified magic to collect what volumes were attached to the containers.\nThat way it is just one simple switch in docker_container module that removes all volumes attached to container.",
        "patchset_number": 6
      },
      {
        "id": "f0f0542f84cac1664ffba99d5527d3d1b7bce22d",
        "author": {
          "account_id": 459,
          "name": "ONAP Jobbuilder",
          "display_name": null,
          "email": "onap-jobbuilder@jenkins.onap.org",
          "username": "onap-jobbuilder"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-05-14 17:55:00.000000000",
        "message": "Patch Set 6:\n\nBuild Started https://jenkins.onap.org/job/offline-installer-master-review/90/",
        "patchset_number": 6
      },
      {
        "id": "76ae9e80668a136a4a26e82c2e19e8cbe6925a43",
        "author": {
          "account_id": 3957,
          "name": "Samuli Silvius",
          "display_name": null,
          "email": "s.silvius@partner.samsung.com",
          "username": "silvius"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-05-14 17:58:08.000000000",
        "message": "Patch Set 6:\n\n> > > > why destroy.yml is needed? Could we contribute to molecule?\n > > What\n > > > is\n > > > > missing?\n > > >\n > > > It is needed because in case of this specific role, the\n > > containers\n > > > have anonymous volumes created with them. The default\n > destroy.yml\n > > > of molecule does not take them down along with the container.\n > > > This version of destroy.yml is a verbatim copy of molecule's\n > own,\n > > > just with added flag to remove volumes during container\n > removal.\n > > > Othervise we waste really a lot of space.\n > >\n > > so molecule cleanup cannot be used for this?\n > \n > It can in theory, but ... cleanup is probably called before\n > destroy, so it cannot remove volumes of containers that are\n > running.\n > Even in case it would, you would need to either blindly remove all\n > unused volumes or use some unspecified magic to collect what\n > volumes were attached to the containers.\n > That way it is just one simple switch in docker_container module\n > that removes all volumes attached to container.\n\nOk, we could contribute to molecule and add \"keep_volumes\" option.",
        "patchset_number": 6
      },
