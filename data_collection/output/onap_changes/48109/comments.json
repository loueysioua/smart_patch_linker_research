      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "5a93c517_26b45c81",
      "file_path": "docs/Chapter5.rst",
      "patchset_number": 5,
      "line": 2424,
      "message": "This may be a problem for existing VNFs.\n In scenario where the VNF provider may wish to support the optional to manually deploy and scale as an optional use case, it would be complicated to scale manually using modular templates since the incremental template needs several resource IDs from the base template.\n  The original motivation  for avoiding ‘heat stack-update’ support originates from a bug that existed in early OpenStack releases, which could cause existing resources to be replaced at scaling. It shouldn't be applicable anymore. Also looking forward using HOT ResourceGroup (which is used when scaling with heat stack-update) is similar to how could design K8s templates using ReplicaSet/StatefulSet.",
      "author": {
        "account_id": 451,
        "name": "John Quilty",
        "display_name": null,
        "email": "john.quilty@ericsson.com",
        "username": "joquiltyL"
      },
      "updated": "2018-05-21 14:52:52.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
