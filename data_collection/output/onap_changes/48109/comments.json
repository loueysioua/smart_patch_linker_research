    {
      "id": "5a93c517_e38666ba",
      "file_path": "docs/Chapter5.rst",
      "patchset_number": 5,
      "line": 2384,
      "message": "Sure it a case of \nR-89913 A VNF’s Heat Orchestration Template’s Cinder Volume Module  **MUST** containbe the UUID(s) of the Cinder Volumes created in template as one of the Output Parameters.\n\nAs it is written you cannot have any other output parameters from the Cinder Volume Module. Is that the intention?",
      "author": {
        "account_id": 451,
        "name": "John Quilty",
        "display_name": null,
        "email": "john.quilty@ericsson.com",
        "username": "joquiltyL"
      },
