    {
      "id": "1a76adc5_47af07e4",
      "file_path": "plugins/reception-plugins/src/main/java/org/onap/policy/distribution/reception/handling/sdc/HsdcConfiguration.java",
      "patchset_number": 2,
      "line": 33,
      "message": "You will need this class to map the parameters coming into you from the main configuration. Can you have a chat with Ram because he is working on the configuration part right now.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
