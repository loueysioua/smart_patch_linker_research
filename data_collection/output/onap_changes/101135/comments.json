    {
      "id": "9c34843a_e24d766e",
      "file_path": "error-catalog-lib/src/main/kotlin/org/onap/ccsdk/error/catalog/service/ErrorCatalogDatabaseHandler.kt",
      "patchset_number": 17,
      "line": 73,
      "message": "why not use string interpolation, there's so many () for no reason? Also do we really need a constant that contains 21 characters to replace '.'? Considering it's private and used only once? i feel like \"${domain.name}.${errorMessageFound.messageID}\" is much clearer.",
      "author": {
        "account_id": 5732,
        "name": "Sebastien Premont-Tendland",
        "display_name": null,
        "email": "sebastien.premont@bell.ca",
