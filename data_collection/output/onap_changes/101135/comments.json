      "file_path": "error-catalog-lib/src/main/kotlin/org/onap/ccsdk/error/catalog/service/ErrorMessagesLibPropertyService.kt",
      "patchset_number": 17,
      "line": 62,
      "message": "We should not throw an exception in the finally clause. We should check if null before closing there. If we want to throw an exception it should be done in the try (where we already handle exceptions and decided to simply log the error). We should simply use inputStream?.close() here",
      "author": {
        "account_id": 5732,
        "name": "Sebastien Premont-Tendland",
        "display_name": null,
        "email": "sebastien.premont@bell.ca",
        "username": "spremont"
      },
      "updated": "2020-02-26 22:15:58.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
