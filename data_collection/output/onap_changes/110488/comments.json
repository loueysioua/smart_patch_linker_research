    {
      "id": "40e4c902_b0e82b30",
      "file_path": "datafile-app-server/src/main/java/org/onap/dcaegen2/collectors/datafile/tasks/ScheduledTasks.java",
      "patchset_number": 4,
      "line": 229,
      "message": "I cannot find it on the wiki now, but at least last year the recommendation was that all files available on the node should be sent in every message, see this quote:\n\"The FileReady notification will send information on files that are available on the node to collect every ROP, the files are ordered in descending chronological order (latest files a top of the message). Files on the node older than 24 hours are not sent in the FileReady notification.\"\nThis is because the node have no idea wether the DFC has been able to collect the files or not. This is also the whole reason why DFC queries the DataRouter to see if a file has already been published.",
      "author": {
        "account_id": 3763,
        "name": "Henrik Andersson",
        "display_name": null,
        "email": "henrik.b.andersson@est.tech",
        "username": "elinuxhenrik"
      },
      "updated": "2020-07-27 11:03:49.000000000",
      "in_reply_to": "1f896282_51e4ea1b",
      "unresolved": true
    },
