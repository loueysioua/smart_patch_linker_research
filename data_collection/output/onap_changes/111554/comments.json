    {
      "id": "2eeeec22_a21a4d63",
      "file_path": "components/pm-subscription-handler/tests/test_network_function_filter.py",
      "patchset_number": 6,
      "line": 1,
      "message": "I think the majority if not all the tests in this class be converted in a single data driven test.\nThere is a decent article on it here\n\nhttps://medium.com/ranorex-webtestit/data-driven-testing-using-python-and-the-parameterized-module-37e2cb863915\n\n\nI'd say its worth it for the maintainability alone, never mind the simplicity in adding new scenarios in the future.",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-09-02 13:52:02.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
