    {
      "id": "ecfaccda_f9e9b656",
      "file_path": "components/pm-subscription-handler/tests/test_network_function_filter.py",
      "patchset_number": 6,
      "line": 1,
      "message": "Not quite sure how to go about this. Would we need filter information and test criteria in a csv/json",
      "author": {
        "account_id": 4893,
        "name": "Gerard Nugent",
        "display_name": null,
        "email": "gerard.nugent@est.tech",
        "username": "egernug"
