    {
      "id": "f4deda76_162636aa",
      "file_path": "/COMMIT_MSG",
      "patchset_number": 6,
      "line": 7,
      "message": "We try to keep the service the change relates to in the commit message, as this repo has multiple services in it.\nAlso majority of the time we use the imperative mood in commits,\nSomething like Enhance Filtering Mechanism or Add Support for Enhanced Filtering.\nhttps://en.wikipedia.org/wiki/Imperative_mood",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-09-02 13:52:02.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
