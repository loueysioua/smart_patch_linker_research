      "file_path": "main/src/test/java/org/onap/policy/pap/main/rest/TestPolicyStatusProvider.java",
      "patchset_number": 1,
      "line": 244,
      "message": "there are 2 getStatus, one is without parameter, second is with parameters. When there is no ambiguity, then you can use any",
      "author": {
        "account_id": 7662,
        "name": "Arkadiusz Adamski",
        "display_name": null,
        "email": "aadamski@est.tech",
        "username": "arkadiusz.adamski"
      },
      "updated": "2021-04-27 14:39:39.000000000",
