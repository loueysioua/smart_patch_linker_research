    {
      "id": "81d8a58a_a3e92a9f",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/rest/PolicyStatusControllerV1.java",
      "patchset_number": 1,
      "line": 142,
      "message": "I think some regex characters could conflict with url characters and would need to be escaped, may not be very convenient for manual testing as they will have to be escaped.   One other option would be to have a POST method specific to regex, so the regex could be embedded in the body of the POST, something sort of ..\n\n@Path(\"policies/deployed/regex\")\nand in body somthing sort of:\n{ regex: \"^[a-z0-9]+\"}\n\n@Path(\"policies/deployed\") will stay as is and a new method would be added with the proposal",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2021-04-28 14:48:57.000000000",
      "in_reply_to": "6294ff7f_4b3dccc7",
      "unresolved": true
    },
