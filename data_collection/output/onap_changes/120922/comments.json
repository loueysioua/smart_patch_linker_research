      "file_path": "main/src/main/java/org/onap/policy/pap/main/rest/PolicyStatusControllerV1.java",
      "patchset_number": 1,
      "line": 142,
      "message": "When you have some characters, that are not allowed in url params, you should use some URL encoding. (https://developer.mozilla.org/en-US/docs/Glossary/percent-encoding)",
      "author": {
        "account_id": 7662,
        "name": "Arkadiusz Adamski",
