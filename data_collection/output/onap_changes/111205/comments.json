      "file_path": "odlsli/odlsli-alpine/pom.xml",
      "patchset_number": 2,
      "line": 46,
      "message": "Thank you Dan for the workaround. \nCan you please check this review? https://gerrit.onap.org/r/c/ccsdk/oran/+/111424",
