    {
      "id": "8ec11146_efa0a848",
      "file_path": "odlsli/odlsli-alpine/pom.xml",
      "patchset_number": 2,
      "line": 46,
      "message": "Latish - the  issue is you need to be careful what version of the sli core classes you compile your oran repo against.  You are using version 2.0.1-SNAPSHOT of the parent pom - which specifies a snapshot version - but this pom installs the released 1.0.0 version of the sli core classes.  This will break the container.\n\nThe best fix would be to update the oran pom to explicitly set ccsdk.sli.core.version to 1.0.0.  Then there will be no conflict.  Until then, merging this would break the container if the oran adapter is installed.",
      "author": {
        "account_id": 87,
        "name": "Dan Timoney",
        "display_name": null,
        "email": "dtimoney@att.com",
        "username": "djtimoney"
      },
      "updated": "2020-08-18 18:59:12.000000000",
      "in_reply_to": "4a65f580_9cf53e0b",
      "unresolved": true
    },
    {
