    {
      "id": "53856b1d_6b637d6b",
      "file_path": "kubernetes/aaf/components/aaf-cert-service/values.yaml",
      "patchset_number": 8,
      "line": 91,
      "message": "The case here is:\n- We dynamically generate certificates for CertService Client and CertService Server\n- They are packed into two separate secrets \n- The server secret is used in CertSerivce deployment \"{{ .Values.tls.server.secret.name }}\" - so if someone wants to use custom secret, then that secret name should be assigned to the mentioned value\n- The client secret is used in other components, so is someone wants to use custom secret, then that secret name should be assigned in component where it's used\n- As far as I remember, I was requested to add this boolean value \"certificateExternalSecret\" - this flag was added, because it gives possibility to use own certificates(not to use dynamically generated ones) and in that case we do not create secrets with dynamically generated certs\n\nShould i rename this variable then? If yes, then please give me proper name",
      "author": {
        "account_id": 3771,
        "name": "Adam Wudzinski",
        "display_name": null,
        "email": "adam.wudzinski@nokia.com",
        "username": "adamwudzinski"
      },
      "updated": "2020-07-23 11:32:38.000000000",
      "in_reply_to": "23b7433e_a6d38bd1",
      "unresolved": true
    },
