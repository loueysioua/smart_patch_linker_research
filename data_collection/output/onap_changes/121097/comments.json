    {
      "id": "870296e1_9e3e4a52",
      "file_path": "cps-service/src/main/java/org/onap/cps/api/impl/CpsDataServiceImpl.java",
      "patchset_number": 2,
      "line": 75,
      "message": "data node is a direct reference to DataNode class which is a CPS internal data \nrepresentation artifact. list-node is reference to yang definition, and it has \na representation within a JSON (being parsed) but list-node itself never became a data node",
      "author": {
        "account_id": 7362,
        "name": "Ruslan Kashapov",
        "display_name": null,
        "email": "ruslan.kashapov@pantheon.tech",
        "username": "rkashapov"
      },
      "updated": "2021-05-07 07:17:37.000000000",
      "in_reply_to": "5f7c9d04_1df26b76",
      "unresolved": true
    },
    {
      "id": "9ce2b928_2846acc4",
      "file_path": "cps-service/src/main/java/org/onap/cps/api/impl/CpsDataServiceImpl.java",
      "patchset_number": 2,
      "line": 120,
      "message": "parentNodeXpath is a generic name which has the same meaning \non all the stages of data processing. while parentDataNodeXpath assumes\nreference to CPS internal data representation, which happens _after_\nincoming data transformation. not _before_.",
      "author": {
        "account_id": 7362,
        "name": "Ruslan Kashapov",
        "display_name": null,
        "email": "ruslan.kashapov@pantheon.tech",
        "username": "rkashapov"
      },
      "updated": "2021-05-07 07:17:37.000000000",
      "in_reply_to": "95fea7f0_038e84a3",
      "unresolved": true
    },
