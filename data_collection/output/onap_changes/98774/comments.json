    },
    {
      "id": "e77a6fc7_a895f2ec",
      "file_path": "models-interactions/model-impl/aai/src/main/java/org/onap/policy/aai/AaiManager.java",
      "patchset_number": 1,
      "line": 159,
      "message": "Ideally in the network.log, we should support INFO and DEBUG, INFO with a meaningul header and not the full message, and DEBUG with the full message.  The shortcoming right now is that we only support INFO, or OFF (FATAL-WARN).   One other option would be to have these statements as debug in Network Logger, but it would be inconsistent on how it is used all over, and then the individual componet set up could set it up to however if pleases to set the logger.   In any case, we should always use the Network logger for message exchanges.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2019-11-22 19:39:21.000000000",
      "in_reply_to": "743462da_d266d5a7",
      "unresolved": false
    },
