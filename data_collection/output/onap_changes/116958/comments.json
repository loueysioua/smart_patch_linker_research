    },
    {
      "id": "a1c0c6ba_1d886f68",
      "file_path": "components/pm-subscription-handler/pmsh_service/mod/pmsh_utils.py",
      "patchset_number": 2,
      "line": 230,
      "message": "Fiachra mentioned that at least 1 filter in the nfFilter had to have a value in it, so a completely empty nfFilter would be in valid, but the value of nfNames, modelInvariantIDs, modelVersionIDs, modelName could be empty, as long as not all of them are empty.",
      "author": {
        "account_id": 7475,
        "name": "Antony Saputra",
        "display_name": null,
        "email": "antony.saputra@est.tech",
        "username": "antonys"
      },
      "updated": "2021-01-20 11:18:56.000000000",
      "in_reply_to": "5791b799_67244b42",
      "unresolved": true
    },
    {
