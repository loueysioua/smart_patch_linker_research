    {
      "id": "bd7f6bdf_996f968c",
      "file_path": "bpmn/so-bpmn-tasks/src/main/java/org/onap/so/bpmn/infrastructure/workflow/tasks/utils/WorkflowResourceIdsUtils.java",
      "patchset_number": 7,
      "line": 27,
      "message": "There are no a naming convention related to utility classes. There are differences between utility and helper class, here you have:\nhttps://stackoverflow.com/questions/12192050/what-are-the-differences-between-helper-and-utility-classes\nAccording to the article, helper can be instantiated, so I would not call this class helper. The question is if 'utils' should be a part of the name of utility classes. In the project, there are many utility classes with name 'utils', so let us leave this name as it is.\nAccording to the package, we should gather utility classes with package utils, so it is good as it is now.",
      "author": {
        "account_id": 2789,
        "name": "Lukasz Muszkieta",
        "display_name": null,
        "email": "lukasz.muszkieta@nokia.com",
        "username": "lukaszM"
      },
      "updated": "2020-02-25 17:29:53.000000000",
      "in_reply_to": "bd4fc71c_5aee580f",
      "unresolved": true
    },
