    {
      "id": "78b345c3_06605889",
      "file_path": "bpmn/so-bpmn-tasks/src/main/java/org/onap/so/bpmn/infrastructure/workflow/tasks/utils/WorkflowResourceIdsExtension.java",
      "patchset_number": 6,
      "line": 67,
      "message": "I think that Consumer as return type in this example is overcomplicated. Especially default statement is a little bit confusing. This is a simple logic, and I would write just void method with switch case:\n\n    private void getSetterForResourceType(WorkflowType resourceType, String resourceId) {\n        switch (resourceType) {\n            case SERVICE:\n                 setServiceInstanceId(resourceId);\n            case VNF:\n                setVnfId(resourceId);\n            case PNF:\n                setPnfId(resourceId);\n            case VFMODULE:\n                setVfModuleId(resourceId);\n            case VOLUMEGROUP:\n                setVolumeGroupId(resourceId);\n            case NETWORK:\n                setNetworkId(resourceId);\n            case NETWORKCOLLECTION:\n                setNetworkCollectionId(resourceId);\n            case CONFIGURATION:\n                setConfigurationId(resourceId);\n            case INSTANCE_GROUP:\n                setInstanceGroupId(resourceId);\n        }\n    }",
      "author": {
        "account_id": 2789,
        "name": "Lukasz Muszkieta",
        "display_name": null,
        "email": "lukasz.muszkieta@nokia.com",
        "username": "lukaszM"
      },
      "updated": "2020-02-14 10:36:43.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
