    {
      "id": "3fd8f3d9_012ec1f1",
      "file_path": "kubernetes/common/common/templates/_storage.tpl",
      "patchset_number": 9,
      "line": 65,
      "message": "I think I've just found a solution for your problem which forces you to use this eq construction. How about just changing the needPV definition to:\n{{- define \"common.needPV\" -}}\n{{- if or (or .Values.persistence.storageClassOverride .Values.persistence.storageClass) .Values.global.persistence.storageClass -}}\n{{- else -}}\n  True\n{{- end -}}\n{{- end -}}\n\nbecause empty string is always considered a false then you could drop the whole eq construction and just use:\n\n{{- if (include \"common.needPV\" .) -}}\n\nWhat do you think?",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2019-12-20 23:58:42.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
