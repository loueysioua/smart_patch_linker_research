    {
      "id": "c95ab655_c2739f18",
      "file_path": "robot/resources/policy_interface.robot",
      "patchset_number": 4,
      "line": 249,
      "message": "If the policy is created and deployed, then the delete request will fail. You need to first undeploy the policy and then attempt the delete.",
      "author": {
        "account_id": 3239,
        "name": "Ram Krishna Verma",
        "display_name": null,
        "email": "ramkrishna.verma@gmail.com",
        "username": "ramverma"
