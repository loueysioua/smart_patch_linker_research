    },
    {
      "id": "592a5e7a_50ce93ef",
      "file_path": "robot/resources/policy_interface.robot",
      "patchset_number": 4,
      "line": 249,
      "message": "I agree to the flow that you stated. But Run Delete Policy Request keyword is using an API which is undeploying and deleting the policy simultaneously. Also, even if the policy is not deployed then the same API will only delete created policy. In both the scenarios a single API is performing the action to undeploy and delete.",
      "author": {
        "account_id": 7974,
        "name": "Rommel Ravneet Singh Pawar",
        "display_name": null,
        "email": "rommel.pawar@bell.ca",
        "username": "rommelsingh"
      },
      "updated": "2022-01-28 03:26:31.000000000",
      "in_reply_to": "c95ab655_c2739f18",
      "unresolved": true
    },
    {
      "id": "9391f4b5_ca679a36",
      "file_path": "robot/resources/policy_interface.robot",
      "patchset_number": 4,
      "line": 249,
      "message": "As discussed over call, the delete api call will not work in case policy is deployed. This api will only work if the policy is not deployed or failed an attempt of deployment (this is the reason your pipeline was working as the policy failed during deployment & cannot be considered as deployed).",
      "author": {
        "account_id": 3239,
        "name": "Ram Krishna Verma",
        "display_name": null,
        "email": "ramkrishna.verma@gmail.com",
        "username": "ramverma"
      },
      "updated": "2022-01-31 16:46:25.000000000",
      "in_reply_to": "592a5e7a_50ce93ef",
      "unresolved": true
    },
