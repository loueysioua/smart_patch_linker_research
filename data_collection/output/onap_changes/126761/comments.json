      "file_path": "main/src/main/java/org/onap/policy/pdpx/main/XacmlState.java",
      "patchset_number": 10,
      "line": 120,
      "message": "this would be a count of deploy-success + deploy-failure, need to trace the code for the PDP_UPDATE message and see how those are counted, so this is not totally accurate.",
