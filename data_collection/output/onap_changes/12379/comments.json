    {
      "id": "9a437d4f_179b5868",
      "file_path": "controlloop/templates/archetype-cl-amsterdam/src/main/resources/archetype-resources/src/main/config/__artifactId__-controller.properties",
      "patchset_number": 1,
      "line": 35,
      "message": "This needs to be the LCMResponseWrapper. The actually LCMResponse is contained inside a dmaap wrapper from APPC, which is why we need to use the wrapper.",
      "author": {
        "account_id": 1677,
        "name": "Daniel Cruz",
        "display_name": null,
        "email": "dc443y@att.com",
        "username": "dc443y"
      },
      "updated": "2017-09-14 13:43:18.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "9a437d4f_d7a4b0a7",
      "file_path": "controlloop/templates/archetype-cl-amsterdam/src/main/resources/archetype-resources/src/main/config/__artifactId__-controller.properties",
      "patchset_number": 1,
      "line": 36,
      "message": "The response wrapper needs to be used and it does not contain a common-header or status, has a body object which contains these fields.",
      "author": {
        "account_id": 1677,
        "name": "Daniel Cruz",
        "display_name": null,
        "email": "dc443y@att.com",
        "username": "dc443y"
      },
      "updated": "2017-09-14 13:43:18.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "9a437d4f_378d3c32",
      "file_path": "controlloop/templates/archetype-cl-amsterdam/src/main/resources/archetype-resources/src/main/config/__artifactId__-controller.properties",
      "patchset_number": 1,
      "line": 37,
      "message": "This needs to use the gson object of the appclcm serialization class, not gson pretty. This is because of the need to add extra wrappers in the json around the body of the request, I had to use two different gson objects to get it working properly, the external one to use for the controller (gson) and the internal one used for the inside of the request to change the timestamp.",
      "author": {
        "account_id": 1677,
        "name": "Daniel Cruz",
        "display_name": null,
        "email": "dc443y@att.com",
        "username": "dc443y"
      },
      "updated": "2017-09-14 13:43:18.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "9a437d4f_77a9847a",
      "file_path": "controlloop/templates/archetype-cl-amsterdam/src/main/resources/archetype-resources/src/main/config/__artifactId__-controller.rest.json",
      "patchset_number": 1,
      "line": 12,
      "message": "Should be LCMResponseWrapper",
      "author": {
        "account_id": 1677,
        "name": "Daniel Cruz",
        "display_name": null,
        "email": "dc443y@att.com",
        "username": "dc443y"
      },
      "updated": "2017-09-14 13:43:18.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "9a437d4f_17b238e6",
      "file_path": "controlloop/templates/archetype-cl-amsterdam/src/main/resources/archetype-resources/src/main/config/__artifactId__-controller.rest.json",
      "patchset_number": 1,
      "line": 13,
      "message": "Use LCMResponseWrapper, it has a body object that contains the true response with a common-header and status. Also it is important to not that the request/responses of the LCM API contain hyphens and not upper camel case syntax (ex. \"CommonHeader\" is actually going to be \"common-header\" when sent back from APPC).",
      "author": {
        "account_id": 1677,
        "name": "Daniel Cruz",
        "display_name": null,
        "email": "dc443y@att.com",
        "username": "dc443y"
      },
      "updated": "2017-09-14 13:43:18.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "9a437d4f_57b8c0c7",
      "file_path": "controlloop/templates/archetype-cl-amsterdam/src/main/resources/archetype-resources/src/main/config/__artifactId__-controller.rest.json",
      "patchset_number": 1,
      "line": 14,
      "message": "Use gson, not gsonPretty",
      "author": {
        "account_id": 1677,
