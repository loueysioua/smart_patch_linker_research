      },
      {
        "id": "f7a016a64cba1062537e9d553ab4ece284554d9d",
        "author": {
          "account_id": 1579,
          "name": "Steven Wright",
          "display_name": null,
          "email": "sw3588@att.com",
          "username": "wombat123"
        },
        "author_role": "REVIEWER",
        "timestamp": "2017-11-14 14:12:55.000000000",
        "message": "Patch Set 1: Code-Review-1\n\nThis is a good topic to discuss, but the week of the project sign-off is not a good time to be changing the top level document structure. \nlet us revisit this in the context of Beijing. We need a good description of onboarding from the perspective of the VNF Provider. VNFRQTS project has repo to handle use cases  descriptions like this and could be a good place to maintain this content going forward. Suggest we create JIRA ticket to include this in VNFRQTS Beijing project Plan.",
        "patchset_number": 1
      },
