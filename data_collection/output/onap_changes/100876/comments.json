    {
      "id": "1ddee481_32acb43e",
      "file_path": "docs/Chapter8/VES_Registraion_3_2.rst",
      "patchset_number": 3,
      "line": 192,
      "message": "This is not really correct.\nYAML documents shall be delimited with \"---\" only, according to this: https://yaml.org/spec/1.2/spec.html \n\nWe actually don`t need \"...\" here, as the <dots> are used close the communications message, when YAML is sent over the wire.\n\nSo this shall be:\n<start>\nYAML document 1\n---\nYAML document 2\n---\nYAML document 3\n<EOF>",
      "author": {
        "account_id": 5597,
        "name": "Damian Nowak",
        "display_name": "Damian Nowak",
        "email": "damian.nowak@nokia.com",
        "username": "deen1985"
      },
      "updated": "2020-02-19 14:09:41.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
