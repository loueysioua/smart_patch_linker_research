    {
      "id": "1812840c_efecfa15",
      "file_path": "docs/Chapter8/VES_Registraion_3_2.rst",
      "patchset_number": 4,
      "line": 2846,
      "message": "What about flipping the direction of this table?\nI mean, start with newest updates...?",
      "author": {
        "account_id": 5597,
        "name": "Damian Nowak",
        "display_name": "Damian Nowak",
        "email": "damian.nowak@nokia.com",
        "username": "deen1985"
      },
