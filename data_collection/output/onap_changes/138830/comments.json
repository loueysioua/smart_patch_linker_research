    {
      "id": "e74ba7a8_e73cfeaa",
      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/api/inventory/NetworkCmProxyInventoryFacade.java",
      "patchset_number": 1,
      "line": 210,
      "message": "Good question, yes it was a bug. Since cm handle and dmi plugin relating to each other was considered in the epic in a way that either one was down, should make effective (resulting) trust level of cm handle 'NONE (untrusted)'\n\nPreviously when doing get cm handle or query cm hanlde was returning only cm hanlde trust level without considering the latest health of dmi plugin.",
      "author": {
        "account_id": 8063,
        "name": "Halil Cakal",
        "display_name": null,
        "email": "halil.cakal@est.tech",
        "username": "halil.cakal"
      },
      "updated": "2024-08-23 08:07:36.000000000",
      "in_reply_to": "bf059692_6ace61ba",
      "unresolved": true
    },
