    {
      "id": "3fd842b5_3740aea1",
      "file_path": "kubernetes/aaf/charts/aaf-sms/resources/config/has.json",
      "patchset_number": 28,
      "line": 9,
      "message": "Sorry for asking so dummy question but I'm trying to find some logic in this solution but I can't.\nLet's try to list the facts just to make sure that we are on the same page.\n1) OOF uses aaf-sms to store all passwords\n2) This file is a part of aaf-sms \"bootstrap data\"\n3) aaf sms is a classic secret store with vault as a backend\n4) OOF retrieves all those passwords at pod startup\n5) All those passwords are encrypted with the appKey that is stored in oof and the oof decrypts them\n\nIs my understanding correct?",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2020-04-06 21:47:58.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "e46bfbb8_97ea0322",
      "file_path": "kubernetes/oof/charts/oof-has/values.yaml",
      "patchset_number": 28,
      "line": 81,
      "message": "it's more readable if you use yaml hooks for this:\n\n  - uid: oof-has-app-key\n    name: &appKeySecretName '{{ include \"common.release\" . }}-oof-has-app-key'\n    type: password\n    password: '{{ .Values.config.appKey }}'\n\n\t\n oof-has-api:\n   config:\t\n    oofHasAppKeyExternalSecret: *appKeySecretName\n\n...",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2020-04-06 21:47:58.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
