    {
      "id": "79711fee_8719849f",
      "file_path": "kubernetes/oof/charts/oof-has/resources/config/conductor.conf",
      "patchset_number": 9,
      "line": 150,
      "message": "We added this appKey to encrypt the passwords.  What is the recomendation?",
      "author": {
        "account_id": 2923,
        "name": "Vikas Varma",
        "display_name": null,
        "email": "vikas.varma@att.com",
        "username": "vrvarma"
      },
      "updated": "2020-04-01 22:33:53.000000000",
