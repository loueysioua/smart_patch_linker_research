    },
    {
      "id": "e08a7323_a4e2e490",
      "file_path": "kubernetes/oof/charts/oof-has/resources/config/conductor.conf",
      "patchset_number": 9,
      "line": 150,
      "message": "Don't encrypt passwords but put them into secrets.\nSee https://gerrit.onap.org/r/c/oom/+/104820 for a \"simple\" example.\n\nhttps://gerrit.onap.org/r/c/oom/+/102171 is one where password values are \"envsubst\" before start.",
      "author": {
        "account_id": 2319,
        "name": "Sylvain Desbureaux",
        "display_name": null,
        "email": "sylvain.desbureaux@orange.com",
        "username": "sdesbure"
      },
      "updated": "2020-04-02 07:15:39.000000000",
      "in_reply_to": "79711fee_8719849f",
      "unresolved": true
    },
    {
      "id": "8d6dd64a_a0ea30d6",
      "file_path": "kubernetes/oof/charts/oof-has/resources/config/conductor.conf",
      "patchset_number": 9,
      "line": 150,
      "message": "Using secrets & environment substitution will require a code change. Is this a gating requirement?",
      "author": {
        "account_id": 2923,
        "name": "Vikas Varma",
        "display_name": null,
        "email": "vikas.varma@att.com",
        "username": "vrvarma"
      },
      "updated": "2020-04-03 23:26:26.000000000",
