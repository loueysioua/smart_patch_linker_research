    {
      "id": "8e17c5f7_ecc99cec",
      "file_path": "certServiceK8sExternalProvider/deploy/configuration.yaml",
      "patchset_number": 2,
      "line": 31,
      "message": "This is an exemplary configuration, however should be close to the final version used in LAB/PROD. I think we should extend the README with the information, that's this is (just) an example and the values like URL and secret names could/should be adjusted while installation.\n\nSo we should provide a guide for someone who would like to install this software locally or on lab.\n\nI would leave it where it is now. Maybe we could rename this directory it a better name could be found.",
      "author": {
        "account_id": 6714,
        "name": "Jan Malkiewicz",
        "display_name": null,
        "email": "jan.malkiewicz@nokia.com",
        "username": "jmalkiewicz"
      },
