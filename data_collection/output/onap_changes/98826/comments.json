      "file_path": "onap-dcae-dcaepolicy-lib/tests/test_dcae_policy.py",
      "patchset_number": 4,
      "line": 22,
      "message": "Same python3 code works in python2.7 (and very likely before).",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
