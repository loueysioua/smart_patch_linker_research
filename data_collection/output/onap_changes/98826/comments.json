  "inline_comments": [
    {
      "id": "1e1122bf_ffcf8502",
      "file_path": "onap-dcae-dcaepolicy-lib/onap_dcae_dcaepolicy_lib/dcae_policy.py",
      "patchset_number": 4,
      "line": 23,
      "message": "There need to be any differences between python versions in this code.",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
        "username": "mirlos"
      },
      "updated": "2019-11-26 12:46:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "c541db9c_41cc3b89",
      "file_path": "onap-dcae-dcaepolicy-lib/onap_dcae_dcaepolicy_lib/dcae_policy.py",
      "patchset_number": 4,
      "line": 137,
      "message": "You do not need to create separate code for 2 and 3 - the overhead of using items() in python2 to create a list is small, especially since this code creates 2 intermediate dicts, before finally creating a third one with deepcopy. Just use the python3 version.",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
        "username": "mirlos"
      },
      "updated": "2019-11-26 12:46:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "5a40aaba_53d509bb",
      "file_path": "onap-dcae-dcaepolicy-lib/onap_dcae_dcaepolicy_lib/dcae_policy.py",
      "patchset_number": 4,
      "line": 155,
      "message": "Python3 version works fine in python2 as well.",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
        "username": "mirlos"
      },
      "updated": "2019-11-26 12:46:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "4caee855_611e6137",
      "file_path": "onap-dcae-dcaepolicy-lib/onap_dcae_dcaepolicy_lib/dcae_policy.py",
      "patchset_number": 4,
      "line": 171,
      "message": "Dict comprehension works well in python2 and 3, and is clearer.\n\nreturn {policy_id: policy.get(POLICY_BODY) for policy_id, policy in policies.items() if policy.get(POLICY_BODY)}",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
        "username": "mirlos"
      },
      "updated": "2019-11-26 12:46:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "98544587_d3237c42",
      "file_path": "onap-dcae-dcaepolicy-lib/onap_dcae_dcaepolicy_lib/dcae_policy.py",
      "patchset_number": 4,
      "line": 264,
      "message": "Python3 version works fine in python2.",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
        "username": "mirlos"
      },
      "updated": "2019-11-26 12:46:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "0ecab23a_59a0dd0f",
      "file_path": "onap-dcae-dcaepolicy-lib/onap_dcae_dcaepolicy_lib/dcae_policy.py",
      "patchset_number": 4,
      "line": 277,
      "message": "Python3 version works fine in python2.\nAlso, instead of items, one could just iterate policy_id over the dict, and then retrieve the item in the loop. It is usually faster than creating the items.",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
        "username": "mirlos"
      },
      "updated": "2019-11-26 12:46:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "9bd4e8f5_1ed9d60c",
      "file_path": "onap-dcae-dcaepolicy-lib/onap_dcae_dcaepolicy_lib/dcae_policy.py",
      "patchset_number": 4,
      "line": 402,
      "message": "No need to create the list if it's just being iterated. The original python2 code should've used itervalues anyway. The python2 version is the better option here.",
      "author": {
        "account_id": 6172,
        "name": "Miroslav Los",
        "display_name": null,
        "email": "miroslav.los@pantheon.tech",
        "username": "mirlos"
      },
      "updated": "2019-11-26 12:46:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
