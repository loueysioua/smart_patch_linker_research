        "message": "Patch Set 2:\n\n#Sample code that was used for integration testing\n\npackage main\n\nimport (\n\t\"k8splugin/krd\"\n\t\"log\"\n)\n\nfunc main() {\n\tdata, err := krd.NewHelmTemplateClient(\"1.12.3\", \"testnamespace\", \"myrelease\").GenerateKubernetesArtifacts(\n\t\t\"/tmp/helm-test/aaf-sms\",\n\t\t[]string{\"/tmp/helm-test/values.yaml\"},\n\t\t[]string{\"global.nodePortPrefix=920\"},\n\t)\n\tif err != nil {\n\t\tlog.Fatalln(err)\n\t}\n\tfor k, v := range data {\n\t\tlog.Printf(\"%s: %s\", k, v)\n\t}\n}",
        "patchset_number": 2
      },
