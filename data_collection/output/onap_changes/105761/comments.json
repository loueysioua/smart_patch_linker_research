    {
      "id": "f3a59450_4b103a62",
      "file_path": "kubernetes/clamp/charts/mariadb/values.yaml",
      "patchset_number": 10,
      "line": 32,
      "message": "nope. Don't use global for this. The design pattern is to try to not propagate credentials but a reference to secret (aka external secret)\n\nSee for example policy how we are propagating this",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2020-04-29 17:00:29.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "ebb903cf_c7e8de4d",
      "file_path": "kubernetes/clamp/values.yaml",
      "patchset_number": 10,
      "line": 28,
      "message": "Now you see the reason why not to use global variable. If you use local once and the design pattern that we used in all other components you don't need to specify this password at all and common secret template will generate it for you using master password",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2020-04-29 17:00:29.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "75c264fa_89cdae0e",
      "file_path": "kubernetes/clamp/values.yaml",
      "patchset_number": 11,
      "line": 32,
      "message": "nope.\n\nYou should use a common secret template in this file and then pass the secret name to subcharts not the actual credentials",
