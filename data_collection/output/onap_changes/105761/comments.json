    {
      "id": "7486504a_53a6c975",
      "file_path": "kubernetes/clamp/charts/mariadb/resources/config/mariadb/docker-entrypoint-initdb.d/bulkload/create-db.sql",
      "patchset_number": 10,
      "line": 1,
      "message": "just because of my curiosity, what happen with those scripts? Why we are removing them?",
