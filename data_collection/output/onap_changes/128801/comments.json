    {
      "id": "3a1acf3e_40edda17",
      "file_path": "cps-service/src/main/resources/logback-spring.xml",
      "patchset_number": 2,
      "line": 105,
      "message": "Traceid = each request and response traceid is same when calling same service or one service to another service.\n\nSpanid = In general Span Id is printed along with Trace Id. Span Id is different every request and response calling one service to another service.\n\nhttps://refactorfirst.com/distributed-tracing-with-spring-cloud-sleuth.html",
      "author": {
