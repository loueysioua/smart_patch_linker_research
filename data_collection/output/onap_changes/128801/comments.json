      "id": "46368311_31f8642c",
      "file_path": "cps-service/src/main/resources/logback-spring.xml",
      "patchset_number": 2,
      "line": 105,
      "message": "We should include these additional field so that make investigation more efficiently.\n\nEx : \n{\"@timestamp\":\"2022-04-28T22:41:19.695Z\",\n\"logTypeName\":\"\",\n\"logLevel\":\"ERROR\",\n\"traceId\":\"fd5b7633322818de\",\n\"statusCode\":\"\",\n\"principalId\":\"cpsuser\",\n\"serviceName\":\"cps-application\",\n\"message\":\"Exception occurred\",\n\"spanId\":\"fd5b7633322818de\",\n\"processId\":\"26508\",\n\"threadId\":\"qtp998574047-28\",\n\"class\":\"o.o.c.n.r.e.NetworkCmProxyRestExceptionHandler\"}",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
