    {
      "id": "077ce2cc_31896ec1",
      "file_path": "catalog-fe/src/main/java/org/openecomp/sdc/fe/servlets/SSLProxyServlet.java",
      "patchset_number": 8,
      "line": 54,
      "message": "after looking into this a bit I believe connectTimeout and StopTimeout are un-related. The stopTimeout would force a timeout during an attempt to stop the client whereas connectTimeout relates to an attempt to make a connection to a destination. \nstopTimeout was removed for this issue https://github.com/eclipse/jetty.project/issues/4321 and is not replaced.\n\nWe therefore have no reason to add a connectTimeout as a result of stopTimeout being removed",
      "author": {
        "account_id": 5269,
        "name": "Michael Morris",
        "display_name": null,
        "email": "michael.morris@est.tech",
        "username": "MichaelMorris"
      },
      "updated": "2023-05-08 12:22:31.000000000",
      "in_reply_to": "7f0bbaca_176effe8",
      "unresolved": false
    },
