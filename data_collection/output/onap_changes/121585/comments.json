    {
      "id": "711c09d7_2eb354b8",
      "file_path": "services/services-onappf/src/main/java/org/onap/policy/apex/services/onappf/handler/PdpUpdateMessageHandler.java",
      "patchset_number": 2,
      "line": 102,
      "message": "line 104 (i.e., removeAll) wouldn't have to change as it takes an arbitrary Collection.  OTOH, you are correct that line 105 would require copying to a new List, but one conversion to a new list, O(N), is still better than the O(N^2) behavior of removeAll when the left side is a List.  Ordinarily, it won't matter as one side or the other will be empty or very short, though I can imagine a few cases where both lists could be long.",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2021-05-28 18:09:28.000000000",
      "in_reply_to": "90bbb856_5359628c",
      "unresolved": true
    },
