    {
      "id": "a2bfdd58_ad044a6a",
      "file_path": "cps-rest/src/main/java/org/onap/cps/rest/controller/AdminRestController.java",
      "patchset_number": 3,
      "line": 41,
      "message": "> why is this required here when the Interface contains the RequestMapping?\n\ninterface contains mapping on per method basis only, not the class level one (to be used as URI prefix). \nfor this purpose there was special property basePath in OpenAPI v2, which was replaced with server.url\nin OpenAPI.v3, the swagger-codegen-maven-plugin does not use this property same way as baseBath.\nso current approach is a workaround. cheapest version.",
      "author": {
        "account_id": 7362,
        "name": "Ruslan Kashapov",
        "display_name": null,
        "email": "ruslan.kashapov@pantheon.tech",
        "username": "rkashapov"
      },
      "updated": "2021-01-21 12:07:16.000000000",
      "in_reply_to": "4b046a39_94e8061b",
      "unresolved": true
    },
