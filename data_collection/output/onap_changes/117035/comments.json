    {
      "id": "8f41dc87_47feeb74",
      "file_path": "cps-rest/src/main/resources/application.yml",
      "patchset_number": 6,
      "line": 6,
      "message": "no, the version is a part of endpoing url which is not allowed to be changed (configured).\nwhen new version for some method is provided, then /vN/ part will be the only difference \nin endpoint URL which differentiates the behavior/response expected. \nalso different versions of same method can be served by same controller class.",
      "author": {
        "account_id": 7362,
        "name": "Ruslan Kashapov",
        "display_name": null,
        "email": "ruslan.kashapov@pantheon.tech",
        "username": "rkashapov"
