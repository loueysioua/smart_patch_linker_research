    {
      "id": "6ff26fc9_fc51453e",
      "file_path": "kubernetes/dmaap/components/message-router/templates/statefulset.yaml",
      "patchset_number": 1,
      "line": 38,
      "message": "Existing tcpSocket check can't detect the frequent failure condition of message-router returning 503 error when trying to fetch events. I have tried to explain this in the Jira ticket.",
