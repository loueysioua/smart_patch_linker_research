      "id": "8122b04a_4eedc90d",
      "file_path": "docs/release-notes.rst",
      "patchset_number": 1,
      "line": 116,
      "message": "Add the following items:\n\n* Enhanced healthchecks on drools pdp to report on stuck applications.  This together with enhanced liveness probes self-heals the unresponsive pod in such condition by restarting it.\n\n* Drools PDP has been upgraded to the latest available stable version: 7.68.0.Final.\n\n* Extend CDS actor model to decouple VNF handling from the vFirewall use case.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2022-05-10 15:07:42.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
