    {
      "id": "f526c25d_5a6e7129",
      "file_path": "cps-ri/src/main/java/org/onap/cps/spi/repository/ModuleReferenceRepositoryImpl.java",
      "patchset_number": 7,
      "line": 91,
      "message": "Nope Priyank its correct. Its supposed to be child attribute only as the cm handle state is child of module set tag xpath. Mainly it start executing query from bottom to top (child and then parent). Idea is to minimize the number of rows based on cm handle state. \n\nFirst it would find all cm handle that is into ready state (into child attribute) and then filter it based on module set tag that is parent attribute. It will minimize the sub-set of fragment data where as if we search top to bottom approach then the sub-set of module set tag lets say tagA then the volume of data is huge and there is performance hit that decreases significantly approx. 100-150 %",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
      "updated": "2024-08-13 17:08:44.000000000",
      "in_reply_to": "44217b60_09ea7a63",
      "unresolved": true
    },
