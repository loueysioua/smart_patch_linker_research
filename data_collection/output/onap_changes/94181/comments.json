    {
      "id": "efb7abd9_2ee6c1f8",
      "file_path": "UniversalVesAdapter/src/main/java/org/onap/universalvesadapter/service/VESAdapterInitializer.java",
      "patchset_number": 2,
      "line": 177,
      "message": "this will return the LAST line from the output of the destination URL.\n\nNormally you want the entire body.\n\nIf so, then use something like\n\nStringBuilder ret = new StringBuilder();\n. . .\nwhile ((line = rd.readLine()) != null) { \nret.append(line); \nret.append('\\n'); // readLine() trims the trailing NL\n}\n. . .\nreturn ret.toString();\n\n\nIf you truly only want the last line, please change the name to fetchLastLineFromDestination().",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
