      "unresolved": false
    },
    {
      "id": "9a437d4f_3a7aeaf1",
      "file_path": "kubernetes/config/pod-config-init.yaml",
      "patchset_number": 8,
      "line": 13,
      "message": "The reason for the new image (tag 1.1.1) is that Michael in a previous comment stated that it is impossible to test the commit without the docker image. Therefore we provided one.I was thinking on Major/Minor/Patch numbering, since we have 3 digits. Guess we need to discuss this further. Didn't want to step on 1.1.0, since this commit is not yet submitted. We indeed tested this locally with another tag. If you prefer, I will push an image with 1.1.0 with these changes as well.",
      "author": {
        "account_id": 497,
        "name": "Borislav Glozman",
        "display_name": null,
        "email": "borislav.glozman@amdocs.com",
        "username": "BorislavG"
      },
      "updated": "2017-09-06 06:39:35.000000000",
