      "id": "e70b4fd1_56988763",
      "file_path": "cps-application/pom.xml",
      "patchset_number": 1,
      "line": 129,
      "message": "This is not needed. The image tag with the timestamp on line 131 below is what is standard and we should only create that, this will create extra tag which can be avoided. Also, it will create this image tag on nexus too.",
      "author": {
        "account_id": 6862,
        "name": "Rishi Chail",
        "display_name": null,
        "email": "rishi.chail7@gmail.com",
        "username": "Rishi.Chail"
