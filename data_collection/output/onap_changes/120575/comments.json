    },
    {
      "id": "e0c80ab2_003ae7f0",
      "file_path": "cps-application/pom.xml",
      "patchset_number": 1,
      "line": 129,
      "message": "All the images need this tag.\nPlease have a look in OOM helm repository.\nThe images should only have version number in helm charts and not the timestamp with it.\nTimestamps create specific images and it will change with every build, but having only the version is important in helm charts to avoid renaming version names in values.yaml file with specific timestamps every time you have to create rolling update in helm.",
      "author": {
        "account_id": 5786,
        "name": "Hanif Kukkalli",
        "display_name": "Hanif Kukkalli",
        "email": "lte-ng@outlook.com",
        "username": "mohak"
      },
      "updated": "2021-04-16 09:15:54.000000000",
      "in_reply_to": "e70b4fd1_56988763",
      "unresolved": false
    },
    {
      "id": "86ff081a_6da44099",
      "file_path": "cps-application/pom.xml",
      "patchset_number": 1,
      "line": 129,
      "message": "If i am not mistaken, there is a separate release process that would retag this image( with the timestamp) during the release process to a tag without the timestamp. For more info on why this was done check out the original JIRA.",
      "author": {
        "account_id": 6862,
