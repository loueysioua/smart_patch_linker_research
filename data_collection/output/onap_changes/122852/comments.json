    {
      "id": "c8b763e9_e5a93269",
      "file_path": "runtime-controlloop/src/main/java/org/onap/policy/clamp/controlloop/runtime/commissioning/CommissioningProvider.java",
      "patchset_number": 5,
      "line": 257,
      "message": "what I was thinking was more like:\n\n  from = getDerivedFrom()\n  while (from != null) {    // or from != \"Root type\"\n    process \"from\" node type\n    from = from.getDerivedFrom()\n  }",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
