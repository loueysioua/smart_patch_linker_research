    {
      "id": "50fae0be_555c2837",
      "file_path": "kubernetes/dcaegen2-services/components/dcae-datafile-collector/values.yaml",
      "patchset_number": 3,
      "line": 155,
      "message": "If I'm reading the templates correctly, this name/path information is used to set up configMaps that are mounted on the dmaap init container but not on the microservice's container.  The paths listed here are the paths expected by the init container.  We should not expect the developer of a microservice to know what to put here.  These should be embedded in the template.",
      "author": {
        "account_id": 511,
        "name": "Jack Lucas",
        "display_name": null,
        "email": "jflos@sonoris.net",
        "username": "jackl"
      },
      "updated": "2021-06-17 15:29:56.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "85688179_6d8991d8",
      "file_path": "kubernetes/common/common/templates/_dmaapProvisioning.tpl",
      "patchset_number": 3,
      "line": 84,
      "message": "PM_MEAS_FILES_LOG_URL_* seems very specific to the DFC use case.  The names should be more generic, since these environment variables will be used in the appplicationConfig for any microservice that used Data Router.  Maybe just DR_LOG_URL_*, DR_FILES_PUBLISHER_URL_*, DR_FILES_PUBLISHER_ID_*.",
      "author": {
        "account_id": 511,
        "name": "Jack Lucas",
        "display_name": null,
        "email": "jflos@sonoris.net",
        "username": "jackl"
      },
      "updated": "2021-06-17 15:52:40.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
