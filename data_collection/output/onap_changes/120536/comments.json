      "patchset_number": 3,
      "line": 195,
      "message": "The condition to check if 'no policiesToBeUndeployed are still running' need to be here to capture any undeployment failures. But this condition doesn't seem right to me. need something like containsAny",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
      },
      "updated": "2021-04-26 14:25:37.000000000",
      "in_reply_to": "a75725c8_601367ad",
      "unresolved": true
    },
