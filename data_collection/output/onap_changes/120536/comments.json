      "file_path": "services/services-onappf/src/main/java/org/onap/policy/apex/services/onappf/handler/PdpUpdateMessageHandler.java",
      "patchset_number": 3,
      "line": 97,
      "message": "As I mentioned earlier, this cannot be simply updated with the new list to be deployed. Already deployed ones also should be there. Otherwise heartbeats will not have the right information with all the policies running in the engine..",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
