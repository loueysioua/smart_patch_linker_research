    {
      "id": "fddc4dc2_8cb92721",
      "file_path": "models-examples/src/main/resources/policy_type_impl/samplePolicyTypeImpl.yaml",
      "patchset_number": 9,
      "line": null,
      "message": "I think this makes things clearer.\n\nWhat we are doing is taking the fields in the \"metadata\" section and adding them to the \"metadata\" of a policy that quotes this policy_type_impl.\n\nSo in the case of a policy type called \"onap.policies.controlloop.operational.common.drools.Power:1.0.0\" that runs on drools-pdp, all policies that quote the \"droolsPolicyTypeImpl_PowerRules:0.0.1\" policyTypeImpl will have \"metadata_field_1\" to \"metadata_field_4\" added to its metadata by PAP.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2022-01-19 16:04:05.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
