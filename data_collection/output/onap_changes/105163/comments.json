        "name": "Francis Toth",
        "display_name": null,
        "email": "francis.toth@yoppworks.com",
        "username": "francistoth"
      },
      "updated": "2020-04-21 03:10:10.000000000",
      "in_reply_to": "ec0f41fe_43532b37",
      "unresolved": true
    },
