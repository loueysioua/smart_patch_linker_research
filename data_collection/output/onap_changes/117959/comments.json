      "file_path": "tosca-controlloop/runtime/src/main/java/org/onap/policy/clamp/controlloop/runtime/main/startstop/Main.java",
      "patchset_number": 6,
      "line": 116,
      "message": "This is Policy Framework template code. See also for example:\nhttps://github.com/onap/policy-pap/blob/master/main/src/main/java/org/onap/policy/pap/main/startstop/Main.java\n\nIt works as follows:\n\nThe shutDown() method works as a way of shutting down execution explicitly in test cases. We run an instance of the system by calling the Main method from test cases. The activator is checked for null here because this method can be explicitly invoked more than once during testing.\n\nThe shutdown hook is the regular way to shut down the server, so activator should never be null in this scenario, and if it is we want an exception to be thrown.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
