      "file_path": "bpmn/so-bpmn-tasks/src/main/java/org/onap/so/bpmn/infrastructure/service/composition/DeleteChildServiceBB.java",
      "patchset_number": 10,
      "line": 63,
      "message": "orElse(null) - this will cause NullPointerException in serviceInstanceToServiceBeanMapper.\n \nIf the AAI call fails, we should call exceptionBuilder.buildAndThrowWorkflowException to trigger error handling, otherwise the process will just get stuck at this point.",
      "author": {
        "account_id": 6218,
        "name": "Jozsef Csongvai",
        "display_name": null,
        "email": "jozsef.csongvai@bell.ca",
