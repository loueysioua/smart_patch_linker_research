    },
    {
      "id": "e42030f5_198400c9",
      "file_path": "bpmn/so-bpmn-tasks/src/main/java/org/onap/so/bpmn/infrastructure/workflow/tasks/ebb/loader/ServiceEBBLoader.java",
      "patchset_number": 11,
      "line": 291,
      "message": "This should be filtered to only apply for composed resources that have relationships. \n\nIf you delete the child service manually, and then try to delete the parent service this will fail a few lines below \n\njava.lang.NullPointerException: null\n\tat org.onap.so.bpmn.infrastructure.workflow.tasks.ebb.loader.ServiceEBBLoader.lambda$traverseServiceInstanceChildService$5(ServiceEBBLoader.java:295)\n\nThis happens because the parent still has a composed resource, but the child service is gone and also its relationship to the composed resource. In other words, the presence of a composed resource does not guarantee the presence of a child service",
      "author": {
        "account_id": 6218,
        "name": "Jozsef Csongvai",
        "display_name": null,
        "email": "jozsef.csongvai@bell.ca",
        "username": "jozsef"
      },
      "updated": "2022-04-22 22:38:01.000000000",
      "in_reply_to": null,
      "unresolved": true
