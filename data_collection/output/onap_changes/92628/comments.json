    {
      "id": "bdde9340_ad445cb0",
      "file_path": "src/monitor/pkg/controller/resourcebundlestate/pod_controller.go",
      "patchset_number": 5,
      "line": 106,
      "message": "Adding finalizer to the resource (during create or update) ensures that it wont get deleted until the finalizer is removed. At the same time the deletion timestamp will be non-null value for deletion. Once the necessary actions and additional clean up is done then the finalizer can be removed. At that time it will trigger reconcile one more time and if the object does not exist then we discard as we know for sure there is no finalizer. https://kubernetes.io/docs/tasks/access-kubernetes-api/custom-resources/custom-resource-definitions/#finalizers",
      "author": {
        "account_id": 1361,
        "name": "Dileep Ranganathan",
        "display_name": null,
        "email": "dileep.ranganathan@intel.com",
        "username": "dileep.ranganathan"
      },
      "updated": "2019-08-26 20:32:56.000000000",
      "in_reply_to": "5502d537_e168477d",
      "unresolved": false
    },
