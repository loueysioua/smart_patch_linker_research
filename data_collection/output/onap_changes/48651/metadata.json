          "username": "os0695"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-06-20 14:34:43.000000000",
        "message": "Patch Set 5:\n\n(9 comments)\n\nLet me know what you think - Thanks guys",
        "patchset_number": 5
      },
