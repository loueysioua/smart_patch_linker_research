        "message": "Patch Set 2:\n\nResult now looks good\n\nadetalhouet at bell in ~/tmp/oom copy/kubernetes/config/docker/init git amsterdam [?]\n$ echo $UEB_ADDR_IP\n10.195.194.11 10.195.194.12 10.195.194.19\n\nadetalhouet at bell in ~/tmp/oom copy/kubernetes/config/docker/init git amsterdam [?]\n$ if [ `echo $UEB_ADDR_IP | wc -w` -gt \"1\" ]; then     UEB_ADDR_IP_COMMA_AND_QUOTE_SEPERATED=`echo $UEB_ADDR_IP | gsed 's/ /\",\"/g'`;     UEB_ADDR_IP_COMMA_SEPERATED=`echo $UEB_ADDR_IP | gsed 's/ /,/g'`; else     UEB_ADDR_IP_COMMA_AND_QUOTE_SEPERATED=\"$UEB_ADDR_IP\\\",\\\"$UEB_ADDR_IP\";     UEB_ADDR_IP_COMMA_SEPERATED=\"$UEB_ADDR_IP,$UEB_ADDR_IP\"; fi\n\nadetalhouet at bell in ~/tmp/oom copy/kubernetes/config/docker/init git amsterdam [?]\n$ echo $UEB_ADDR_IP_COMMA_AND_QUOTE_SEPERATED\n10.195.194.11\",\"10.195.194.12\",\"10.195.194.19",
