    {
      "id": "1a76adc5_67b37fe9",
      "file_path": "TPM2-Plugin/lib/tpm2_plugin_api.c",
      "patchset_number": 3,
      "line": 430,
      "message": "Why not check for extensions of the file rather than this method?",
