    {
      "id": "1a76adc5_27f7c78c",
      "file_path": "TPM2-Plugin/lib/tpm2_plugin_api.c",
      "patchset_number": 3,
      "line": 430,
      "message": "The file loading logic is generic and is driven from the get_all_file_contents function in Softhsm. That is used to load various other data files under the key01 hierarchy structure such as activate. We would need to revamp all that code for it to work based on extensions.\nEven if we made the code aware of file extensions and loaded it as such, we will still need these checks anyway to prevent any assumption that a particular buffer index is public or private.",
      "author": {
        "account_id": 301,
        "name": "Kiran Kamineni",
        "display_name": null,
        "email": "kiran.k.kamineni@intel.com",
        "username": "kirankamineni"
      },
      "updated": "2018-09-11 19:02:58.000000000",
      "in_reply_to": "1a76adc5_67b37fe9",
      "unresolved": false
    },
