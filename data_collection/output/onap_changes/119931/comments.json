    {
      "id": "112b429c_a1baee51",
      "file_path": "kubernetes/aai/components/aai-traversal/values.yaml",
      "patchset_number": 1,
      "line": 44,
      "message": "Ok. Thank you for the clarification. Maybe to be super clear it would be better to replace this localhost with sth like: keycloak.your.doman?\n\nAdditionally what are the expectations to that link? Should it be just host or it should point to a particular realm? How you provide credentials to this keycloak instance and what are your expectations to it? Do you expect it to be configured in a certain way?",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
