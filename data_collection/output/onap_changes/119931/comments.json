    {
      "id": "73cc8998_11306e2c",
      "file_path": "kubernetes/aai/components/aai-traversal/resources/config/application-keycloak.properties",
      "patchset_number": 2,
      "line": 5,
      "message": "Hi Team, Pushed a new patchset, please take a look. \nJust for clarification, In order to integrate keycloak, 'keycloak' needs to be added to 'profiles.active' in https://gerrit.onap.org/r/c/oom/+/119931/5/kubernetes/aai/components/aai-traversal/values.yaml#62. When added, keycloak's properties file will be loaded and will be used to support multiTenancy. The properties file contains all keycloak configurations, plus, 'multi.tenancy.enabled'. \nWhen enabled, an extra criteria will be added into traversal query. So, by default 'multi.tenancy.enabled' needs to be true, if not, why keycloak is added to active profiles?\nBut, there might be some use-cases which needs to run traversal without multiTenancy, while keycloak has been integrated. In that case we should set 'multi.tenancy.enabled' to false.",
      "author": {
        "account_id": 7355,
        "name": "Mohammad Hosnidokht",
        "display_name": null,
        "email": "mohammad.hosnidokht@yoppworks.com",
        "username": "MHosnidokht"
      },
      "updated": "2021-04-13 18:03:12.000000000",
      "in_reply_to": "9a835465_9937b23e",
      "unresolved": true
    },
