      "patchset_number": 6,
      "line": 7,
      "message": "Liam, In other places I have noticed that 20xx-20xx format is being used. So, I did the same. Please correct me, if I am wrong.",
      "author": {
        "account_id": 7889,
        "name": "Suresh Charan",
        "display_name": null,
        "email": "suresh.charan@bell.ca",
