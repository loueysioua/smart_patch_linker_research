    },
    {
      "id": "0d89a128_003d9a1e",
      "file_path": "policy-endpoints/src/main/java/org/onap/policy/common/endpoints/event/comm/bus/internal/BusConsumer.java",
      "patchset_number": 6,
      "line": 7,
      "message": "2020-2023 indicates there were changes in all 4 years. which is not true.\n2020,2023 indicates there were changes in 2020 and 2023. which is true and what should be done here in this case.\nThat's why you see the difference. \nIf next year someone makes a change, then it would be: 2020, 2023-2024\nwhich shows all the years a change was made. Make sense?",
      "author": {
        "account_id": 57,
        "name": "Pamela Dragosh",
        "display_name": null,
        "email": "pd1248@att.com",
        "username": "pdragosh"
      },
      "updated": "2023-02-25 15:35:23.000000000",
      "in_reply_to": "bc6ae3ee_754b7906",
      "unresolved": true
    },
