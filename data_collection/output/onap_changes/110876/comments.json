    {
      "id": "ad08512a_3e68af1b",
      "file_path": "etc/collector.properties",
      "patchset_number": 10,
      "line": 61,
      "message": "These are values of parameters for external-schema-manager. They mean internal JSON location (location in event) of schemaReference and data fields.\n \nThese locations depend on 1st stage schema in VES, where their existence is validated. So when they possibly change in future, the SDK tool doesn't need any change in code.\n \nAlso, we tried to make the tool as generic as possible, so these paths couldn't be hardcoded only for VES, because other components wouldn't be able to re-use it.",
      "author": {
        "account_id": 5234,
        "name": "Micha? Ba?ka",
        "display_name": "Michal Banka",
        "email": "michal.banka@nokia.com",
        "username": "michal.banka"
      },
      "updated": "2020-08-11 08:58:22.000000000",
      "in_reply_to": "84ec8dde_dbbc4922",
      "unresolved": false
    },
