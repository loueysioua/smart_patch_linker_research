          "username": "kopasiak"
        },
        "author_role": "REVIEWER",
        "timestamp": "2020-01-24 11:14:32.000000000",
        "message": "Patch Set 5:\n\nIt's useful in the development phase because you can enable ingress for individual component with just override instead of rebuilding it",
        "patchset_number": 5
      },
