    {
      "id": "9adffdf1_523c6e93",
      "file_path": "appc-config/appc-config-params/provider/src/test/java/org/onap/sdnc/config/params/parser/TestPropertyDefinitionNode.java",
      "patchset_number": 2,
      "line": 153,
      "message": "It was me who added patch set 2 which included the rule code.\n\nThis is a comment on most of the reviews on this package. \n\nWhen you test with 'expected=Exception.class' or even 'expected=SvcLogicException.class' all this does is verify that the start of the try{ block in the code under test is reached. Therefore the tests that do this are not providing useful information as when the expected paths through the code are not followed due to some change or error the test will still pass.\nIf we use code of the type I pushed in PatchSet 2 then we are verifying the code that the test case is intended to test is actually being executed.",
      "author": {
        "account_id": 3979,
        "name": "Joss Armstrong",
        "display_name": null,
        "email": "joss.armstrong@ericsson.com",
        "username": "jarmstrong001"
