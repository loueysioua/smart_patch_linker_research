      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/impl/inventory/sync/lcm/CmHandleStateMonitor.java",
      "patchset_number": 2,
      "line": 41,
      "message": "The dependencies seem backwards. It seems like it should be:\n\n    CmHandleStateMonitor depends on CmHandleStateGaugeConfig depends on AdminCacheConfig",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
