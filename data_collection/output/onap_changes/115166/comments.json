    {
      "id": "6e5834a6_af420685",
      "file_path": "models-tosca/src/main/java/org/onap/policy/models/tosca/authorative/concepts/ToscaCapabilityAssignment.java",
      "patchset_number": 2,
      "line": 43,
      "message": "also need to override hashCode?",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
