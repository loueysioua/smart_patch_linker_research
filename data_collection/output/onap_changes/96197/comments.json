    },
    {
      "id": "91de4b44_a24f8f18",
      "file_path": "policy-core/src/main/java/org/onap/policy/drools/core/lock/PolicyResourceLockManager.java",
      "patchset_number": 16,
      "line": 131,
      "message": "This creates a 'ServiceLoader', which searches through all of the resources, looking for those with the name 'META-INF/services/org.onap.policy.drools.core.lock.PolicyResourceLockFeatureApi', looks up the corresponding class instances, and sorts the resulting list according to sequence number.\n\nNote that this will be happening every time a lock is created -- this should only be done once.",
      "author": {
        "account_id": 743,
        "name": "Ralph Straubs",
        "display_name": null,
        "email": "rs8887@att.com",
        "username": "rs8887"
      },
      "updated": "2019-10-11 13:09:42.000000000",
      "in_reply_to": null,
