      "file_path": "policy-core/src/main/java/org/onap/policy/drools/core/lock/PolicyResourceLockManager.java",
      "patchset_number": 15,
      "line": 134,
      "message": "Shouldn't this have a high sequence number? It should not be chosen if there are other providers.",
      "author": {
        "account_id": 743,
