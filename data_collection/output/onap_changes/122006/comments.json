    {
      "id": "8e103054_1c78c487",
      "file_path": "checkstyle/pom.xml",
      "patchset_number": 8,
      "line": 17,
      "message": "you need this, cps-parent pom inherits from oparent, and oparent from version(parent).\nHere we don't use oparent, because it will bring too much config and dependencies that are not need it,\nkeeping it light weight.\nIf you are trying to reduce duplicate config, then create a new module called cps-parent-lite, containing this common config, and reuse it across all modules that have the same config.\nccsdk has one  odlparent-lite, maybe we could reuse it( I dont recommend to do it,is better to have ours). But we could have the same naming maybe?.\nAlso Aditya mentioned something about DistributionManagement been present under settings.xml(.m2/settings.xml ?), that is a system individual configuration and independent from project. So I hope that is not reason to removing this.\nRegards",
      "author": {
        "account_id": 6679,
        "name": "Claudio David Gasparini",
        "display_name": null,
        "email": "gasparini24@gmail.com",
        "username": "cdgasparini"
      },
      "updated": "2021-06-23 15:20:39.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
