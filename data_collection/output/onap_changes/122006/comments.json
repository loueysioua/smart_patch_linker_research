    {
      "id": "b35b6c62_4ab80147",
      "file_path": "cps-application/pom.xml",
      "patchset_number": 6,
      "line": 130,
      "message": "We need a way to provide the custom docker push registry. So image name should be '${docker.push.registry}/onap/${image.name}:${image.tag}'.\n\nI think you removed it to fix the issue with csit failure. To fix the csit issue, the new parameter 'docker.push.registry' needs to be passed when running the job.\n\nUse https://gerrit.onap.org/r/c/ci-management/+/121383/2/jjb/cps/cps-csit.yaml as reference",
      "author": {
        "account_id": 7680,
        "name": "Renu Kumari",
        "display_name": "Renu Kumari",
        "email": "kashi.renu@gmail.com",
        "username": "renukumari"
      },
      "updated": "2021-06-21 18:01:38.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
