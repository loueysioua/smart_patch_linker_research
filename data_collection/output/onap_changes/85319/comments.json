    {
      "id": "57643ee0_18171ef2",
      "file_path": "src/main/docker/docker-entrypoint.sh",
      "patchset_number": 3,
      "line": 33,
      "message": "The difference is following:\n/opt/app/aai-cacher/logs is a symlink, by default chown doesn't traverse symlinks (man chown) and chown does nothing.\nFor example graphadmin's docker-entrypoint.sh has \nchown -R aaiadmin:aaiadmin /opt/app/aai-graphadmin/logs/gc where /opt/app/aai-graphadmin/logs/gc is a directory and chown traverse up to gc directory and change owner as expected.",
      "author": {
        "account_id": 5040,
        "name": "Dmitrii Puzikov",
        "display_name": null,
        "email": "d.puzikov2@partner.samsung.com",
        "username": "dpuzikov"
      },
      "updated": "2019-05-02 14:36:38.000000000",
      "in_reply_to": "dc71335c_39c6e552",
      "unresolved": false
    },
