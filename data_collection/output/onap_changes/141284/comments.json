    {
      "id": "4d760046_2d8b0804",
      "file_path": "cps-service/src/main/java/org/onap/cps/utils/deltareport/DeltaReportGenerator.java",
      "patchset_number": 5,
      "line": 80,
      "message": "In line #62 we flatten all the parent and child data nodes to a Map of xpath to their respective data node. After doing that the child data nodes still remain as part the data node structure under a parent node. Hence this block clears the child nodes under a parent DataNode after the flattening operation so that the child nodes do not get added to the delta report twice. \nThis was not needed before because earlier the delta report contained information about leaves but now, we are adding the node name and the corresponding JSON structure into the delta report hence this need came into picture.",
      "author": {
        "account_id": 7846,
        "name": "Arpit Singh",
        "display_name": "Arpit",
        "email": "as00745003@techmahindra.com",
        "username": "arpitsingh"
      },
      "updated": "2025-09-01 08:14:31.000000000",
      "in_reply_to": "fae05236_84f7ce19",
      "unresolved": true
    },
    {
