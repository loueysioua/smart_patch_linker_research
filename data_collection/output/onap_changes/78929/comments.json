    {
      "id": "e5162934_a6271546",
      "file_path": "datafile-app-server/src/main/java/org/onap/dcaegen2/collectors/datafile/tasks/DataRouterPublisher.java",
      "patchset_number": 1,
      "line": 82,
      "message": "Yes, to make the code more readable, in our opinion at least, we want to format it so that each method call is on its own row. First we used the \n// @formatter:off\n...\n// @formatter:on\ntags, but it was brought to our attention that this is Eclipse specific. So we found this other way that is IDE agnostic, and decided to use that instead.",
      "author": {
