    {
      "id": "f3cc1c2a_55a4f476",
      "file_path": "datafile-app-server/src/main/java/org/onap/dcaegen2/collectors/datafile/service/PublishedFileCache.java",
      "patchset_number": 8,
      "line": 45,
      "message": "As this put method is used for the same file for every message that the file is included in, the old implementation led to the files not being removed until after twice the time that is intended. This is due to the fact that a new instant is created every time this method is called. So the instant that will be used to purge will be from the last time the file was put in, i.e. after the full retention period, not the first. It will then not be romeved until another further 24 hours.\n\nIt is not a big thing, but in this implementation it does what is intended.",
      "author": {
        "account_id": 3763,
        "name": "Henrik Andersson",
        "display_name": null,
        "email": "henrik.b.andersson@est.tech",
        "username": "elinuxhenrik"
      },
      "updated": "2019-03-15 14:37:59.000000000",
      "in_reply_to": "598a9b6f_c4f5c06b",
      "unresolved": false
    },
