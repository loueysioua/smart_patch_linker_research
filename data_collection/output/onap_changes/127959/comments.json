    {
      "id": "f92d7ffa_e92c3087",
      "file_path": "repos/yaml-verify-schema.py",
      "patchset_number": 3,
      "line": 4,
      "message": "if this code is to be copied here, and then modified, there needs to be an additional copyright line added.\n\nPersonally, I think this program should accept a list of files to be checked against the schema.\n\nIf no mods are being made (and I haven't seen any yet), then no additional copyright lines are needed.\n\nIt's probably worth adding a pointer to the origin of this file, as in adding this line either here or in the README.md file:\n\n# Copied from https://github.com/lfit/releng-global-jjb/blob/master/yaml-verify-schema.py\n\nAlso, the Eclipse license requires that \n\n    b) a copy of this Agreement must be included with each copy of the Program.\n\nThis would go in a LICENSE.txt file.",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2022-03-23 13:58:24.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "c59250cb_b5aaa469",
      "file_path": "repos/yaml-verify-schema.py",
      "patchset_number": 3,
      "line": 32,
      "message": "\"_\" is usually used for a variable whose value will then be ignored, not for a value that then gets used.",
