    {
      "id": "263e1fee_e86e0098",
      "file_path": "heat/vFW_NextGen/templates/vfw.yaml",
      "patchset_number": 3,
      "line": 96,
      "message": "I'm not sure floating is the right term here, unless the guidelines say so. It makes me think of a floating IP attached to a private port, while this is a private IP. Does it make sense to rename it?",
      "author": {
        "account_id": 55,
        "name": "Marco Platania",
        "display_name": null,
        "email": "platania@research.att.com",
        "username": "platania"
