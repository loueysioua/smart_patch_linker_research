        "name": "Miriam Eini",
        "display_name": null,
        "email": "miriam.eini@amdocs.com",
        "username": "miriame"
      },
      "updated": "2020-06-03 10:02:33.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
