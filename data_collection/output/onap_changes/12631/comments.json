    {
      "id": "9a437d4f_04be7665",
      "file_path": "kubernetes/oneclick/setenv.bash",
      "patchset_number": 4,
      "line": 4,
      "message": "MSB itself isn't aware of the ONAP components. It's the kube2msb registrator who gets the service endpoint information from annotation and register these service to MSB.\nSo if the MSB has been restarted, kube2msb need to resync all the service information to MSB. This feature is not ready yet and will be added in the next release.\n\nCurrently what we can do is to manage the dependency between MSB and kube2msb using readiness container.",
      "author": {
        "account_id": 189,
        "name": "HuabingZhao",
        "display_name": null,
        "email": "huabingzhao@tencent.com",
        "username": "HuabingZhao"
      },
