  "inline_comments": [
    {
      "id": "e52f391e_4ddc5737",
      "file_path": "kubernetes/a1policymanagement/resources/config/application.yaml",
      "patchset_number": 3,
      "line": 95,
      "message": "Please also add a `tracing.enabled` key here:\n\n```yaml\nmanagement:\n  tracing:\n    enabled: {{ .Values.global.tracing.enabled }}\n```\n\nIt is important to make this configurable as jaeger is not part of the default ONAP deployment and that can lead to log noise and even OOM killing of the pod if traces cannot be exported",
      "author": {
        "account_id": 7849,
        "name": "Fiete Ostkamp",
        "display_name": null,
        "email": "fiete.ostkamp@telekom.de",
        "username": "fostkamp"
      },
      "updated": "2025-07-27 16:25:11.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "c1f5a664_061f039a",
      "file_path": "kubernetes/a1policymanagement/resources/config/application.yaml",
      "patchset_number": 3,
      "line": 104,
      "message": "Please use `{{ .Values.global.tracing.collector.baseUrl }}` here to configure the jaeger url.\nIn general, the `.global.tracing.*` keys are used by the whole platform (`AAI`, `SO`, `PORTALNG`) and it would be great if we could use them here too.\nThat has the advantage, that there is only one global place that needs to be adjusted when choosing to use Jaeger.",
      "author": {
        "account_id": 7849,
        "name": "Fiete Ostkamp",
        "display_name": null,
        "email": "fiete.ostkamp@telekom.de",
        "username": "fostkamp"
      },
      "updated": "2025-07-27 16:25:11.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "6cfc537a_d0fc1aaa",
      "file_path": "kubernetes/a1policymanagement/values.yaml",
      "patchset_number": 3,
      "line": 23,
      "message": "You can define the global tracing config here like this:\n\n```yaml\nglobal:\n  tracing:\n    enabled: false\n    collector:\n      baseUrl: http://jaeger-collector.istio-config:9411\n```",
      "author": {
        "account_id": 7849,
        "name": "Fiete Ostkamp",
        "display_name": null,
        "email": "fiete.ostkamp@telekom.de",
        "username": "fostkamp"
      },
      "updated": "2025-07-27 16:25:11.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
