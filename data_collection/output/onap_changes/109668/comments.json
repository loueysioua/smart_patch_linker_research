    {
      "id": "5dd6d1d7_dd28569b",
      "file_path": "rules.pl",
      "patchset_number": 4,
      "line": 52,
      "message": "Each word should be capitalized as that is the standard label style in Gerrit. So this should be: INFO-File-Not-Alone",
      "author": {
        "account_id": 1,
        "name": "Andrew Grimberg",
        "display_name": null,
        "email": "agrimberg@linuxfoundation.org",
        "username": "agrimberg"
      },
      "updated": "2020-07-16 05:05:13.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "6dbbc9b2_01beb0e9",
      "file_path": "rules.pl",
      "patchset_number": 4,
      "line": 63,
      "message": "I'm talking username lookup. It's impossible for them to have the same username as one of our accounts as it's an account which we own ;)\n\nSo lookup the username of all of our various jobbuilder accounts and just add them all in here. That way we can have just a single master rule that we roll out to all the Gerrit systems and if we add another Gerrit system we update the rule everywhere.",
      "author": {
        "account_id": 1,
        "name": "Andrew Grimberg",
        "display_name": null,
        "email": "agrimberg@linuxfoundation.org",
        "username": "agrimberg"
      },
      "updated": "2020-07-16 05:05:13.000000000",
      "in_reply_to": "8fa5c133_0336ade9",
      "unresolved": true
    },
