    {
      "id": "4c9b48ef_8537a90d",
      "file_path": "ansible/test/roles/prepare-docker/tasks/main.yml",
      "patchset_number": 13,
      "line": 15,
      "message": "For me the logic introduced in this prepare role is too complicated, we'll end up with unreliable test results in the end. For me it should not be a generic-docker-preparation-role, just for 'docker' role. If some other role uses docker too it should have it's own prepare-<role> role with simplified logic to make the testing image more reliable.",
      "author": {
        "account_id": 5097,
        "name": "Bartek Grzybowski",
        "display_name": null,
        "email": "b.grzybowski@partner.samsung.com",
