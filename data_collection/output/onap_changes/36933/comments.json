    {
      "id": "5a93c517_a1691a27",
      "file_path": "kubernetes/policy/charts/drools/values.yaml",
      "patchset_number": 3,
      "line": 33,
      "message": "Do you want this to be by default 4?",
      "author": {
        "account_id": 2763,
