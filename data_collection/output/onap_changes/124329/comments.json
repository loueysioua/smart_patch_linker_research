      "id": "28174da1_6dc51652",
      "file_path": "cps-ri/src/main/java/org/onap/cps/spi/repository/YangResourceRepository.java",
      "patchset_number": 1,
      "line": 58,
      "message": "sure, I think we need to make a team decision on this. I will add both examples here\n\nSELECT DISTINCT\nyr.module_Name AS ModuleName,\nyr.revision AS Revision\nFROM\ndataspace d\nJOIN anchor a ON a.dataspace_id = d.id\nJOIN schema_set ss ON ss.id = a.schema_set_id\nJOIN schema_set_yang_resources ssyr ON ssyr.schema_set_id = ss.id\nJOIN yang_resource yr ON yr.id = ssyr.yang_resource_id\nWHERE\nd.name = 'NFP-Operational' AND\na.name ='ran-network-simulation';\n\t\t\nSELECT DISTINCT\nyang_resource.module_Name AS ModuleName,\nyang_resource.revision AS Revision\nFROM\ndataspace dataspace\nJOIN anchor anchor ON anchor.dataspace_id = dataspace.id\nJOIN schema_set schema_set ON schema_set.id = anchor.schema_set_id\nJOIN schema_set_yang_resources schema_set_yang_resources ON schema_set_yang_resources.schema_set_id = schema_set.id\nJOIN yang_resource yang_resource ON yang_resource.id = schema_set_yang_resources.yang_resource_id\nWHERE\ndataspace.name = 'NFP-Operational' AND\nanchor.name ='ran-network-simulation';",
      "author": {
        "account_id": 6841,
        "name": "Niamh Core",
        "display_name": null,
        "email": "niamh.core@est.tech",
        "username": "niamhcore"
      },
