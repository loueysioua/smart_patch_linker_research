    {
      "id": "4065e1bb_16fd1bfc",
      "file_path": "ansible/roles/certificates/tasks/upload_root_ca.yml",
      "patchset_number": 4,
      "line": null,
      "message": "What's the point of checking in the second task if the distro is redhat like if you're not doing it in the first task? If we want to have real interoperability between distros of various kind let's implement it for real straight from the beginning and do not only pretend that we actually do. \n\nThe first task will fail as in Debian like distros the actual dir is \"/etc/ca-certificates\".\n\nI say we either support both Debian/RedHat role wide or we actually do not and not pretend in single tasks that we do.",
      "author": {
        "account_id": 5097,
        "name": "Bartek Grzybowski",
        "display_name": null,
        "email": "b.grzybowski@partner.samsung.com",
        "username": "bgrzybowski"
      },
      "updated": "2019-03-12 07:48:25.000000000",
