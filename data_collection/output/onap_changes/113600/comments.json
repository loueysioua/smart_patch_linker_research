    {
      "id": "e9c9244c_4c5db6e6",
      "file_path": "kubernetes/contrib/external-schema-repo-generator/environment.config",
      "patchset_number": 2,
      "line": 10,
      "message": "I think we already had that conversation on runtime external dependencies?:) If you happen to have missed it please get acquainted with comments in https://gerrit.onap.org/r/c/oom/+/113228\n\nAlso please take a look at architectural concepts of Onap in https://wiki.onap.org/pages/viewpage.action?pageId=84642385 point \"4.4.7 Runtime Independence from Internet\"",
