      "file_path": "controlloop/common/feature-controlloop-utils/src/main/feature/install/enable",
      "patchset_number": 4,
      "line": 43,
      "message": "note: since each file is actor-specific, these patterns can be shorted substantially.  Ex:\n\n  -e \"s/userName.*/userName=policy/\"",
      "author": {
