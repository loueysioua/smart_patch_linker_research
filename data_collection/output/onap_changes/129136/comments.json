    {
      "id": "9dcd811a_bf230e8c",
      "file_path": "csit/tests/cps-model-sync/cps-model-sync.robot",
      "patchset_number": 9,
      "line": 90,
      "message": "Instead of sleep or update the API manually, We could introduce a retry mechanism (simple loop with max number of retry attempts) to check the status of the cm handle periodically and if it is changed to READY then proceed further otherwise let the test case fail.\nWe are trying to write test case to check the system failure and due to some reason if the Watchdog fails to update the cm handle state then it is the intended behaviour and lets not try to fix that here in the CSIT.",
      "author": {
        "account_id": 3813,
        "name": "Lathishbabu Ganesan",
        "display_name": null,
        "email": "lathishbabu.ganesan@est.tech",
        "username": "Lathish"
      },
      "updated": "2022-06-17 12:20:54.000000000",
      "in_reply_to": "83cf3524_5c2280b7",
      "unresolved": true
    },
    {
      "id": "36f307c0_83ab4406",
      "file_path": "csit/tests/cps-model-sync/cps-model-sync.robot",
      "patchset_number": 9,
      "line": 90,
      "message": "Decision - We will keep sleep for now. Retry task can be fund here: https://jira.onap.org/browse/CPS-1093",
