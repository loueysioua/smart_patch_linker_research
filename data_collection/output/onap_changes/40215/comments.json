    {
      "id": "5a93c517_1fb827e4",
      "file_path": "kubernetes/onap/resources/environments/dev.yaml",
      "patchset_number": 4,
      "line": 29,
      "message": "This is true, however, we actually need to move (or mirror) docker hub and other images in nexus 3. I have an outstanding ticket with the LF on providing this for us. I also have an action to move all oomks artifacts into nexus3.\nI will be raising another patch shortly that should provide you with exactly what you are looking for, in the form of a new _repository.tpl in the common chart. This will allow a default repository to be overridden with a global repository value and then, if need be, have the global value overridden on a per chart basis using a repositoryOverride configuration value.",
      "author": {
        "account_id": 127,
        "name": "Mike Elliott",
        "display_name": null,
        "email": "mike.elliott@amdocs.com",
        "username": "melliott"
      },
