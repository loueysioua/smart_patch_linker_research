    {
      "id": "9a6a9dd7_c64a4cac",
      "file_path": "appc-dispatcher/appc-license-manager/appc-license-manager-core/src/main/java/org/onap/appc/licmgr/impl/LicenseManagerImpl.java",
      "patchset_number": 1,
      "line": 69,
      "message": "The intention of isReady() method was to stop xml processing when both fields are set, just for a slight performance improvement. It is checked before every iteration of the processing loop. I think that checking it here wouldn't help much, as it could be false only if the xml wouldn't contain the required fields. In the original implementation it was also possible to create LicenseModel object with empty fields in that case. Or maybe should we handle this situation somehow?",
      "author": {
        "account_id": 3699,
        "name": "Joanna Jeremicz",
        "display_name": null,
        "email": "joanna.jeremicz@nokia.com",
        "username": "joannajeremicz"
      },
      "updated": "2018-07-31 11:08:08.000000000",
      "in_reply_to": "9a6a9dd7_400e2436",
      "unresolved": false
    },
    {
