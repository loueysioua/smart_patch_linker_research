    {
      "id": "3a6ce767_82eac865",
      "file_path": "cps-service/src/main/java/org/onap/cps/api/impl/CpsDataServiceImpl.java",
      "patchset_number": 2,
      "line": 88,
      "message": "Same here, if this is adding a new list element should it not be create?",
      "author": {
        "account_id": 7744,
        "name": "Dylan Byrne",
        "display_name": null,
        "email": "dylan.byrne@est.tech",
