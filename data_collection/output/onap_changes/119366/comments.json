    },
    {
      "id": "23c4fa2b_7fd0d8b9",
      "file_path": "tosca-controlloop/runtime/src/main/java/org/onap/policy/clamp/controlloop/runtime/monitoring/MonitoringProvider.java",
      "patchset_number": 1,
      "line": 61,
      "message": "Yes the provider classes are creating their own db connections. I am not sure, I have any alternative way here to avoid this problem . I will check this.",
      "author": {
        "account_id": 6070,
        "name": "Ramesh Murugan Iyer",
        "display_name": null,
        "email": "ramesh.murugan.iyer@est.tech",
