      "file_path": "components/pm-subscription-handler/pmsh_service/mod/policy_response_handler.py",
      "patchset_number": 3,
      "line": 89,
      "message": "Refactoring would increase the scope of functional stories thereby impacting the delivery. Additionally, we have a story to handle NFR's like refactoring where this change is already mentioned DCAEGEN2-2820.",
