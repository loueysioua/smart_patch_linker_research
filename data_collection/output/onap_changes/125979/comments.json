    {
      "id": "668d0af6_78378e93",
      "file_path": "components/pm-subscription-handler/pmsh_service/mod/api/services/measurement_group_service.py",
      "patchset_number": 3,
      "line": 78,
      "message": "Earlier we used to pass admin state of subscription, and now its admin state of MeasGroup as per the new format.\nThe DELETE change type will be triggered on update from UNLOCK to LOCKED admin status that would be handled in story DCAEGEN2-2820.\nI believe the third scenario is not possible as DELETE would be sent on admin state Locked.",
      "author": {
        "account_id": 7746,
        "name": "Sagar Shetty",
        "display_name": null,
        "email": "sagar.shetty@est.tech",
        "username": "SagarS"
      },
      "updated": "2021-12-07 11:10:58.000000000",
      "in_reply_to": "d5f5e1a7_ed9fb0fc",
      "unresolved": true
    },
    {
      "id": "3a2b4adf_71ba32c5",
      "file_path": "components/pm-subscription-handler/pmsh_service/mod/api/services/measurement_group_service.py",
      "patchset_number": 3,
      "line": 114,
      "message": "PENDING_DELETE scenario would be set on Measgrp admin status update from UNLOCKED to LOCKED performed in DCAEGEN2-2820. \nAlso, originally subscription_handler used to perform create and retry operation. Now create API handles the create action and retry needs to refactored now pertaining to a measurement group to remove measurement group assigned to a nf and eventually on subscription.",
      "author": {
        "account_id": 7746,
        "name": "Sagar Shetty",
        "display_name": null,
        "email": "sagar.shetty@est.tech",
        "username": "SagarS"
      },
      "updated": "2021-12-07 11:10:58.000000000",
      "in_reply_to": "f0c3f8ce_1479ff21",
      "unresolved": true
    },
