    {
      "id": "9b21595a_9e0abeba",
      "file_path": "controlloop/common/controller-tdjam/src/main/java/org/onap/policy/controlloop/tdjam/TdjamController.java",
      "patchset_number": 17,
      "line": 89,
      "message": "I see. I had a different understanding of what this was going to look like. It turns out that the controller and application event processing are tightly coupled here. I thought the TDJAM controller was going to be added to the Drools-PDP repo, and it was going to have no knowledge of the application data (control loop events, params, etc). It would simply receive events from topics and then forward to some registered \"event handler\", similar to how 'offer' passes events to the kie session for rules processing. That \"event handler\" would be a feature in the drools applications repo that hooks into a TDJAM controller and serves as the replacement of the drools rules layer. It would have understanding of application specific data and handle tracking events and associated event managers, etc. I have no issue with the current design if it is intended for the ONAP use cases only.",
      "author": {
        "account_id": 1677,
        "name": "Daniel Cruz",
        "display_name": null,
        "email": "dc443y@att.com",
        "username": "dc443y"
      },
      "updated": "2020-08-31 16:47:26.000000000",
      "in_reply_to": "97bb9d94_b40df6df",
      "unresolved": true
    }
  ]
