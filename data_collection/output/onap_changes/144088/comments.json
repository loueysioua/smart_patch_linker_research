      "id": "c5b223ab_16a46d9d",
      "file_path": "runtime-acm/src/test/groovy/org/onap/policy/clamp/acm/runtime/supervision/SupervisionAcHandlerSpec.groovy",
      "patchset_number": 4,
      "line": 76,
      "message": "Test could be simplified using a 'where' table:\n\n    given: \"an automation composition and an ack message built from it\"\n    def ac = helper.loadAc(\"Crud\")\n    def msg = helper.buildAck(ac)\n\n    and: \"parameters are set from the table\"\n    msg.stateChangeResult = stateChangeResult\n    msg.automationCompositionId = automationCompositionId\n\n    when: \"the ack message is handled\"\n    helper.handler.handleAutomationCompositionStateChangeAckMessage(msg)\n\n    then: \"the message should not be saved\"\n    0 * helper.messageProvider.save(_)\n\n    where: \"the following parameters are used\"\n    scenario                          | stateChangeResult          | automationCompositionId\n    'stateChangeResult is null'       | null                       | identifier\n    'stateChangeResult is TIMEOUT'    | StateChangeResult.TIMEOUT  | identifier\n    'automationCompositionId is null' | StateChangeResult.NO_ERROR | null",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2026-05-01 17:36:13.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
