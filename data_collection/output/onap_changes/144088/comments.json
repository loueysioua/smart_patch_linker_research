    {
      "id": "f1b3bcc0_f50f6425",
      "file_path": "runtime-acm/src/test/groovy/org/onap/policy/clamp/acm/runtime/helper/CommissioningControllerTestHelper.groovy",
      "patchset_number": 6,
      "line": 41,
      "message": "Note Groovy doesn't strictly enforce private/public etc, so not needed. Also groovy uses type inference, so we don't need datatypes like String. Following groovy/spock documentation, this is how a constant would usually be defined:\n\n    static final ENDPOINT = \"compositions\"",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2026-05-13 11:00:39.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "e0c287de_3134b4c8",
      "file_path": "runtime-acm/src/test/groovy/org/onap/policy/clamp/acm/runtime/helper/CommissioningControllerTestHelper.groovy",
      "patchset_number": 6,
      "line": 61,
      "message": "Following https://spockframework.org/spock/docs/1.3/all_in_one.html#_fields, they recommend just initializing fields directly and not bother with constructor, e.g. \n\n    def serviceTemplate = InstantiationUtils.getToscaServiceTemplate(CommonTestData.TOSCA_SERVICE_TEMPLATE_YAML)\n    def client = new CommonRestClient()",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2026-05-13 11:00:39.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "c6305d01_c187e5a5",
      "file_path": "runtime-acm/src/test/groovy/org/onap/policy/clamp/acm/runtime/helper/CommissioningControllerTestHelper.groovy",
      "patchset_number": 6,
      "line": 124,
      "message": "can remove all the .value()'s here",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2026-05-13 11:00:39.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
