    {
      "id": "944866a3_95f3d590",
      "file_path": "models-interactions/model-impl/rest/src/test/java/org/onap/policy/rest/HttpDeleteWithBodyTest.java",
      "patchset_number": 1,
      "line": 30,
      "message": "This test actually doesn't issue any request. \nIt basically just tests the constructor, getMethod()  and getURI() method of org.onap.policy.rest.HttpDeleteWithBody\n\nSome/most servers will reject (400) any DELETE request with a body ... so it doesn't really make sense to have a test for DELETE with a body. \nSupport for DELETE with body/payload should probably be removed from org.onap.policy.rest.RestManager\n\nThe change to be reviewed is a simple string replacement from what was in the original test. \n\nIf it would be helpful I could extend the other REST test to include a DELETE without any body.",
      "author": {
        "account_id": 5519,
        "name": "John Keeney",
        "display_name": "John Keeney",
        "email": "john.keeney@est.tech",
        "username": "JohnKeeney"
      },
