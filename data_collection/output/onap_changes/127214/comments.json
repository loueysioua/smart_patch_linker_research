    {
      "id": "aeb9a071_33bb3d8a",
      "file_path": "gui-editors/gui-editor-apex/src/main/java/org/onap/policy/gui/editors/apex/rest/handling/plugin/upload/PolicyUploadHandler.java",
      "patchset_number": 3,
      "line": 48,
      "message": "There are many ways to do this with spring boot. You may:\n- pass on command line using -Dapex-editor.upload-url=<url>\n- set an environment variable, e.g. export APEX_EDITOR_UPLOAD_URL=<url>\n- place `apex-editor.upload-url=<url>` in a properties file and set -Dspring.config.location\n- place config in a default location, e.g. application.properties in current directory",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2022-02-21 15:25:32.000000000",
      "in_reply_to": "58620e21_9212d5de",
      "unresolved": false
    },
    {
