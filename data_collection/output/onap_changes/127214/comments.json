      "patchset_number": 3,
      "line": 51,
      "message": "Likewise:\n- Command line: java jar -Dapex-editor.upload-userid=myuser app.jar\n- Environment var: export APEX_EDITOR_UPLOAD_USERID=myuser\n- Properties file: apex-editor.upload-userid=myuser",
      "author": {
