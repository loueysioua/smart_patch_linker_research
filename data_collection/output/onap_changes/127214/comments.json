    {
      "id": "5769b870_0413b75f",
      "file_path": "gui-editors/gui-editor-apex/src/main/java/org/onap/policy/gui/editors/apex/rest/handling/plugin/upload/PolicyUploadHandler.java",
      "patchset_number": 3,
      "line": 48,
      "message": "I was mistaken, in fact we use the parameters:\n-uurl to set the new apex-editor.upload-url\n-uuid to set the new apex-editor.upload-userid\n\nWe also use \"-l\" and \"-p\" to set the host address and the port respectively. Were those changed to the Spring boot way or they remain the same? I couldn't find in the changes, so I believe nothing has changed for those parameters.",
      "author": {
        "account_id": 5565,
        "name": "Andr� Schmid",
        "display_name": "André Schmid",
        "email": "andre.schmid@est.tech",
        "username": "andre.schmid"
