    {
      "id": "729171ba_828a9714",
      "file_path": "models-examples/src/main/resources/policytypes/onap.policies.monitoring.cdap.tca.hi.lo.app.yaml",
      "patchset_number": 1,
      "line": 4,
      "message": "I believe the xacml-pdp code went yaml->json->ToscaPolicy and the version was left as \"null\".  To change this behavior, we'd need to modify this line as follows in ToscaPolicy:\n\n  private String typeVersion = \"1.0.0\"; // or \"0.0.0\"\n\nToscaEntity might need something similar for its version.",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2019-09-04 13:36:34.000000000",
      "in_reply_to": "1430d08c_56daf378",
      "unresolved": false
    },
    {
      "id": "15928587_1e2cd725",
      "file_path": "models-examples/src/main/resources/policytypes/onap.policies.monitoring.cdap.tca.hi.lo.app.yaml",
      "patchset_number": 1,
      "line": 4,
      "message": "When the version is not set int he Yaml, it becomes 0.0.0 when it's imported into the service template. I don't remember where this happens but it does. I'll check this later tonight if we need to.",
