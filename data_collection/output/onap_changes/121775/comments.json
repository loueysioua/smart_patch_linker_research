    {
      "id": "682ced02_33b1a53d",
      "file_path": "participant/participant-impl/participant-impl-simulator/src/main/resources/config/application.yaml",
      "patchset_number": 2,
      "line": 5,
      "message": "Usually in application.yaml we can use generic credentials for development purpose. There are many way to override parameters defined in application.yaml, and a more common is using  environment variable. Any property can be overridden by an environment variable of the same name, with the characters changed to upper case, and the dots changed to underscores. In this case SPRING_SECURITY_USER_NAME, SPRING_SECURITY_USER_PASSWORD",
      "author": {
        "account_id": 7565,
        "name": "Francesco Fiora",
        "display_name": null,
        "email": "francesco.fiora@est.tech",
        "username": "FrancescoFioraEst"
