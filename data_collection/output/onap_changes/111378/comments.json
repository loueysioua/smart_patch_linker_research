    {
      "id": "eb4e7446_5f3297b2",
      "file_path": "kubernetes/so/charts/so-etsi-nfvo-ns-lcm/values.yaml",
      "patchset_number": 3,
      "line": 57,
      "message": "Common secret template generates only plaintext passwords but you can bcrypt them in the init container and that's the desired way of handling this to make sure that the user can actually set the password without having any tools other than the text editor\n\nAs far as I remember one of SO components is already doing this",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
