      "id": "06ca013a_3d792160",
      "file_path": "cps-application/src/main/java/org/onap/cps/Application.java",
      "patchset_number": 2,
      "line": 32,
      "message": "Yes @Gerard, applyHostnameBasedStartupDelay() is executed before the Spring context is initialized because it's called before SpringApplication.run(...) in our main() method.\n\nSpring Boot will only initialize the Liquibase bean after the application context starts — which means applyHostnameBasedStartupDelay() does run before Liquibase is triggered.\n\nSo the delay logic does execute before Liquibase starts.",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
      "updated": "2025-04-09 14:46:48.000000000",
      "in_reply_to": "29a8e272_fb3e4043",
      "unresolved": true
    },
    {
      "id": "524def0f_c6875f69",
