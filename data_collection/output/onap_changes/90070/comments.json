      "file_path": "rest-services/dmaap-client/src/test/java/org/onap/dcaegen2/services/sdk/rest/services/dmaap/client/MessageRouterTestsUtils.java",
      "patchset_number": 2,
      "line": 101,
      "message": "Right, I added `jsonBatch` and `plainBatch` functions long before `getAsJsonObjects`  and have forgotten to refactor that class ;)",
