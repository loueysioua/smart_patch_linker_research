      "unresolved": true
    },
    {
      "id": "17cc5523_f6d7a124",
      "file_path": "cps-service/src/main/java/org/onap/cps/spi/exceptions/CpsExceptionBuilder.java",
      "patchset_number": 1,
      "line": null,
      "message": "I myself had some reservations about specific exceptions too initially but it was what the team agreed! Also I now see the advantage of the Java API throwing more specific exception as Java Client can then build specific handling (this was the deciding factor for a specialized exception) without the need to examine the message or details but they can also choose to just catch a superclass instead if they don't need to, it gives them more flexibility\n\nRe the need for a builder class I am awaiting response from team members...",
      "author": {
        "account_id": 6639,
        "name": "Toine Siebelink",
        "display_name": null,
        "email": "toine.siebelink@est.tech",
        "username": "ToineSiebelink"
      },
      "updated": "2020-12-09 12:31:55.000000000",
      "in_reply_to": "366f7a75_71e95cbd",
      "unresolved": true
    },
    {
