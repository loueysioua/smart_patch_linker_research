    },
    {
      "id": "4a8423be_58edc48f",
      "file_path": "cps-ri/src/main/java/org/onap/cps/spi/impl/CpsAdminPersistenceServiceImpl.java",
      "patchset_number": 1,
      "line": 56,
      "message": "I'll revert to generation of not found exceptions in the repository\nhoever I do see value in a specific DataspaceNotFound exception as dataspace is such a core concept for CPS it is good to have a clear exception separate form more generic not found exceptions",
      "author": {
        "account_id": 6639,
        "name": "Toine Siebelink",
        "display_name": null,
        "email": "toine.siebelink@est.tech",
