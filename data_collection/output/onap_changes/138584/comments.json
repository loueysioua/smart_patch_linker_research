    {
      "id": "f23ab76c_8f6befd4",
      "file_path": "k6-tests/ncmp/ncmp-kpi.js",
      "patchset_number": 1,
      "line": 160,
      "message": "We should not use iteration as batch number here because we have 20000 CM-handles total, and if we batch read 200 each time, after 100 iterations, the generated cm handle IDs will be bigger than 20000!\n\nI'd suggest to just the same batchNumber e.g. 1 each time, or randomly pick a batch number between 1 and (TOTAL_CM_HANDLES / DATA_OPERATION_READ_BATCH_TOTAL_SIZE)",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2024-07-29 09:42:40.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "5c8f924c_e3cb0617",
      "file_path": "k6-tests/ncmp/ncmp-kpi.js",
      "patchset_number": 1,
      "line": 166,
      "message": "We are not measuring the http request time! Only the arrival rate of the kafka responses. No need to record anything here, just execute the request.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2024-07-29 09:42:40.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
