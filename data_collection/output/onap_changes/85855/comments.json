    {
      "id": "60ff81b7_02879ea0",
      "file_path": "products/onap-dublin/features/so/src/main/resources/open-cli-schema/service-create-schema-dublin.yaml",
      "patchset_number": 2,
      "line": 36,
      "message": "The cloud region are usually specified when creating the VNF instance and the VF module. It is not specified when creating the service instance even without homing. I have tested both cases and confirmed that it works. I also looked through the request sent when the ONAP GUI is used to create a service instance, no cloud details are specified",
      "author": {
        "account_id": 2395,
        "name": "Itohan Ukponmwan",
        "display_name": null,
        "email": "itohan.ukponmwan@intel.com",
        "username": "Itohan"
      },
      "updated": "2019-04-26 18:14:17.000000000",
      "in_reply_to": "388ae77e_9540a66d",
      "unresolved": false
    },
    {
      "id": "d314da88_77f76fc9",
      "file_path": "products/onap-dublin/features/so/src/main/resources/open-cli-schema/service-create-schema-dublin.yaml",
      "patchset_number": 2,
      "line": 36,
      "message": "Yes I tested it without homing and confirmed that it works. I also looked Through the request sent by VID when you create a service instance via GUI. No cloud region or tenant is specified. The cloud region and tenant are usually specified when creating the VNF instance and the VF module not when creating the service instance.",
      "author": {
        "account_id": 2395,
        "name": "Itohan Ukponmwan",
        "display_name": null,
        "email": "itohan.ukponmwan@intel.com",
        "username": "Itohan"
      },
      "updated": "2019-04-26 18:14:17.000000000",
      "in_reply_to": "f47235d3_abe8ae1f",
      "unresolved": false
    },
