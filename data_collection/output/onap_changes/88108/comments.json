    {
      "id": "03ca96cb_8c2a48bd",
      "file_path": "components/aai-graphgraph/templates/deployment.yaml",
      "patchset_number": 4,
      "line": 40,
      "message": "There is a race condition such that if schema service isn't started and ready that graph graph will fail to start or start with incomplete data?\nIts best to add an init container to wait for this pod to be up until schema service is ready.\n\nYou can refer to how graphadmin is done.\n\nhttps://gerrit.onap.org/r/gitweb?p=aai/oom.git;a=blob;f=components/aai-graphadmin/templates/deployment.yaml;h=f768603a8960aec3f450ef09ffa7a0853dac4e99;hb=HEAD\n\nYou can change it so you only wait for schema service as graph graph doesn't need to wait for Cassandra",
      "author": {
        "account_id": 75,
        "name": "Venkata Harish Kajur",
        "display_name": null,
        "email": "vk250x@att.com",
        "username": "vk250x"
      },
      "updated": "2019-08-26 19:00:04.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
