    {
      "id": "a0fcf2f4_107046e6",
      "file_path": "rest-services/aai-client/src/main/java/org/onap/dcaegen2/services/sdk/rest/services/aai/client/service/http/put/AaiHttpPutClient.java",
      "patchset_number": 3,
      "line": 41,
      "message": "Yes, we do plan on moving to the new API. The reason why we do not want to make the switch adhoc and still keep this aligned with the old API for now is because these changes had been introduced before the new API was introduced and old API became deprecated. Switching to new API would require changes on PRH side which we do not want to risk doing before having e2e impl finished. Also IMO switching to new API can and should be a bulk change.",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2019-03-25 09:42:24.000000000",
      "in_reply_to": "1df241ca_7cb57941",
      "unresolved": false
    },
