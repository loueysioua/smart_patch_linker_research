    {
      "id": "267c3b04_b04be079",
      "file_path": "kubernetes/cps/components/cps-temporal/resources/config/application-helm.yml",
      "patchset_number": 5,
      "line": 35,
      "message": "As cps is going to add some other topics in the next release, then it might be good to rename the property with something like `config.app.listener.data-updated.topic` to be able to identify this topic.\n\nAlso, this topic name property is not strimzi kafka specfic,then it would be good not to have strimzy kafka in the property name.\n\nFinally, it seems that topic name is not configured the same way in cps core and cps temporal. Making this consistent is out of the scope of this change and can be reworked in a different change.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
