      "unresolved": true
    },
    {
      "id": "0b37bc84_968d5a3f",
      "file_path": "certService/src/main/java/org/onap/aaf/certservice/certification/configuration/validation/Cmpv2ServerValidator.java",
      "patchset_number": 3,
      "line": 44,
      "message": "Yes, but also now, all these Violations and Validator are visible in the whole Spring context and it's not necessary, because we need it only here. From my perspective it violates encapsulation. This code here is also way more complicated and the only benefit we get is scalability, which I think we don't need here.",
      "author": {
        "account_id": 3771,
        "name": "Adam Wudzinski",
        "display_name": null,
        "email": "adam.wudzinski@nokia.com",
        "username": "adamwudzinski"
      },
