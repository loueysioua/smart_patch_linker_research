    {
      "id": "1a2f8d8d_14a3b59f",
      "file_path": "aai-core/src/main/resources/dbedgerules/DbEdgeRules_v11.json",
      "patchset_number": 2,
      "line": 455,
      "message": "Hello Jimmy,\nAs per our discussion we can retrieve the vim (esr-system-info) using vim-id from esr-vnfm.\n\nNow the relationship will look like this:\ngeneric-vnf -> esr-vnfm -> esr-system-info (vim which has attribute default-tenant).\n\nNow we can remove this relationship.",
      "author": {
        "account_id": 879,
        "name": "subhash kumar singh",
        "display_name": null,
        "email": "subh.singh@samsung.com",
        "username": "subhash_singh"
      },
      "updated": "2017-10-11 07:12:22.000000000",
      "in_reply_to": "1a2f8d8d_5436e204",
      "unresolved": false
    },
    {
