      "file_path": "aai-schema/src/main/resources/oxm/aai_oxm_v11.xml",
      "patchset_number": 3,
      "line": 298,
      "message": "the system-name in esr-system-info which wrapped in esr-vnfm is indicate to the vnfm-name. So, here should not add it again",
      "author": {
        "account_id": 313,
        "name": "Li Zi",
        "display_name": null,
        "email": "li.zi30@zte.com.cn",
        "username": "nancylizi"
      },
      "updated": "2017-10-11 07:56:17.000000000",
