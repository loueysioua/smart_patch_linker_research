      "id": "e1452d72_212bb12c",
      "file_path": "build/build_nexus_blob.sh",
      "patchset_number": 7,
      "line": 35,
      "message": "hmm not sure... i have probably seen this once or twice, but do you have a guarantee that bash itself does not in fact use these descriptors? When you use bash specific features to allocate a fresh descriptor, bash always starts from 10. Not quite sure if this redirection via using argument-less exec is bash specific or not, but if we want bash specific behaviour we may do for example, instead of 3>&1, something like {OLD_STDOUT}>&1.",
      "author": {
        "account_id": 5019,
        "name": "Michal Zegan",
        "display_name": null,
        "email": "m.zegan@samsung.com",
        "username": "m.zegan"
