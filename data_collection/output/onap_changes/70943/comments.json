    },
    {
      "id": "bada0100_dec082e2",
      "file_path": "vid-app-common/src/test/java/org/onap/vid/mso/MsoBusinessLogicImplTest.java",
      "patchset_number": 2,
      "line": 301,
      "message": "This is true, but only for the newer version of mockito >2. \nThe older (currently used) version of Mockito provides ArgumentMatcher as an abstract class which is buggy - even though it is parametrized with a generic type, the Object type is hardcoded in the matches method. In the newer version of Mockito ArgumentMatcher exists as a proper interface. For now this will have to stay. \nFor reference check: https://static.javadoc.io/org.mockito/mockito-core/2.2.9/org/mockito/ArgumentMatcher.html\nThere is even a migration guide :)",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
