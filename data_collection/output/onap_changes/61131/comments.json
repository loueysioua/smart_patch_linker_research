    },
    {
      "id": "1a76adc5_3a40b0a4",
      "file_path": "main/src/main/java/org/onap/policy/distribution/main/healthcheck/HealthCheckMonitor.java",
      "patchset_number": 3,
      "line": 81,
      "message": "Are we using Java properties here? Should these not be in our parameters as a parameter group, otherwise we have two different ways of configuring app.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2018-08-19 16:35:20.000000000",
