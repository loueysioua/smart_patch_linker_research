    {
      "id": "3f7a5d69_ae937c65",
      "file_path": "mod/bpgenerator/src/main/java/org/onap/blueprintgenerator/models/blueprint/ExternalTlsInfo.java",
      "patchset_number": 14,
      "line": 84,
      "message": "Hello @Vijay,\nI think Remigiusz followed here allready existing in app design which could be find in Properties.java:\n```\n\tprivate void addTlsInfo(ComponentSpec cs, TreeMap<String, LinkedHashMap<String, Object>> retInputs) {\n\t\tTlsInfo tlsInfo = new TlsInfo();\n\t\ttlsInfo.setCertDirectory((String) cs.getAuxilary().getTls_info().get(\"cert_directory\"));\n\t\tGetInput useTLSFlag = new GetInput();\n\t\tuseTLSFlag.setGet_input(\"use_tls\");\n\t\ttlsInfo.setUseTls(useTLSFlag);\n\t\tthis.setTls_info(tlsInfo);\n\t\tLinkedHashMap<String, Object> useTlsFlagInput = new LinkedHashMap<String, Object>();\n\t\tuseTlsFlagInput.put(\"type\", \"boolean\");\n\t\tuseTlsFlagInput.put(\"description\", \"flag to indicate tls enable/disable\");\n\t\tuseTlsFlagInput.put(\"default\", cs.getAuxilary().getTls_info().get(\"use_tls\"));\n```",
      "author": {
        "account_id": 2837,
        "name": "Kornel Janiak",
        "display_name": null,
        "email": "kornel.janiak@nokia.com",
        "username": "kjaniak"
      },
      "updated": "2020-07-02 07:08:31.000000000",
      "in_reply_to": "0790d1d0_b7496ab5",
      "unresolved": true
    },
