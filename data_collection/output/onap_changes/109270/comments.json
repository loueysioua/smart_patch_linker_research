    {
      "id": "7692634c_f4107357",
      "file_path": "mod/bpgenerator/src/test/java/org/onap/blueprintgenerator/core/BlueprintGeneratorTest.java",
      "patchset_number": 14,
      "line": 429,
      "message": "I understand; my comment were towards specific properties being sourced from spec file itself",
      "author": {
        "account_id": 93,
        "name": "Vijay Venkatesh Kumar",
        "display_name": null,
        "email": "vijayv81@gmail.com",
        "username": "vv770d"
      },
      "updated": "2020-07-02 14:48:19.000000000",
      "in_reply_to": "36ebf5b3_1fb0feb6",
