    {
      "id": "bf71a9bc_d8d82036",
      "file_path": "jjb/integration/simulators/integration-pnf-simulator.yaml",
      "patchset_number": 3,
      "line": 33,
      "message": "as far as I understand this job is responsible for static code analysis and is responsible for yaml, yml and json validation. In our case it is causing more problems, because we have incorrect json for testing purpose and if it comes to code analysis, we are using sonar, so in my opinion this job is not needed",
      "author": {
        "account_id": 5098,
        "name": "Bartosz Gardziejewski",
        "display_name": null,
        "email": "bartosz.gardziejewski@nokia.com",
        "username": "BartoszG"
      },
      "updated": "2020-04-07 05:56:30.000000000",
      "in_reply_to": "2e1b6a83_3f2d841b",
      "unresolved": true
    },
    {
      "id": "706a06f5_1dd61afb",
      "file_path": "jjb/integration/simulators/integration-pnf-simulator.yaml",
      "patchset_number": 3,
      "line": 33,
      "message": "as I understand Bartek G., mentioned json files are used in JUnit tests to verify behavior of logic in error cases. So in our case mentioned job is not applicable.",
      "author": {
        "account_id": 3433,
        "name": "Bogumil Zebek",
        "display_name": null,
        "email": "bogumil.zebek@nokia.com",
        "username": "bogumil_zebek"
      },
      "updated": "2020-04-07 06:01:35.000000000",
      "in_reply_to": "bf71a9bc_d8d82036",
      "unresolved": true
    },
    {
      "id": "37c32fed_973a0efe",
      "file_path": "jjb/integration/simulators/integration-pnf-simulator.yaml",
      "patchset_number": 3,
      "line": 33,
      "message": "Sonar is run as a daily job, not as a gating job for patchset. If there are files that you wouldn't want to be linted they can be added to ignores (\"ignore\" keyword in relevant section of .coafile).",
