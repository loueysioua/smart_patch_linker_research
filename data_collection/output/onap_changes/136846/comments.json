    {
      "id": "7cfe706b_da61511b",
      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/api/impl/config/HttpClientConfiguration.java",
      "patchset_number": 3,
      "line": 49,
      "message": "Yes, 5 connections per route is the cause of the observed degradation when Apache HttpClient is on the class-path (Apache uses maxConnPerRoute = 5 by default). The use-case has a DMI that supports 24 parallel connections, with DMI requests having high latency (> 1 second), so 24 connections minimum. We also need a connection for DMI healthcheck, so 25. To future-proof, I double that to 50. The user may have two or more DMIs, so 2x that for total connections (100) is a sensible default. No need for more since it's now configurable.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2023-12-18 11:40:28.000000000",
      "in_reply_to": "00567826_06ab8c93",
      "unresolved": false
    },
    {
      "id": "96e781a5_5d4c774e",
      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/api/impl/config/HttpClientConfiguration.java",
      "patchset_number": 3,
      "line": 32,
      "message": "will add to ReadTheDocs in separate commit",
      "author": {
        "account_id": 3237,
