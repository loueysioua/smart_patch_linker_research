    {
      "id": "e13ce279_2bb6b678",
      "file_path": "catalog-be/src/test/java/org/openecomp/sdc/be/components/impl/ComponentInstanceBusinessLogicTest.java",
      "patchset_number": 2,
      "line": 1779,
      "message": "Theses tests are way too long. This is probably due to the lack of factory method to create ComponentIntances and Resources. Please factor these object building with additional methods.\n\nAlso, the mocks look like these tests target the internal details of the createComponentInstance function. A test should always be done against the API of a function, not against its internals. If this is not possible, this means the function probably needs to be refactored by leveraging inversion of control and/or be split into multiple smaller functions (Considering the size of the class, I would probably go with extracting meaningful testable chunks). This is probably not possible here, but should be kept in mind in the future.",
      "author": {
        "account_id": 6614,
        "name": "Francis Toth",
        "display_name": null,
        "email": "francis.toth@yoppworks.com",
        "username": "francistoth"
      },
      "updated": "2020-05-05 17:20:25.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
