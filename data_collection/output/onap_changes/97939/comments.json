    {
      "id": "a6b9fd7c_bb1b4b54",
      "file_path": "models-pdp/src/main/java/org/onap/policy/models/pdp/persistence/concepts/JpaPdp.java",
      "patchset_number": 2,
      "line": 91,
      "message": "It will be better to have PdpStatistics as a separate table with PdpName & Timestamp of the statistics entry as primary key. So that everytime we update the statistics in DB we don't need to update the main Pdp table. Thoughts?",
      "author": {
        "account_id": 3239,
        "name": "Ram Krishna Verma",
        "display_name": null,
        "email": "ramkrishna.verma@gmail.com",
        "username": "ramverma"
      },
      "updated": "2019-11-07 15:37:30.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "d69d7def_20e4e412",
      "file_path": "models-pdp/src/main/java/org/onap/policy/models/pdp/persistence/concepts/JpaPdp.java",
      "patchset_number": 2,
      "line": 91,
      "message": "I agree.\n\nActually we must have this table, otherwise we have no history of the statistics, only the most recent ones.\n\nAlso then we wouldn't need to update the PDP table every time just for a statistics update change.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2019-11-07 16:16:55.000000000",
      "in_reply_to": "a6b9fd7c_bb1b4b54",
      "unresolved": false
    },
