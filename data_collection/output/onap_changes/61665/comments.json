    {
      "id": "1a76adc5_822f12f6",
      "file_path": "packer/provision/local-docker.yaml",
      "patchset_number": 2,
      "line": 133,
      "message": "The copy module is preferred over 'command: mv' as it will only run if the file doesn't already exist, and will allow you to set file attributes at the same time.\n\n> remote_src: true\n\nThis is needed as the default copy module assumes your copying a file from your host to the guest machine.\n\n> - name: Install rebar3\n>   copy:\n>     src: /tmp/rebar3/rebar3\n>     dest: /usr/bin/rebar3\n>     remote_src: true",
      "author": {
        "account_id": 3833,
        "name": "Trevor Bramwell",
        "display_name": null,
        "email": "tbramwell@linuxfoundation.org",
        "username": "bramwelt"
      },
      "updated": "2018-08-21 20:21:47.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
