        "account_id": 7833,
        "name": "Kevin Sandi",
        "display_name": null,
        "email": "ksandi@contractor.linuxfoundation.org",
        "username": "kevin.sandi"
      },
      "updated": "2025-05-14 17:35:35.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
