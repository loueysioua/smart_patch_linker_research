    {
      "id": "f07d8a25_743ffe52",
      "file_path": "build/creating_data/docker-images-collector.sh",
      "patchset_number": 6,
      "line": 87,
      "message": "exact examples are visible in this comment\nhttps://jira.onap.org/browse/OOM-1622?focusedCommentId=35132&page=com.atlassian.jira.plugin.system.issuetabpanels%3Acomment-tabpanel#comment-35132\n\nTomas already spent some time in finding non-helm way and I really don't think it's worth for the effort. Furthermore, keeping native helm parsing looks also safer to maintain with regards of all possible changes in yaml charts.",
      "author": {
        "account_id": 4009,
        "name": "Michal Ptacek",
        "display_name": null,
        "email": "m.ptacek@partner.samsung.com",
        "username": "Michal.Ptacek"
