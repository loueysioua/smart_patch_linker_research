    {
      "id": "4b1a95bc_327c543d",
      "file_path": "docs/Chapter7/Monitoring-And-Management.rst",
      "patchset_number": 5,
      "line": 481,
      "message": "Both MUST and should in text.\n\nTo be backwards compatible with VES 7.1.1, should add the following:\n\nThe VNF or PNF MAY discard buffered events older than a certain time limit even if the event was never successfully delivered to the event listener. This limit should not be less than 1 hour.",
      "author": {
        "account_id": 5279,
        "name": "Oskar Malm",
        "display_name": null,
        "email": "oskar.malm@ericsson.com",
        "username": "eoskmal"
      },
      "updated": "2020-06-11 09:21:56.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "b6feffbb_8da801ce",
      "file_path": "docs/Chapter7/Monitoring-And-Management.rst",
      "patchset_number": 5,
      "line": 493,
      "message": "This requirement is not backwards compatible with VES 7.1.1. See also comment above. Suggested change:\n\nA VNF or PNF producing VES events that is buffering events per R-658596 MUST store new in-scope events even when the maximum capacity of the buffer has been reached. To make room for new events in this situation, the oldest events in the buffer shall be removed as necessary (i.e. First In First Out).",
      "author": {
        "account_id": 5279,
        "name": "Oskar Malm",
        "display_name": null,
        "email": "oskar.malm@ericsson.com",
        "username": "eoskmal"
      },
      "updated": "2020-06-11 09:21:56.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
