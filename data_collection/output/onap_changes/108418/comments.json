    {
      "id": "9096192e_98bb7309",
      "file_path": "docs/Chapter7/Monitoring-And-Management.rst",
      "patchset_number": 4,
      "line": 490,
      "message": "The VNF or PNF may have a time limit for how long events are buffered. In fact VES 7.1.1 stated that events should be buffered for maximum of 1h, although this is changed to at least 1h in R-658596 above. I think this requirement should be reworded to describe that if buffer becomes full before time limit is reached, FIFO approach shall be used to make room for new events.",
      "author": {
        "account_id": 5279,
        "name": "Oskar Malm",
        "display_name": null,
        "email": "oskar.malm@ericsson.com",
        "username": "eoskmal"
      },
      "updated": "2020-06-03 23:06:27.000000000",
