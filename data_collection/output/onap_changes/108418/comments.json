    {
      "id": "51f5cd66_d999235c",
      "file_path": "docs/Chapter7/Monitoring-And-Management.rst",
      "patchset_number": 4,
      "line": 490,
      "message": "I've made some changes here, but I don't know if I fully addressed the comment.  I split out the sizing of the buffer to a new requirement (i.e. the buffer size must be enough to store at least an hour).  I tweaked the wording here, but I don't know if it's what you're looking for. I think regardless of whether the buffer fills up before or after the minimum time limit, the logic is is the same (FIFO).  If the revised wording does not address your concerns, then please feel free to propose alternate language.",
      "author": {
        "account_id": 3999,
        "name": "Trevor Lovett",
        "display_name": null,
        "email": "trevor.lovett@att.com",
        "username": "tl2972"
      },
      "updated": "2020-06-09 17:02:23.000000000",
      "in_reply_to": "9096192e_98bb7309",
      "unresolved": false
    },
