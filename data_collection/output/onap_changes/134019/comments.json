      "line": 494,
      "message": "I was referring to this comment from Toine https://gerrit.onap.org/r/c/cps/+/134019/9/cps-service/src/main/java/org/onap/cps/spi/CpsDataPersistenceService.java#147\n\nSo if all the team members agree I can rollback the code to Collection<DataNode>.",
      "author": {
        "account_id": 7846,
        "name": "Arpit Singh",
        "display_name": "Arpit",
        "email": "as00745003@techmahindra.com",
        "username": "arpitsingh"
      },
      "updated": "2023-05-03 09:49:54.000000000",
      "in_reply_to": "0522b6a9_a3031e31",
      "unresolved": true
    },
