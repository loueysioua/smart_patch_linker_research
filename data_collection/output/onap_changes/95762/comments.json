      "id": "9fed986e_d4492ef9",
      "file_path": "applications/common/src/main/java/org/onap/policy/pdp/xacml/application/common/TestUtils.java",
      "patchset_number": 1,
      "line": 71,
      "message": "I'm trying to fix sonar complaints - here specifically they don't want multiple exception types to be thrown. So I'm consolidating into just XacmlApplicationException.\nSonar wants you to either log or re-throw the exception so I thought this would clear all of them as the caller should be catching and logging the exception.\nI will need to create a constructor to add in the e.",
      "author": {
        "account_id": 57,
        "name": "Pamela Dragosh",
        "display_name": null,
        "email": "pd1248@att.com",
        "username": "pdragosh"
      },
      "updated": "2019-09-17 13:25:57.000000000",
      "in_reply_to": "6ccce079_8445ea0e",
      "unresolved": false
    },
    {
      "id": "f8329089_c9cae87c",
