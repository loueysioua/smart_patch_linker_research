      "id": "a4a39293_c4b70ede",
      "file_path": "kubernetes/dcaegen2-services/components/dcae-hv-ves-collector/values.yaml",
      "patchset_number": 8,
      "line": 113,
      "message": "With 1.8.0 HV-VES there should be 4 new streams_publishes added.\nYou can paste them as below, just pay attention to spacing:\n\n    ves-3gpp-fault-supervision:\n      type: kafka\n      aaf_credentials:\n        username: ${AAF_USER}\n        password: ${AAF_PASSWORD}\n      kafka_info:\n        bootstrap_servers: message-router-kafka:9092\n        topic_name: SEC_3GPP_FAULTSUPERVISION_OUTPUT\n    ves-3gpp-provisioning:\n      type: kafka\n      aaf_credentials:\n        username: ${AAF_USER}\n        password: ${AAF_PASSWORD}\n      kafka_info:\n        bootstrap_servers: message-router-kafka:9092\n        topic_name: SEC_3GPP_PROVISIONING_OUTPUT\n    ves-3gpp-heartbeat:\n      type: kafka\n      aaf_credentials:\n        username: ${AAF_USER}\n        password: ${AAF_PASSWORD}\n      kafka_info:\n        bootstrap_servers: message-router-kafka:9092\n        topic_name: SEC_3GPP_HEARTBEAT_OUTPUT\n    ves-3gpp-performance-assurance:\n      type: kafka\n      aaf_credentials:\n        username: ${AAF_USER}\n        password: ${AAF_PASSWORD}\n      kafka_info:\n        bootstrap_servers: message-router-kafka:9092\n        topic_name: SEC_3GPP_PERFORMANCEASSURANCE_OUTPUT",
      "author": {
