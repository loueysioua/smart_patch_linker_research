      {
        "id": "224843f74ad8bb5de74648fff8368ba3de9f94d7",
        "author": {
          "account_id": 4965,
          "name": "Krzysztof Opasiak",
          "display_name": null,
          "email": "k.opasiak@samsung.com",
          "username": "kopasiak"
        },
        "author_role": "OWNER",
        "timestamp": "2019-01-29 16:39:37.000000000",
        "message": "Patch Set 2:\n\nNothing special to be honest. I'm learning on Policy FW and I opened this piece of code and I saw that it's a total mess there in terms of architecture and code (copy-paste programming for example) so now I'm trying to get more deeply in it and rework Topic Factories as mention in parent of this task.\n\nThis series is just a small fix that I did in the beginning and now I'm working further on simplifying topic factories",
        "patchset_number": 2
      },
      {
        "id": "199e58763becbb2aaf558d8720ffe1e012a2e672",
        "author": {
          "account_id": 477,
          "name": "Jorge Hernandez",
