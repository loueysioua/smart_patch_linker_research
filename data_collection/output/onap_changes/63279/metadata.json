      {
        "id": "cc4d4eec867c920d04103b9e71bc051fc021c719",
        "author": {
          "account_id": 1423,
          "name": "Rob Daugherty",
          "display_name": null,
          "email": "rd472p@att.com",
          "username": "rd472p"
        },
        "author_role": "OWNER",
        "timestamp": "2018-08-28 21:54:30.000000000",
        "message": "Patch Set 2: -Code-Review\n\nYou raise a good point, Marcus. Leave this open and I'll do some more testing.  Because these are libraries used in the openstack adapter springboot app, we are rather limited to what springboot 1.5.13.RELEASE can support in terms of different jackson versions.  I do know that this version of springboot will not work with any jackson 2.9 version, but I think it will work with 2.8.10 or 2.8.11, which may help us somewhat with the CVEs.",
        "patchset_number": 2
      },
      {
        "id": "f13baa5c9c0285f780c3812c6e2899058e236cba",
        "author": {
          "account_id": 1423,
          "name": "Rob Daugherty",
          "display_name": null,
          "email": "rd472p@att.com",
          "username": "rd472p"
        },
        "author_role": "OWNER",
        "timestamp": "2018-08-28 21:57:21.000000000",
        "message": "Patch Set 2:\n\nJackson 2.8.11 is still vulnerable to Sonatype CWE: 502, but as you say, it fixes CVE-2017-7525",
        "patchset_number": 2
      },
