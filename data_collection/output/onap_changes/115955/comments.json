    {
      "id": "a23b0bea_40b5665e",
      "file_path": "odlparent/setup/src/main/resources/pom-template.xml",
      "patchset_number": 1,
      "line": 57,
      "message": "If ODL Aluminum is only looking for bundles build using JDK11, \nthen source and target is not required and \nmaven-compiler-plugin needs to be overriden as below:\n\n    \n<plugin>\n    <groupId>org.apache.maven.plugins</groupId>\n    <artifactId>maven-compiler-plugin</artifactId>\n    <version>3.8.1</version>\n    <configuration>\n        <release>${java.version}</release>\n        <!--explicitly remove source and target-->\n        <source combine.self=\"override\"/>\n        <target combine.self=\"override\"/>\n    </configuration>\n</plugin>\n\n\nFurther, maven-surefire-plugin and maven-failsafe-plugin version should be upgraded to 3.0.0-M5\n\nRefer: https://gerrit.onap.org/r/c/ccsdk/cds/+/111484/40/pom.xml#67 for relative changes !",
      "author": {
        "account_id": 865,
        "name": "KAPIL SINGAL",
        "display_name": null,
        "email": "ks220y@att.com",
        "username": "ks220y"
      },
      "updated": "2020-12-02 18:21:02.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
