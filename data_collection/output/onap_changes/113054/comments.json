    },
    {
      "id": "ef6349c1_76cfd78e",
      "file_path": "models-interactions/model-simulators/src/main/java/org/onap/policy/simulators/CdsSimulator.java",
      "patchset_number": 3,
      "line": 149,
      "message": "eventType also will have to be changed to \"EVENT_COMPONENT_FAILURE\".\nAlso when it comes to CDS failure, the ExecutionServiceOutput usually has the payload content same as that of ExecutionServiceInput object by default unless there is some payload specific to error. But the same payload as success response doesn't make much sense, if the simulator is to behave like a real CDS.",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
      },
      "updated": "2020-09-24 10:40:26.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
