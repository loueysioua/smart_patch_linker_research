    {
      "id": "cb1d66fc_ab52d634",
      "file_path": "models-interactions/model-simulators/src/main/java/org/onap/policy/simulators/CdsSimulator.java",
      "patchset_number": 3,
      "line": 85,
      "message": "As the intention of this responseTimer is to wait for the said time to return a response, I guess you are doing this to substract the time already taken to read the response. Just waiting for the specific time should have been ok as well.\nYou might want to avoid Thread.sleep and use something like a latch if possible.",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
      },
      "updated": "2020-09-24 10:40:26.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "503bd745_d2a70d16",
      "file_path": "models-interactions/model-simulators/src/main/java/org/onap/policy/simulators/CdsSimulator.java",
      "patchset_number": 3,
      "line": 138,
      "message": "Better to keep the responses like <blueprintName>-<actionName>.json so that the simulator can support different scenarios in usecases testing.",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
      },
