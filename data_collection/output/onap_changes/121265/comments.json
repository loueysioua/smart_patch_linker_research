    {
      "id": "2eb6ec25_f91f01c5",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/comm/msgdata/UpdateReq.java",
      "patchset_number": 1,
      "line": 104,
      "message": "I don't think this is going to work.   \nOn the drools review, the agreement was that it was to have no changes on this, being OK to keep sending the policy-ids deployed as before.   \nIt will probably also break xacml as it does not support the deploy and undeploy lists yet.   I think this is also comparing different types, getPolicies() returns policy-ids while getPoliciesToBeDeployed() returns full tosca policies.   \nThis implementation also loses functionality as it does not verify that the policies in the undeploy list have being truly undeployed.   That was supported too in the previous implementation.\nI suggest to keep the getPolicies as before and what needs to be checked is that the policiesToBeDeployed are a subset of getPolicies, and policiesToBeUndeployed yields the empty set in the intersection with the getPolicies set.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2021-05-11 21:54:01.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "d6aa113c_7d15295e",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/comm/msgdata/UpdateReq.java",
