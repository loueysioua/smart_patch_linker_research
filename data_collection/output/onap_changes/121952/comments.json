    {
      "id": "99333efa_b440a31f",
      "file_path": "pom.xml",
      "patchset_number": 5,
      "line": 361,
      "message": "The dmi-plugins pom's parent pom is org.onap.oparent, in this parent pom the docker.push.registry variable equals nexus3.onap.org:10003, this is why we need the / here. In CPS, we are not using the docker.push.registry from the oparent pom, instead we are using docker.repository.push which comes from the cps-parent pom.",
      "author": {
        "account_id": 7486,
        "name": "Shiva Subedi",
        "display_name": null,
        "email": "shiva.subedi@est.tech",
        "username": "shivasubedi"
      },
