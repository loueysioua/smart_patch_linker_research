      "file_path": "main/src/main/java/org/onap/policy/api/main/rest/provider/HealthCheckProvider.java",
      "patchset_number": 1,
      "line": 72,
      "message": "perhaps I was thinking of the Root policy TYPE.  In any event, there must be some query we can make that use an index to retrieve a single record",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
