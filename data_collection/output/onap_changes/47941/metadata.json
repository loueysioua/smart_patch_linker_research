        },
        "author_role": "OWNER",
        "timestamp": "2018-05-16 23:48:27.000000000",
        "message": "Patch Set 1:\n\nThe fact that there is already a ReplicaSet makes this very easy - i did however completely uninstall and helm install onap to pick up this change so the service distributes the load",
        "patchset_number": 1
      },
