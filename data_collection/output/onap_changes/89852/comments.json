    {
      "id": "f9fc426d_9811dcbf",
      "file_path": "vid-app-common/src/main/java/org/onap/vid/aai/AaiOverTLSClient.java",
      "patchset_number": 3,
      "line": 101,
      "message": "I think should be named `probeGetAllSubscribers`.",
      "author": {
        "account_id": 4379,
        "name": "Ittay Stern",
        "display_name": null,
        "email": "ittay.stern@att.com",
        "username": "ittays"
