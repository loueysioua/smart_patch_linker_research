    {
      "id": "b469d3d5_64cc8995",
      "file_path": "plans/policy/api/setup.sh",
      "patchset_number": 2,
      "line": 27,
      "message": "General comment:\n\nI think get-versions.sh script is unnecessary.  This one liner would be the version for example for the API component:\n\n[~] POLICY_API_VERSION=\"$(curl --silent https://git.onap.org/policy/api/plain/pom.xml?h=dublin | xmllint --xpath '/*[local-name()=\"project\"]/*[local-name()=\"version\"]/text()' -)\"\n\n[~] echo $POLICY_API_VERSION\n2.0.2-SNAPSHOT\n\nNeed to install - apt  install libxml2-utils though\n\nBut would be much simpler and faster.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2019-06-10 17:58:58.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
