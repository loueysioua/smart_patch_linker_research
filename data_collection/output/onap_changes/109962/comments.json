    },
    {
      "id": "cf9c09a3_ee25f4bb",
      "file_path": "asdctool/src/test/java/org/openecomp/sdc/asdctool/impl/validator/ValidationToolBLTest.java",
      "patchset_number": 2,
      "line": 42,
      "message": "So overall the problem is that it impacts performances as using an interface here will require the compiler to use dynamic dispatch to retrieve which implementation of the functions called on `List` should be used. In this case, this does not really make a difference but applying this principle without knowing what it implies could significantly impact performances.",
      "author": {
        "account_id": 6614,
        "name": "Francis Toth",
        "display_name": null,
        "email": "francis.toth@yoppworks.com",
        "username": "francistoth"
