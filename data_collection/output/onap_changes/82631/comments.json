    {
      "id": "c5f3ca25_f2e9f8c0",
      "file_path": "sources/hv-collector-core/src/main/kotlin/org/onap/dcae/collectors/veshv/impl/Router.kt",
      "patchset_number": 9,
      "line": 87,
      "message": "For now we should pass null as a partition. We do not support any partitioning so it might be better to make kafka sender do this for us.\n\nThe meaning of null partition in SenderRecord: \"The partition to which the record is sent. If null, the partitioner configured for the {@link KafkaSender} will be used to choose the partition.\"",
      "author": {
        "account_id": 2683,
        "name": "Piotr Jaszczyk",
        "display_name": null,
        "email": "piotr.jaszczyk@nokia.com",
        "username": "jaszczur"
      },
      "updated": "2019-03-28 08:18:20.000000000",
