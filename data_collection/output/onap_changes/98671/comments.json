    {
      "id": "a163784b_8eb5a141",
      "file_path": "miss_htbt_service/config_notif.py",
      "patchset_number": 3,
      "line": 43,
      "message": "If you want to maintain python2-compatibility for now, I think it would be better to add the\nfrom __future__ import print_function\n\nThis totally eliminates the possibility of (x,e) being treated as a tuple and works with both python2 and python3 just fine.\n\nFormat also has many advantages over % formatting.\n\nHowever, if you REALLY feel that % is the best choice here, I won't stand in the way.",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2019-11-27 04:41:19.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
