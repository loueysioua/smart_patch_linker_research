    {
      "id": "ab6eed2c_990e84a2",
      "file_path": "sources/hv-collector-core/src/test/kotlin/org/onap/dcae/collectors/veshv/impl/adapters/ConfigurationProviderTest.kt",
      "patchset_number": 6,
      "line": 57,
      "message": "This spec is for Spek 2.0 which is pretty much different framework. Using only `describe/context` and `it` in our tests actually breaks our build - you can try it yourself on this class :)\n\nI didn't investigate deeply into issue, however it's probably related to different executions made by various spek-dsl methods:\n\ndescribe/context/given -> group\non -> action\nit -> test \n\nI believe this was main reason why we did not move to Spek2.0",
      "author": {
        "account_id": 3701,
        "name": "Filip Krzywka",
        "display_name": null,
        "email": "filip.krzywka@nokia.com",
        "username": "fkrzywka"
      },
      "updated": "2019-03-11 08:42:42.000000000",
      "in_reply_to": "b1d8cabe_7830881a",
      "unresolved": false
    },
