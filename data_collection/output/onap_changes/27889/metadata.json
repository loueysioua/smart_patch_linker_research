      {
        "id": "453deb3e5a36f0361104a7b699e179476e803e21",
        "author": {
          "account_id": 299,
          "name": "Nate Potter",
          "display_name": null,
          "email": "Nathaniel.Potter@intel.com",
          "username": "ntpttr"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-01-12 00:31:06.000000000",
        "message": "Patch Set 1:\n\nHey Victor, I think this is a good change. Since we're now including the all-in-one inventory in-tree here and it's used to deploy OpenStack services, do you think we should also add to the \"enable\" section to the globals file and allow the user to choose which services to enable and disable, and mention this option in the docs? This could be done in a follow-up patch, I wouldn't mind adding that.",
        "patchset_number": 1
      },
      {
        "id": "b2436454474dc10791d2a867c30819817eac35bb",
        "author": {
          "account_id": 299,
          "name": "Nate Potter",
          "display_name": null,
          "email": "Nathaniel.Potter@intel.com",
          "username": "ntpttr"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-01-12 00:46:59.000000000",
        "message": "Patch Set 1:\n\nAlso FYI - without this patch, I was getting a failure on the openstack VM instantiation, with ansible saying NO VALID HOST WAS FOUND. After applying this patch that has been fixed.",
        "patchset_number": 1
      },
      {
        "id": "2d4b23d7bd14d9fc45232e5a4bfde0e414db83c0",
        "author": {
          "account_id": 947,
          "name": "Victor Morales",
          "display_name": null,
          "email": "chipahuac@hotmail.com",
          "username": "electrocucaracha"
        },
        "author_role": "OWNER",
        "timestamp": "2018-01-12 02:22:48.000000000",
        "message": "Patch Set 1:\n\n> Hey Victor, I think this is a good change. Since we're now\n > including the all-in-one inventory in-tree here and it's used to\n > deploy OpenStack services, do you think we should also add to the\n > \"enable\" section to the globals file and allow the user to choose\n > which services to enable and disable, and mention this option in\n > the docs? This could be done in a follow-up patch, I wouldn't mind\n > adding that.\n\nMy original idea was to keep the globals file simple and just appending the services that we want to enable, but the idea of mentioning what services have been tested and what could be useful for ONAP should be fine as long as we keep it simple",
        "patchset_number": 1
      },
