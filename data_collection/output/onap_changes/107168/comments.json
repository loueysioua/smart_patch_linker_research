    {
      "id": "b82162be_a36ce282",
      "file_path": "kubernetes/common/certInitializer/requirements.yaml",
      "patchset_number": 1,
      "line": 18,
      "message": "I dig a little bit around this and I know the reason. All charts in common use this construction to make their build process independent from what you have in helm repo.\n\nIf we use the @local then the order of charts in common repo starts being significant. We need to make sure that all charts that are being used by other charts are build before them.\n\nIf we use file:// then the order of build in common dir doesn't really matter as charts will be included directly from their directories instead of helm repo",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2020-05-06 18:48:42.000000000",
      "in_reply_to": "afb688b7_b2dbebe7",
      "unresolved": true
    },
