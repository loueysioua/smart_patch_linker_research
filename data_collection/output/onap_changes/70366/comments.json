    {
      "id": "bada0100_9e2c57ad",
      "file_path": "sparky/appconfig/application-sync.properties",
      "patchset_number": 1,
      "line": 6,
      "message": "Technically this file doesn't need to be provided, as it's already in the docker container.  It doesn't hurt anything by leaving it here, and it gives you control over which synchronizers run in the resources.\n\nWhen we configure gizmo vs resources, it's generally easy to omit the sync by not include the sync spring-profile when configuring for gizmo, instead of setting all these properties to false.\n\nThere is no harm in leaving it here, but just so you know, it's not really needed as we generally enable / disable sync as a whole.",
      "author": {
        "account_id": 1157,
        "name": "Dave Adams",
        "display_name": null,
        "email": "Dave.Adams@amdocs.com",
        "username": "da490c"
      },
      "updated": "2018-10-12 17:09:22.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
