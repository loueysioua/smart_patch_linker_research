          "email": "cameron.scholes@est.tech",
          "username": "eschcam"
        },
        "author_role": "REVIEWER",
        "timestamp": "2022-12-16 11:09:03.000000000",
        "message": "Patch Set 6:\n\n(10 comments)\n\nJust some suggestions",
        "patchset_number": 6
      },
      {
        "id": "cfcfac42b81e1e03bf384cea7fab066c7e5f7c2c",
