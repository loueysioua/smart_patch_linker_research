    {
      "id": "bba2ed2d_cd1f0a3d",
      "file_path": "base_sdc-python/Dockerfile",
      "patchset_number": 4,
      "line": 1,
      "message": "Well 7.0.0 means the latest one as of today.\nUsing \"latest\" means that you have no control when some stuff are changed.\nIt will imply more often change of base image than before but it will be in a \"controlled\" way",
