    {
      "id": "91866a8f_057563c4",
      "file_path": "etc/collector.properties",
      "patchset_number": 11,
      "line": 51,
      "message": "We have split stndDefined event routing into a few small user stories to have full control of implementation in VES.  Additionally it will be easier to review the code,\\.\n\n1. In the first US, which was merged, we added event schema and support event routing which depends only on domain parameter in the event.\n2. In the second US (this) we added event routing which depends on the domain and stndDefinedNamespace parameter.\n3. In the third US we implemented external schema validator which was added to dceagen2 sdk project. (already merged)\n4. In the fourth US we will add separate property (set default at false) to activate secondary schema validation and add external schema mapfile and schemas- to make sure that original ves validation won't be break.\n5. In the fifth US we will activate secondary schema validation and the same finish implementation of stndDefined event support.",
      "author": {
        "account_id": 3433,
        "name": "Bogumil Zebek",
        "display_name": null,
        "email": "bogumil.zebek@nokia.com",
        "username": "bogumil_zebek"
      },
      "updated": "2020-08-04 05:37:19.000000000",
      "in_reply_to": "c3716cb0_91aaf0d3",
      "unresolved": true
    },
    {
      "id": "b11dd199_fa2dd25a",
      "file_path": "etc/collector.properties",
