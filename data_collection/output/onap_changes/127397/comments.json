    },
    {
      "id": "c8c548ab_9e219bff",
      "file_path": "cps-service/src/main/java/org/onap/cps/notification/NotificationService.java",
      "patchset_number": 5,
      "line": 130,
      "message": "I think this is also a way to identify if the request came with '/' or containerNode(/bookstore). \nIt would be readable to use method inside the isRootXpath method. As per NotificaionService logic, it only wants to check if it is rootNode or not and the event will be for root node if the xpath is '/' or '' or '/parent' (containerNodeCheck) . \n\nName Suggestion: isRootContainerNodeXPath -> Container node can be confused with container at any level but here we are checking if it is root container node.",
      "author": {
        "account_id": 7680,
        "name": "Renu Kumari",
        "display_name": "Renu Kumari",
        "email": "kashi.renu@gmail.com",
        "username": "renukumari"
      },
      "updated": "2022-03-03 12:13:06.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
