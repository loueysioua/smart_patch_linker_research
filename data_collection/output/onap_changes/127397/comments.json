    {
      "id": "3a5bc2b9_c2cb5214",
      "file_path": "cps-service/src/main/java/org/onap/cps/notification/NotificationService.java",
      "patchset_number": 5,
      "line": 125,
      "message": "In which scenario do we expectect rootXpath to be '' ?",
      "author": {
        "account_id": 7680,
        "name": "Renu Kumari",
        "display_name": "Renu Kumari",
        "email": "kashi.renu@gmail.com",
        "username": "renukumari"
      },
      "updated": "2022-03-03 12:13:06.000000000",
