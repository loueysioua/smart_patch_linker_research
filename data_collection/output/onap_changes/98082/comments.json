    {
      "id": "38408226_6e287310",
      "file_path": "docs/specs/multicloud4k8s-hpa-discovery.rst",
      "patchset_number": 1,
      "line": 33,
      "message": "ESR call registration flow was the original plan. However we abandoned that, due to the fact that ESR appears to be end of life. ZTE is no longer providing resources to maintain it and so it will likely be deprecated. The covering plan is to create a CLI command that duplicates the register calls to Multicloud plugin. This will allow a cluster to register itself automatically to the K8s scheduler and then all that is needed is a call from ONAP (in this case CLI) to register the cluster to AAI as a cloud/tenant and set of flavors.",
      "author": {
        "account_id": 2363,
        "name": "Huang Haibin",
        "display_name": null,
        "email": "haibin.huang@intel.com",
        "username": "haibin"
      },
      "updated": "2019-11-12 01:55:44.000000000",
      "in_reply_to": "35e2cd7f_19b0f69e",
      "unresolved": true
