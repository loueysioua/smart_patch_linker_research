    {
      "id": "9adffdf1_7c28e432",
      "file_path": "datarouter-node/src/main/java/org/onap/dmaap/datarouter/node/DeliveryTask.java",
      "patchset_number": 6,
      "line": 115,
      "message": "It's actually not neccessary: part of the logging api's specifies that the header should always be called X-ONAP-RequestID. Any other Header names have been depreciated.\n\nyou can have a look here: \n\nhttps://wiki.onap.org/pages/viewpage.action?pageId=28378955#ONAPApplicationLoggingSpecificationv1.2(Casablanca)-MDC-RequestID\n\ntheres no need to make it a property since it should always be the same value.",
      "author": {
        "account_id": 4439,
        "name": "Emmett  Cox",
        "display_name": null,
        "email": "emmett.cox@ericsson.com",
        "username": "EmmettCox"
      },
      "updated": "2019-01-31 16:28:31.000000000",
      "in_reply_to": "9adffdf1_a885abcf",
      "unresolved": false
    },
    {
