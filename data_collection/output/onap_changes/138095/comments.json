    {
      "id": "7036c55a_a6c72cd6",
      "file_path": "k6-tests/ncmp/5-search-no-filter.js",
      "patchset_number": 2,
      "line": 29,
      "message": "Less VUs means less parallel requests, so there will be less CPU and memory usage, which makes it faster. Basically I think it takes so long right now because it is running out of memory.\n\nTesting on my laptop shows it is much faster e.g. going from 5 to 4 VUs shows search goes from 9 seconds to 5 seconds.\n\nLet's deploy it on the server and see.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
