    {
      "id": "094e4a13_bee085aa",
      "file_path": "kubernetes/so/charts/so-bpmn-infra/templates/deployment.yaml",
      "patchset_number": 14,
      "line": 126,
      "message": "This is related to AAF CADI authentication. AAF doesn't seem to have a DNS FQDN for CADI access. I have raised a Jira ticket https://jira.onap.org/browse/AAF-1022 to address it. These host aliases will associate a hostname to an IP Address. This is a short term workaround for AAF authentication  till AAF fixes the above jira ticket.",
