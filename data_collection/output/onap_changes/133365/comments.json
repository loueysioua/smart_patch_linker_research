    {
      "id": "28bd49e9_62474c6f",
      "file_path": "catalog-be/src/main/java/org/openecomp/sdc/be/components/validation/NodeFilterValidator.java",
      "patchset_number": 22,
      "line": 121,
      "message": "In the case of a in_range value with tosca functions, the filterConstraint.value appears to be a list with two entries, however, filterConstraint.valueType is a single value.\nWhere get_property is used for one value in the range, and get_attribute is used for the other value, then the single filterConstraint.valueType cannot be correct for both.\nThis can cause the wrong path to be taken in this switch (e.g. going into case GET_PROPERTY for a get_attribute value) resulting an error being thrown when mixing get_property and get_attribute values in an in_range value. The same happens for valid_values",
      "author": {
        "account_id": 5269,
        "name": "Michael Morris",
        "display_name": null,
        "email": "michael.morris@est.tech",
        "username": "MichaelMorris"
      },
      "updated": "2023-05-10 10:52:56.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "a88de825_4f7cb3de",
      "file_path": "catalog-be/src/main/java/org/openecomp/sdc/be/tosca/ToscaExportHandler.java",
      "patchset_number": 22,
      "line": 1765,
      "message": "this assumes the list contains tosca function values, when the list contains literal values (e.g. when setting in_range on a float to [12.34, 23.45]) then a class cast exception is thrown here",
      "author": {
        "account_id": 5269,
        "name": "Michael Morris",
