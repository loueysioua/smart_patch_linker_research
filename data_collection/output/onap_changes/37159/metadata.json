          "email": "liam.fallon@est.tech",
          "username": "liamfallon"
        },
        "author_role": "OWNER",
        "timestamp": "2018-03-21 21:45:55.000000000",
        "message": "Patch Set 2:\n\nThanks for the clarification.\n\nThis means therefore that this entire submission should be abandoned because SO only issues a single response. I guess therefore, the JIRA should also be closed.",
        "patchset_number": 2
      },
