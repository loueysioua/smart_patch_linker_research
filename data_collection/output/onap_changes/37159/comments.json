      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "5a93c517_3a222802",
      "file_path": "controlloop/common/model-impl/so/src/main/java/org/onap/policy/so/SOManager.java",
      "patchset_number": 1,
      "line": 214,
      "message": "I used the same check as this below on the async call.\n\nIn this logic, any HTTP status code sent in response will result in the timeout kicking in. Do we really want to wait on HTTP 4xx/5xx (or even 3xx) codes? I would have thought they should go straight to errors. All the other timeouts (AAI/VFC etc) seem to handle this the same.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2018-03-20 17:39:42.000000000",
