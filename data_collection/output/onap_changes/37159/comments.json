      "id": "5a93c517_daf0e493",
      "file_path": "controlloop/common/model-impl/so/src/main/java/org/onap/policy/so/SOManager.java",
      "patchset_number": 1,
      "line": 55,
      "message": "For me, this is a vary long timeout, especially as the loop waits for 20 attempts each with a 20 second timeout, that's over 6 minutes. I would have thought that a 1-2 second timeout would be enough on a REST call.",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
