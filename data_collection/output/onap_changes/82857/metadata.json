          "display_name": null,
          "email": "jorge.hernandez-herrero@att.com",
          "username": "jhh"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-03-21 12:38:09.000000000",
        "message": "Patch Set 1: -Code-Review",
        "patchset_number": 1
      },
      {
