      "id": "bf4e6adf_60d0c970",
      "file_path": "docker-compose/docker-compose.yml",
      "patchset_number": 5,
      "line": 101,
      "message": "These are not RFC compliant hostnames. Hostname can only have a-z, 0-9, and '-'.\n'#' is definitely not allowed, as it has different meaning in a url, e.g. hostname/page#section",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
