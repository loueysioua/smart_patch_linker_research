    {
      "id": "d82f43cf_09c6e95f",
      "file_path": "scripts/policy/docker-compose-all.yml",
      "patchset_number": 7,
      "line": 33,
      "message": "Do we really need this URI anymore? Given that they are associated with portal and we are not included in portal.",
      "author": {
