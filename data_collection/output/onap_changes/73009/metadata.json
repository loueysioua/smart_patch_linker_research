          "email": "jakub.dudycz@nokia.com",
          "username": "dudini1"
        },
        "author_role": "OWNER",
        "timestamp": "2018-11-21 11:15:29.000000000",
        "message": "Uploaded patch set 4.",
        "patchset_number": 4
