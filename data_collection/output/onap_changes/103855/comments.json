      "id": "46fafe61_b5c07b67",
      "file_path": "applications/common/src/main/java/org/onap/policy/pdp/xacml/application/common/matchable/MatchablePropertyTypeInteger.java",
      "patchset_number": 1,
      "line": 51,
      "message": "We have to toString() it anyway see line #62 - because of XACML/XML issues, so right now the Integer object seems better to use.",
      "author": {
        "account_id": 57,
        "name": "Pamela Dragosh",
        "display_name": null,
        "email": "pd1248@att.com",
