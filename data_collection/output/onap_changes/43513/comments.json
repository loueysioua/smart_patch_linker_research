      "file_path": "prh-app-server/src/main/java/org/onap/dcaegen2/services/prh/controllers/ScheduleController.java",
      "patchset_number": 2,
      "line": 71,
      "message": "It's risky to modify spring component (singleton) state on every request. Please review if it is still thread-safe.\n\nI know you expect \"start\" to be called once but it's an API. What if someone calls it few times by accident?",
      "author": {
        "account_id": 2683,
        "name": "Piotr Jaszczyk",
        "display_name": null,
        "email": "piotr.jaszczyk@nokia.com",
        "username": "jaszczur"
      },
      "updated": "2018-04-19 12:30:57.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
