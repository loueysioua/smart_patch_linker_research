      "file_path": "prh-app-server/src/main/java/org/onap/dcaegen2/services/prh/tasks/BbsActionsTask.java",
      "patchset_number": 6,
      "line": 129,
      "message": "Extract all PNF endpoints as field constants. This type of information should not be in-lined as it's actually a physical representation of the external component's address.\nPreferably this should be taken from a property/config file.",
