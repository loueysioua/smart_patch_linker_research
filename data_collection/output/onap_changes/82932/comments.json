    {
      "id": "8681b020_5e984857",
      "file_path": "prh-app-server/src/main/java/org/onap/dcaegen2/services/prh/tasks/BbsActionsTask.java",
      "patchset_number": 6,
      "line": 134,
      "message": "buildUri method name too generic, what type of URI ? This is specific to logical-link and should be stated",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
