    },
    {
      "id": "896da2b6_0d34d15b",
      "file_path": "prh-app-server/src/main/java/org/onap/dcaegen2/services/prh/tasks/BbsActionsTask.java",
      "patchset_number": 6,
      "line": 140,
      "message": "Please consider switching from this custom implementation of URI to what is provided by JDK. This is reinventing the wheel, there is no benefit in having and maintaining a crippled implementation of URI class which does not even verify if the URI is valid. \nAs for the URIBuilder - I understand the intent, but there is a lot of room for improvement - what's  the point of having a builder that still requires raw string concatenation ?",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2019-03-26 09:36:51.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
