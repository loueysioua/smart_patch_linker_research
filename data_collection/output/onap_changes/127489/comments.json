    {
      "id": "55f01062_7d347804",
      "file_path": "cps-rest/src/main/java/org/onap/cps/rest/controller/CpsRestInputMapper.java",
      "patchset_number": 3,
      "line": 34,
      "message": "By default I would recommend not to add extra logic in the mapper to handle nulls. It brings some intelligence in the mapper that it might not have as a null and a default instantiated type does not means the same thing.\n\nFor example, a null Anchor is going to be mapped into an AnchorDetails with empty name, dataspace and shcema set, which are not the same.\n\nUnless when explicitly needed, I think the mapper should remains dumb, with minimum responsibility, and handling null on the mapper result should be the mapper client's responsibility.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2022-03-08 11:30:10.000000000",
      "in_reply_to": null,
      "unresolved": true
