    },
    {
      "id": "e27a275b_697f849b",
      "file_path": "cps-service/src/main/java/org/onap/cps/utils/YangParserHelper.java",
      "patchset_number": 4,
      "line": 123,
      "message": "when catching all the exceptions I got the following error while building the code \"Low: Exception is caught when Exception is not thrown\". What I found is that it could result in a wrong exception being thrown and can hide the actual problem. So only select run time exceptions need to be thrown.\nThis is one of the threads I found about this https://stackoverflow.com/questions/33729523/exception-is-caught-when-exception-is-not-thrown",
      "author": {
        "account_id": 7846,
        "name": "Arpit Singh",
        "display_name": "Arpit",
        "email": "as00745003@techmahindra.com",
        "username": "arpitsingh"
      },
      "updated": "2024-07-22 15:15:12.000000000",
      "in_reply_to": "bfb2f12d_33f0fa9e",
      "unresolved": false
    },
