    {
      "id": "9891bffa_1833b05f",
      "file_path": "main/src/main/java/org/onap/policy/pdpx/main/rest/XacmlPdpRestServer.java",
      "patchset_number": 6,
      "line": 100,
      "message": "I should have mentioned this before: in this case, you should leave this property out, as thehe default is to use the jackson provider.  JacksonHandler, however, is a *GSON* provider that provides limited jackson behavior - I believe xacml is still dependent on the real jackson provider.\n\nthe alternative would be to specify \"com.fasterxml.jackson.jaxrs.json.JacksonJaxbJsonProvider\".",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
