      "file_path": "cps-service/src/test/groovy/org/onap/cps/notification/NotificationErrorHandlerSpec.groovy",
      "patchset_number": 4,
      "line": 26,
      "message": "Modify it as below :\n\n@SpringBean\nNotificationErrorHandler objectUnderTest=Spy(NotificationErrorHandler)",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
