    {
      "id": "275e8b8a_93b36e0b",
      "file_path": "cps-service/src/test/groovy/org/onap/cps/notification/NotificationErrorHandlerSpec.groovy",
      "patchset_number": 4,
      "line": 31,
      "message": "Avoid stream :\n\ndef mockLogWatcher = Spy(ListAppender<ILoggingEvent>)\n\n    @BeforeEach\n    void setup() {\n        ((Logger) LoggerFactory.getLogger(NotificationErrorHandler.class)).addAppender(mockLogWatcher);\n    }\n\n    @AfterEach\n    void teardown() {\n        ((Logger) LoggerFactory.getLogger(NotificationErrorHandler.class)).detachAndStopAllAppenders();\n    }\n\n    def 'Logging exception via notification error handler'() {\n        given: 'create and start a ListAppender'\n            mockLogWatcher.start();\n        when: 'some exception occurs'\n            objectUnderTest.onException(new Exception('sample exception'), 'some context')\n        then: 'log output results contains the correct error details'\n            List<ILoggingEvent> logsList = mockLogWatcher.list;\n            logsList.get(0).getLevel() == Level.ERROR;\n            logsList.get(0).getFormattedMessage()\n                    .contains(\"Failed to process \\n\" +\n                    \" Error cause: sample exception \\n\" +\n                    \" Error context: [some context]\")\n    }",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
      "updated": "2022-07-05 15:59:13.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
