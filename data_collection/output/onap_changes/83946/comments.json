    {
      "id": "7898af2d_1143c7bb",
      "file_path": "datafile-app-server/src/main/java/org/onap/dcaegen2/collectors/datafile/controllers/ScheduleController.java",
      "patchset_number": 3,
      "line": 61,
      "message": "In my understanding, ENTRY marker will be put when starting tasks, and EXIT marker when stopping them. You should not have ENTRY/EXIT markers for both start and stop. I think you should double-check the documentation.",
      "author": {
        "account_id": 5051,
        "name": "Muhammad Rehan Raza",
        "display_name": null,
        "email": "muhammad.rehan.raza@est.tech",
        "username": "RehanRaza"
      },
      "updated": "2019-04-04 13:43:18.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "27ca3868_3c28b3df",
      "file_path": "datafile-app-server/src/main/java/org/onap/dcaegen2/collectors/datafile/controllers/ScheduleController.java",
      "patchset_number": 3,
      "line": 73,
      "message": "I don't understand what is the point of initialising MDC when stopping all the tasks. I think you should initialise MDC when receiving the start request, save it, and then stop it with the same MDC that was set at the time of receiving start request.",
      "author": {
        "account_id": 5051,
        "name": "Muhammad Rehan Raza",
        "display_name": null,
        "email": "muhammad.rehan.raza@est.tech",
        "username": "RehanRaza"
      },
      "updated": "2019-04-04 13:43:18.000000000",
      "in_reply_to": null,
      "unresolved": false
