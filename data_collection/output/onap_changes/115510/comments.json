      "file_path": "models-provider/src/main/java/org/onap/policy/models/provider/PolicyModelsProviderFactory.java",
      "patchset_number": 1,
      "line": 38,
      "message": "Is it a concern that we can't differentiate between a permanently incorrect URL and a temporarily unavailable DB? Both show as \"Can't connect\" exceptions",
