    {
      "id": "7f6ddfb2_a3b87cf9",
      "file_path": "models-provider/src/main/java/org/onap/policy/models/provider/PolicyModelsProviderFactory.java",
      "patchset_number": 2,
      "line": 116,
      "message": "Playing devil's advocate here, I am questioning why this work is needed.   In OOM deployments, API and other components won't be started until Database is up and provisioned.\n\nIt makes me a little nervous to have an infinite loop here.    I think this may not accomplish the desire intention for some components that may be invoking this function from the initialization thread, that are not yet fully initialized.   In such case, OOM liveness checks may take down the pod anyways.\n\nSafety checks could also be alternatively in .sh entry point rather that in java code but again I am questioning why this is needed in the first place.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2020-12-01 18:32:03.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
