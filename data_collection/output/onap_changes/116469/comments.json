      "id": "14081e22_682d71b2",
      "file_path": "test/legal/docker_license_analysis/README.rst",
      "patchset_number": 4,
      "line": 79,
      "message": "True. How about adding dummy \"Dockerfile.sample\":\n\n FROM scratch\n COPY . /opt/legal\n\nand patching Vagrant file to use it unless ENV is set:\n\n diff --git a/test/legal/docker_license_analysis/Vagrantfile b/test/legal/docker_license_analysis/Vagrantfile\n index e6d47bad..c27e1a96 100644\n --- a/test/legal/docker_license_analysis/Vagrantfile\n +++ b/test/legal/docker_license_analysis/Vagrantfile\n @@ -7,6 +7,8 @@ VM_DISK = 128\n  VM_STORAGE_POOL = \"default\"\n  VM_USER = \"vagrant\"\n  \n +DOCKER_IMAGE = ENV[\"DOCKER_FILE_ANALYSE\"] || \"Dockerfile.sample\"\n +\n  $install_docker= <<-SCRIPT\n    apt-get update\n    apt-get install --yes \\\n @@ -88,11 +90,11 @@ Vagrant.configure(\"2\") do |config|\n    end\n  \n    # Add the Dockerfile for analysis to the Vagrant box\n -  config.vm.provision \"file\", source: ENV['DOCKER_FILE_ANALYSE'], destination: \"/home/vagrant/ternvenv/Dockerfile\"\n +  config.vm.provision \"file\", source: DOCKER_IMAGE, destination: \"/home/vagrant/ternvenv/Dockerfile\"\n  \n    config.vm.provision \"license_analysis\", type: \"shell\" do |s|\n      s.privileged = false\n -    s.env = {\"IMAGE\":ENV['DOCKER_IMAGE_ANALYSE']}\n +    s.env = {\"IMAGE\":DOCKER_IMAGE}\n      s.path = \"tools/analysis.sh\"\n    end\n  end\n\nLet me know what you think",
      "author": {
        "account_id": 5047,
        "name": "Pawe? Wieczorek",
        "display_name": "Pawel Wieczorek",
        "email": "pawel-wieczorek@outlook.com",
        "username": "pwieczorek"
