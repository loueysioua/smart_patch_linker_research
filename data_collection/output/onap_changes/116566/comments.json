      "id": "cf795f4d_46ca472a",
      "file_path": "models-pap/src/main/java/org/onap/policy/models/pap/concepts/PapPolicyIdentifier.java",
      "patchset_number": 2,
      "line": null,
      "message": "This class is used to serialize and deserialize IDs in the \"policy-id\" \"policy-version\" format used on PAP-PDP communication. I has no getters or setters so GSON serialization and deserialization is used for instantiation. The getGenericIdentifier() method converts an instance of the class  into a regular ToscaConceptIdentifierOptVersion instance",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
