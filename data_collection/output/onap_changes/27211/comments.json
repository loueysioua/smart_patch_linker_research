    {
      "id": "5a93c517_32122cb2",
      "file_path": "openecomp-be/lib/openecomp-sdc-enrichment-lib/openecomp-sdc-enrichment-impl/src/main/java/org/openecomp/sdc/enrichment/impl/external/artifact/MonitoringMibEnricher.java",
      "patchset_number": 1,
      "line": 242,
      "message": "A bit dangerous to update a variable outside a loop if not some runs of the loop skip the update. You're using \"continue\" here, so in some cases this variable will hold the result of a previous iteration. I'd use getArtifactPath() inline or reduce the scope of \"path\".",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
        "username": "vempo"
      },
      "updated": "2018-01-02 10:12:20.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "5a93c517_120db090",
      "file_path": "openecomp-be/lib/openecomp-sdc-enrichment-lib/openecomp-sdc-enrichment-impl/src/main/java/org/openecomp/sdc/enrichment/impl/external/artifact/MonitoringMibEnricher.java",
      "patchset_number": 1,
      "line": 248,
      "message": "It doesn't make much sense to return Optional in a private method. \nMoreover, here it can never be anything other than ComponentMonitoringUploadInfo componentMonitoringUploadInfo = new ComponentMonitoringUploadInfo(); Which also makes the .ifPresent() in line 215 redundant.",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
