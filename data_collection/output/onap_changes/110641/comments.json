    {
      "id": "296f635b_90c4d07c",
      "file_path": "src/dcm/pkg/module/apply.go",
      "patchset_number": 15,
      "line": 61,
      "message": "I made it like this to be consistent with the approval k8s subresource itself. But we could make it more like an interface with rsync. For example: i.e. let rsync create the time but also the message and reason, based on parameters passed by DCM.\n\nDCM could provide parameters like:\n- justification\n- request time\n- others\n\nWith rsync using them (or not) while creating the actual approval subresource.\n\nI don't have a strong opinion about either way.",
      "author": {
        "account_id": 693,
        "name": "Igor Duarte Cardoso",
        "display_name": null,
        "email": "igordcard@gmail.com",
        "username": "igordcard"
      },
      "updated": "2020-09-14 23:19:37.000000000",
      "in_reply_to": "a801a9f4_5d925e64",
      "unresolved": true
    },
    {
