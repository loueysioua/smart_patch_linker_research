    {
      "id": "f4685f69_b64b8b80",
      "file_path": "cps-ri/src/main/java/org/onap/cps/spi/repository/FragmentRepository.java",
      "patchset_number": 4,
      "line": 134,
      "message": "Due to JPA inserting each Collection element as a query parameter, this limits collection size to 65,533:\n- JDBC Postgres driver has a limit of 65,535 parameters per query\n- 1 used for anchorId\n- 1 used for maxDepth\n- leaving 65,533 for xpaths\nThere is a workaround that completely removes this limit, but I will address it in a future patch.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2023-03-08 19:50:56.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
