    {
      "id": "cf88a733_21f7dd21",
      "file_path": "services/services-engine/src/main/java/org/onap/policy/apex/service/engine/main/ApexMain.java",
      "patchset_number": 4,
      "line": 93,
      "message": "ApexMain is the class that is instantiated for each ToscaPolicy. If one of the policies' deployment failed(or even if all policy deployments failed), then APEX-PDP will just return corresponding information to PAP, but the application will keep running.\nApexMain is the main class for running apex in standalone mode, but the APEX-PDP application main class that runs as part of ONAP is a different one, and that throws all the right exceptions to exit with non zero code in case of a fatal error.",
      "author": {
        "account_id": 4903,
        "name": "Ajith Sreekumar",
        "display_name": "Ajith Sreekumar",
        "email": "ajith.sreekumar@bell.ca",
        "username": "a.sreekumar"
      },
      "updated": "2021-02-10 17:07:58.000000000",
      "in_reply_to": "9acc2897_63a6feeb",
      "unresolved": true
    },
