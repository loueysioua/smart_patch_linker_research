    },
    {
      "id": "1a76adc5_c601e7b0",
      "file_path": "vid-app-common/src/test/java/org/onap/vid/controllers/HealthCheckControllerTest.java",
      "patchset_number": 9,
      "line": 40,
      "message": "Method name - ok/nokCaseSetUp is too vague. From a code reader's perspective there still a neeed to look inside the method to understand what is going - an additional jump. Please rename these methods to something more descriptive i.e:\ngivenProfileCountIs(666) or givenProfileCountThrows(ex)\nAlso reorder these methods, they should be placed after their last usage. Definitely private methods should not be defined at the beginning of a class :)",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2018-09-25 18:07:33.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "1a76adc5_c6b7a739",
      "file_path": "vid-app-common/src/test/java/org/onap/vid/dao/FnAppDoaImplTest.java",
      "patchset_number": 9,
      "line": 64,
      "message": "I would rename this to simply: shouldRethrowSQLException",
