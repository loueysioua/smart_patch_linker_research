      "patchset_number": 9,
      "line": 10,
      "message": "This class is just a generic connection factory, it has no information about the FnApp or any other DB specificinformation. I'd suggest renaming this to a ConnectionFactory.",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2018-09-25 18:07:33.000000000",
