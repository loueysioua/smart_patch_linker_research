    },
    {
      "id": "1a76adc5_4585ccab",
      "file_path": "vid-app-common/src/test/java/org/onap/vid/controllers/HealthCheckControllerTest.java",
      "patchset_number": 9,
      "line": 40,
      "message": "One thing about name. I think old code was supposed to check connection with database so there is no need not tell anything about what we querying.",
      "author": {
        "account_id": 2731,
        "name": "KK",
        "display_name": null,
        "email": "krzysztof.kurczewski@nokia.com",
        "username": "kurczews"
      },
      "updated": "2018-09-26 06:34:47.000000000",
      "in_reply_to": "1a76adc5_c601e7b0",
      "unresolved": false
    },
    {
      "id": "1a76adc5_687bfd7b",
      "file_path": "vid-app-common/src/test/java/org/onap/vid/controllers/HealthCheckControllerTest.java",
      "patchset_number": 9,
      "line": 40,
      "message": "Yes we do not have to know nor expose anything that has to do with the DB and the query inside - from these tests perspective we don't care about what is going on inside the Dao. But we do care about the api and what value it returns, because it affects the code. I pointed out only the vague name that prepares a test condition. You and I know what ok and nok means. Someone who sees this for the first time has to dive inside the methods to see what it actually means and in this case the mockito implementation is just more descriptive:) I am obviously nitpicking in such simple code, but this approach becomes a problem in more sophisticated code.",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2018-09-26 07:01:50.000000000",
