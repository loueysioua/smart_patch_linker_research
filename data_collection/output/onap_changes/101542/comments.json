    {
      "id": "21898b69_b4219e82",
      "file_path": "certService/helm/aaf-cert-service/templates/deployment.yaml",
      "patchset_number": 1,
      "line": 20,
      "message": "From mariadb-galera helm chart:\nValues:\nresources:\n  small:\n    limits:\n      cpu: 2\n      memory: 4Gi\n    requests:\n      cpu: 1\n      memory: 2Gi\n  large:\n    limits:\n      cpu: 2\n      memory: 4Gi\n    requests:\n      cpu: 1\n      memory: 2Gi\n  unlimited: {}\n\n\nUsage in helm chart:\n          resources:\n{{ include \"common.resources\" . | indent 12 }}\n\nWe don't need to provide profiles like in mariadb-galera, so we can use:\nValues:\nresources:\n  limits:\n    cpu: X\n    memory: YGi\n  requests:\n    cpu: Z\n    memory: AGi\n\nand usage in helm chart:\n          resources:\n{{ toYaml .Values.resources | indent ?? }}",
      "author": {
        "account_id": 5775,
        "name": "Pawel Baniewski",
        "display_name": "Pawel Baniewski",
        "email": "pawel.baniewski@nokia.com",
        "username": "baniewsk"
      },
      "updated": "2020-02-12 13:01:52.000000000",
      "in_reply_to": "ec0e8de5_5c42b847",
      "unresolved": true
