    {
      "id": "5fea96c7_2b28d2ae",
      "file_path": "cps-application/pom.xml",
      "patchset_number": 1,
      "line": 18,
      "message": "I was trying to keep to the scope of the task which was mainly editing the Nordix licenses and in this case I edited Nordix's contribution to a Pantheon License. As such I decided not to add the License Identifier at the end.",
      "author": {
        "account_id": 7830,
        "name": "Luke Gleeson",
        "display_name": null,
        "email": "luke.gleeson@est.tech",
        "username": "lukegleeson"
      },
      "updated": "2021-07-09 09:24:02.000000000",
      "in_reply_to": "06805ba8_e3dd545f",
      "unresolved": true
    },
    {
      "id": "f21e11ce_a4f55914",
      "file_path": "cps-rest/src/test/groovy/org/onap/cps/rest/controller/AdminRestControllerSpec.groovy",
      "patchset_number": 1,
      "line": 3,
      "message": "I was following the following guidelines for licensing formatting: https://wiki.nordix.org/display/DEV/Copyright+and+Licences+for+ONAP\n\n\"In the example files, the copyright line is specified as follows:\nCopyright (C) 20XX-20YY Nordix Foundation.\nWhere XX is the year of the creation of the file and YY  is the year of the last modification of the file. Modify the XX and YY  dates as appropriate.\"",
      "author": {
        "account_id": 7830,
        "name": "Luke Gleeson",
        "display_name": null,
        "email": "luke.gleeson@est.tech",
        "username": "lukegleeson"
      },
      "updated": "2021-07-09 09:28:23.000000000",
      "in_reply_to": "5605ad22_e4658dc5",
      "unresolved": true
    },
