          "username": "os0695"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-06-17 10:29:30.000000000",
        "message": "Patch Set 1: Code-Review+1\n\nCompanies changing existing files can (and should) add \"modifications\" line in copyrights.\nUpgrading Jetty is due to known vulnerabilities in previous version.",
        "patchset_number": 1
      },
      {
        "id": "9a903003c69268c83517426c3d1c20890a402221",
        "author": {
          "account_id": 3717,
