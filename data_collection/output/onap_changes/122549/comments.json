      "id": "d0405ed5_71182391",
      "file_path": "models-pap/src/main/java/org/onap/policy/models/pap/persistence/provider/PolicyAuditProvider.java",
      "patchset_number": 1,
      "line": 86,
      "message": "The difference from the getAll and getFiltered is not the max records in this case.\n\nfrom my view, setting the check for max records on getFiltered won't affect the reason the \"if filter is empty\" exists.\n\nmy decision on adding the check was just to avoid all the objects checks and creation related to building up the where clause on getFiltered - we don't have a filter so why not use the getAll",
      "author": {
        "account_id": 7625,
        "name": "Adheli Tavares",
        "display_name": "Eli Tavares",
        "email": "adheli.tavares@est.tech",
        "username": "adheli.tavares"
      },
      "updated": "2021-07-12 13:53:26.000000000",
      "in_reply_to": "a45a9c8c_9cd9927e",
      "unresolved": true
    },
    {
