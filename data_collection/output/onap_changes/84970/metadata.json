      },
      {
        "id": "6d52e0c7266c6c35ec5b46c83c062111123789b5",
        "author": {
          "account_id": 57,
          "name": "Pamela Dragosh",
          "display_name": null,
          "email": "pd1248@att.com",
          "username": "pdragosh"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-04-11 11:43:28.000000000",
        "message": "Patch Set 3:\n\nThe scenario came up with XACML PDp and guard policies. Some of the values are Integer, but GSON was converting them to doubles. This broke the XACML because we are expecting integer. It will break the DCAE Monitoring policies or any policy that has properties that are expected to be Integer vs Double.",
        "patchset_number": 3
      },
