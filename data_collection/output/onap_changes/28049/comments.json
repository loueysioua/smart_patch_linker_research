    {
      "id": "5a93c517_4db845c8",
      "file_path": "adapters/mso-adapters-rest-interface/src/main/java/org/openecomp/mso/adapters/nwrest/NetworkRequestCommon.java",
      "patchset_number": 4,
      "line": 38,
      "message": "Yes, your suggestion is one of the ways, and definitely shorter. However, let us leave it as it is done. Although there is more changes, it does not mean it is the worse way.",
