    {
      "id": "5a93c517_cd0d3540",
      "file_path": "adapters/mso-adapters-rest-interface/src/main/java/org/openecomp/mso/adapters/nwrest/NetworkRequestCommon.java",
      "patchset_number": 4,
      "line": 38,
      "message": "Besides I think that the change you suggest would introduce more chaos (more abstract class). My change is related to lots of file, but the inheritance is more clear, also the new created abstract classes have more clear names.",
      "author": {
        "account_id": 2789,
        "name": "Lukasz Muszkieta",
        "display_name": null,
        "email": "lukasz.muszkieta@nokia.com",
