    {
      "id": "2eb6b910_bb43ca2a",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/rest/PolicyComponentsHealthCheckProvider.java",
      "patchset_number": 2,
      "line": 99,
      "message": "Hi Jorge,\n(1) it calls policy-api and policy-distribution for their health report.\n(2) Using parallel stream to call two components in parallel to reduce response time.\n(3) After two components return response, the reports will be put in a shared Map.\n(4) forEach need a function with one argument. fetchPolicyComponentHealthStatus has actually two arguments, one is *this*, one is httpClient. \"this::fetchPolicyComponentHealthStatus\" is the way to bind *this* as the first argument to fetchPolicyComponentHealthStatus.",
      "author": {
        "account_id": 6351,
        "name": "Huaxing Jin",
        "display_name": null,
        "email": "huaxing.jin@est.tech",
        "username": "huaxing"
      },
      "updated": "2020-02-26 06:06:09.000000000",
      "in_reply_to": "8ac88bd7_53547e5e",
      "unresolved": false
    },
