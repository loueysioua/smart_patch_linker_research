    {
      "id": "41f2356f_99d00967",
      "file_path": "main/src/main/java/org/onap/policy/pap/main/rest/PolicyComponentsHealthCheckProvider.java",
      "patchset_number": 2,
      "line": 98,
      "message": "knowing a little more about java's asynchronous threads, this parallelStream() call needs to be done a different way, because it will block the ForkJoinPool while it performs the REST calls - should never do blocking I/O in a parallelStream()\n\nnow that I think about it, this should only invoke getHttpClients() once and then cache the result, reusing it on each call to fetch().",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2020-02-25 13:43:53.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
