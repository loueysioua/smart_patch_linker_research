      "file_path": "policy-management/src/main/java/org/onap/policy/drools/controller/DroolsControllerBuilderApi.java",
      "patchset_number": 3,
      "line": 5,
      "message": "Copyright (C) 2020",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2020-07-17 20:56:52.000000000",
