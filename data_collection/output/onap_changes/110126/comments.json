      "patchset_number": 2,
      "line": 144,
      "message": "Just to make it more clear what I tried to explain below, this method skipped, and may want to reuse for DMN controllers, (that they also use kie-ci maven coordinates for artifacts so).. so that would be one reason to delay instantiation till the \"new\".",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2020-07-16 21:58:40.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
