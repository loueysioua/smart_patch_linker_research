    {
      "id": "5a4e6583_aea93b26",
      "file_path": "openecomp-be/lib/openecomp-sdc-validation-lib/openecomp-sdc-validation-api/src/main/java/org/openecomp/core/validation/errors/ErrorMessagesFormatBuilder.java",
      "patchset_number": 2,
      "line": 26,
      "message": "Do you think it would make sense to add a separate API with an error code here? It looks like the case \"[CODE]: Message\" is a common one. Having an method for that could enforce a unified approach and be easier to maintain. Imagine requiring \"<CODE> - Message\" instead of the format above. You will have to find all places where it is used and fix them. On the other hand, changing a code itself is unlikely and would require very pinpointed fix.\n\nExample: getErrorWithParameters(ErrorCode code, String format, String... params) {\n   return \"[\" + code \"]:\" + getErrorWithParameters(error, params);\n}\n\nThis would allow you to leave Messages.java unchanged and backward compatible.\n\nErrorCode is a simple immutable class to distinguish it from String and communicate its purpose.\n\nExample: private static final ErrorCode NS1 = new ErrorCode(\"NS1\");",
      "author": {
        "account_id": 329,
        "name": "Vitaly Emporopulo",
        "display_name": null,
        "email": "Vitaliy.Emporopulo@amdocs.com",
        "username": "vempo"
      },
      "updated": "2017-11-02 16:48:14.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
