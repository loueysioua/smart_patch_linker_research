    {
      "id": "39055163_e6e28b26",
      "file_path": "openecomp-ui/src/sdc-app/onboarding/softwareProduct/validationResults/SoftwareProductValidationResultsView.jsx",
      "patchset_number": 1,
      "line": 205,
      "message": "The logic is already added under a method to construct the accordion. The page view is different based on whether the results are in root node or child node of the accordion. This is to handle inconsistent API response from VTP backend. We discussed with Ofir about the possible complexity in code due to the backend api specs and this was agreed to be fixed in later releases when the VTP backend is standardized. Since this logic is going to be changed after API standardization, can we leave it as-is in this release - as discussed with Ofir, and refactor in subsequent releases?",
      "author": {
        "account_id": 5282,
        "name": "Vodafone Group",
        "display_name": null,
        "email": "onap@vodafone.com",
        "username": "Vodafone"
      },
