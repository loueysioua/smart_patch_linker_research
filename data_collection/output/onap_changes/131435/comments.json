    {
      "id": "0c7f2aa7_a9673222",
      "file_path": "docs/sections/services/slice-analysis-ms/slice_analysis_ms_overview.rst",
      "patchset_number": 2,
      "line": 13,
      "message": "Minor grammar changes:\n\nUnlike the SON-Handler MS, which passes runtime configuration through Policy - Policy Handler - Cloudify Manager - Consul Cluster - CBS - SONHandler, the Slice Analysis MS provides a lighter and easier way to send runtime configurations in seconds.",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2022-10-21 17:52:33.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "5707edd1_a0b42b62",
      "file_path": "docs/sections/services/slice-analysis-ms/slice_analysis_ms_overview.rst",
      "patchset_number": 2,
      "line": 15,
      "message": "Minor grammar changes:\n\nFor the Slice Analysis MS, there is a CBS thread running that will continually fetch the latest policies from the XCAML PDP engine. So if you want to pass runtime configuration, you can format your configuration contents in the form of an XCAML policy, then push it into the XCAML PDP engine. The Slice Analysis MS will get updated within seconds.",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2022-10-21 17:52:33.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
