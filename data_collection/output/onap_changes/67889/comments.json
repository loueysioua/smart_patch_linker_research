    {
      "id": "1a76adc5_6247911e",
      "file_path": "kubernetes/common/music/values.yaml",
      "patchset_number": 3,
      "line": 48,
      "message": "As of Casablanca all charts require resource limits. This ensures proper scheduling of pods within a k8s cluster.\n\nExample deployment.yaml change:\n        resources:\n{{ include \"common.resources\" . | indent 12 }}\n\nExample values.yaml change:\n\nresources:\n  small:\n    limits:\n      cpu: 2\n      memory: 4Gi\n    requests:\n      cpu: 1\n      memory: 2Gi\n  large:\n    limits:\n      cpu: 4\n      memory: 8Gi\n    requests:\n      cpu: 4\n      memory: 8Gi\n  unlimited: {}",
      "author": {
        "account_id": 127,
        "name": "Mike Elliott",
        "display_name": null,
        "email": "mike.elliott@amdocs.com",
        "username": "melliott"
      },
      "updated": "2018-09-27 19:50:06.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
