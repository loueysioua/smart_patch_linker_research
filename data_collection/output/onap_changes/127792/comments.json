    {
      "id": "456eeb82_09794243",
      "file_path": "checkstyle/pom.xml",
      "patchset_number": 2,
      "line": 40,
      "message": "In windows the executable name defaults to python, regardless of version.\n\nWhereas Linux, the python default means python2, whereas python 3 is python3\n\nhttps://stackoverflow.com/questions/40914108/bash-python3-command-not-found-windows-discord-py",
      "author": {
        "account_id": 7744,
        "name": "Dylan Byrne",
        "display_name": null,
        "email": "dylan.byrne@est.tech",
        "username": "DylanB95EST"
      },
      "updated": "2022-03-25 12:59:38.000000000",
      "in_reply_to": "672a14aa_72179ee5",
      "unresolved": true
    },
    {
      "id": "14c91ed3_c277b31f",
      "file_path": "checkstyle/pom.xml",
      "patchset_number": 2,
      "line": 40,
      "message": "I did a little test there and it seems like we can have both as Python3. Will set as Python3 for now and if people have issues running can fix later",
