        "account_id": 7744,
        "name": "Dylan Byrne",
        "display_name": null,
        "email": "dylan.byrne@est.tech",
        "username": "DylanB95EST"
      },
      "updated": "2022-03-25 15:35:40.000000000",
      "in_reply_to": "14c91ed3_c277b31f",
      "unresolved": true
    },
    {
      "id": "ecf6066c_91a6093e",
      "file_path": "checkstyle/pom.xml",
      "patchset_number": 2,
      "line": 40,
      "message": "What we reckon is that python always installs on windows using python as a path pointer to the python exec but only sometimes does the same with python3. So safer to have it the way it was before as has little extra overhead. What do people think?",
      "author": {
        "account_id": 7830,
        "name": "Luke Gleeson",
        "display_name": null,
        "email": "luke.gleeson@est.tech",
        "username": "lukegleeson"
      },
