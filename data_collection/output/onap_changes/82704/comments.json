      "id": "4adf6b00_2baf33fc",
      "file_path": "ice_validator/tests/conftest.py",
      "patchset_number": 3,
      "line": 1045,
      "message": "This isn't quite right.  If you're trying to determine if a requirement is testable, then the keyword should be MUST or MUST NOT, and the validation mode should != none.  That will be consistent with how it's determined in the traceability report generation.\n\n            keyword = metadata[\"keyword\"].upper()\n            mode = metadata[\"validation_mode\"].lower()\n            testable = keyword in {\"MUST\", \"MUST NOT\"} and mode != \"none\"",
      "author": {
        "account_id": 3999,
        "name": "Trevor Lovett",
        "display_name": null,
        "email": "trevor.lovett@att.com",
        "username": "tl2972"
      },
      "updated": "2019-03-19 18:47:25.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
