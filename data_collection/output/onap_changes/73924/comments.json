    {
      "id": "9adffdf1_c09f234f",
      "file_path": "pom.xml",
      "patchset_number": 5,
      "line": 579,
      "message": "Why test? This will probably ruin logging in every \"main\" module.\n\nQuick intro to slf4j: every module should have dependency to slf4j-api. Only \"main\" modules should have runtime dependency to one of the implementations of this api, eg logback. In order for logging in unit tests to work they also need a test-scoped dependency to logback. If any external library uses slf4j-api then we are fine - it will work out of the box. Every other case should be analyzed separately. Eg. misbehaving deps with logback-classic dependency should have it excluded; for libs using log4j (another logging framework) an adapter should be in the classpath which will expose log4j api and direct it through slf4j api to logback in main module.",
      "author": {
        "account_id": 2683,
        "name": "Piotr Jaszczyk",
        "display_name": null,
        "email": "piotr.jaszczyk@nokia.com",
        "username": "jaszczur"
      },
      "updated": "2018-11-30 14:20:39.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
