    },
    {
      "id": "cdc721b5_062f9574",
      "file_path": "kubernetes/dcaegen2/resources/external/map/schema-map.json",
      "patchset_number": 8,
      "line": null,
      "message": "It is meta-data used for lookup to validate VES Events (which will container the publicURL)",
      "author": {
        "account_id": 93,
        "name": "Vijay Venkatesh Kumar",
        "display_name": null,
        "email": "vijayv81@gmail.com",
        "username": "vv770d"
      },
      "updated": "2021-02-16 21:10:00.000000000",
      "in_reply_to": "7804fbb9_26aeb893",
      "unresolved": true
    },
    {
      "id": "ae41bbc5_93ca6927",
      "file_path": "kubernetes/dcaegen2/resources/external/map/schema-map.json",
      "patchset_number": 8,
      "line": null,
      "message": "Does that mean that no-one will try to actually *connect* to those publicURLs at any time from ONAP side?",
      "author": {
        "account_id": 3949,
        "name": "Lasse Kaihlavirta",
        "display_name": null,
        "email": "l.kaihlavirt@partner.samsung.com",
        "username": "kaihlavi"
      },
      "updated": "2021-02-17 09:17:58.000000000",
      "in_reply_to": "cdc721b5_062f9574",
      "unresolved": true
    },
    {
      "id": "d465e08a_11ab6ab4",
      "file_path": "kubernetes/dcaegen2/resources/external/map/schema-map.json",
      "patchset_number": 8,
      "line": null,
      "message": "The publicURL will never be used by VES to connect with remote resource.\nHow does it work: An event which is send to VES contains information about a schema (publicURL) which describes structure of data stored in the event. VES takes this publicURL and map publicURL to local resource (localURL). The local resource is used to validate mentioned data. There is no connection outside the VES container.",
      "author": {
        "account_id": 3433,
        "name": "Bogumil Zebek",
        "display_name": null,
        "email": "bogumil.zebek@nokia.com",
        "username": "bogumil_zebek"
      },
      "updated": "2021-02-18 06:12:12.000000000",
      "in_reply_to": "ae41bbc5_93ca6927",
      "unresolved": true
    },
