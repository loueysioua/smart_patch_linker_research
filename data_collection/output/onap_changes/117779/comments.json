      "patchset_number": 8,
      "line": null,
      "message": "Resources listed in \"publicURL\" keys will be downloaded in run-time or it's just some metadata?",
      "author": {
        "account_id": 5097,
        "name": "Bartek Grzybowski",
        "display_name": null,
        "email": "b.grzybowski@partner.samsung.com",
