      {
        "id": "46bea94b8f75fc8e356a7ba68061b7aed96ef769",
        "author": {
          "account_id": 105,
          "name": "Tony Hansen",
          "display_name": null,
          "email": "tony@att.com",
          "username": "TonyLHansen"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-03-26 17:39:02.000000000",
        "message": "Patch Set 2: Code-Review-1\n\n1) I don't know how the jks files were accepted before, but all keystore binary files must be base64 encoded. Please create jks.b64 files and use base64 -d to decode them.\n\n2) please create a Jira ticket to \na) follow the steps here - https://wiki.onap.org/display/DW/Certificate+update+procedure+in+DCAE (assign it to El Alto release) and align with standard tls distribution mechanism and \nb) removing the certs from this repo.\n\nPlease add a comment with the Jira ticket number in the Commit message.",
        "patchset_number": 2
      },
      {
        "id": "8bfe1720e9c26f126a4d880c55744db85be676be",
        "author": {
          "account_id": 5059,
          "name": "Tamas Bakai",
          "display_name": null,
          "email": "tamas.bakai@est.tech",
          "username": "TamasBakai"
        },
        "author_role": "OWNER",
        "timestamp": "2019-04-02 08:24:17.000000000",
        "message": "Patch Set 2:\n\nThe current solution is more of a fix for expired certificates based on\nhttps://jira.onap.org/browse/DCAEGEN2-1300\n\nAs the ipmlementation is expected to change in El Alto, the b64 encoding might be related to \nhttps://jira.onap.org/browse/DCAEGEN2-1320\nand could handled by a different commit maybe.",
        "patchset_number": 2
      },
      {
        "id": "5933972bb4674ec6b49c90e4787ef2ac84ff64bd",
        "author": {
          "account_id": 105,
          "name": "Tony Hansen",
          "display_name": null,
          "email": "tony@att.com",
          "username": "TonyLHansen"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-04-02 12:34:50.000000000",
        "message": "Patch Set 2:\n\nThis is an example of how the base64 decoding is handled in another docker container:\n\ndcaegen2/deployments/tls-init-container/Dockerfile-template\n\nRUN base64 -d /opt/tls/source/trust.jks.b64 > /opt/tls/source/trust.jks  && base64 -d /opt/tls/source/cert.jks.b64 > /opt/tls/source/cert.jks && base64 -d /opt/tls/source/cert.p12.b64 > /opt/tls/source/cert.p12",
        "patchset_number": 2
      },
