    {
      "id": "32ecbe5e_ce30ebdf",
      "file_path": "catalog-be/src/test/java/org/openecomp/sdc/be/components/property/ComponentInstanceInputPropertyDeclaratorTest.java",
      "patchset_number": 2,
      "line": 53,
      "message": "Multiple variables should not be declared on the same line\n \nCode smell\n \nMinor\nsquid:S1659\n \nDeclaring multiple variable on one line is difficult to read.\nNoncompliant Code Example\n  class MyClass {      private int a, b;      public void method(){      int c; int d;    }  }  \nCompliant Solution\n  class MyClass {      private int a;    private int b;      public void method(){      int c;      int d;    }  }  \nSee\nMISRA C++:2008, 8-0-1 - An init-declarator-list or a member-declarator-list shall consist of a single init-declarator or member-declarator respectively\nCERT, DCL52-J. - Do not declare more than one variable per declaration\nCERT, DCL04-C. - Do not declare more than one variable per declaration",
      "author": {
        "account_id": 2119,
        "name": "Oren Haim Zvi Kleks",
        "display_name": null,
        "email": "orenkleks@hotmail.com",
        "username": "shrek2000"
      },
      "updated": "2019-05-14 06:52:57.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
