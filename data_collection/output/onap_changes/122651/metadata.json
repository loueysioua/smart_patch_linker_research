          "username": "djtimoney"
        },
        "author_role": "CI_BOT",
        "timestamp": "2021-08-24 15:57:42.000000000",
        "message": "Uploaded patch set 2.",
        "patchset_number": 2
      },
      {
        "id": "016279ff99d4b59816e077d603ba665c63013526",
        "author": {
          "account_id": 459,
          "name": "ONAP Jobbuilder",
          "display_name": null,
          "email": "onap-jobbuilder@jenkins.onap.org",
          "username": "onap-jobbuilder"
        },
        "author_role": "REVIEWER",
        "timestamp": "2021-08-24 16:00:40.000000000",
        "message": "Patch Set 2:\n\nBuild Started https://jenkins.onap.org/job/ccsdk-cds-maven-verify-master-mvn36-openjdk11/757/",
        "patchset_number": 2
      },
      {
        "id": "bdcf81d1e462bc411192842d32edeb88961cc019",
        "author": {
          "account_id": 87,
          "name": "Dan Timoney",
          "display_name": null,
          "email": "dtimoney@att.com",
          "username": "djtimoney"
        },
        "author_role": "REVIEWER",
        "timestamp": "2021-08-24 16:02:55.000000000",
        "message": "Patch Set 2:\n\nPosted a change set that to allow TRUSTSTORE_PASSWD to be passed in as variable setting (set to standard Java cacerts password by default.\n\nTo support a custom truststore, rather than passing the filename in as an environment variable, it would be better to mount that truststore as $JAVA_HOME/lib/security/cacerts rather than using a shell variable.  This would avoid potential permission problems which might occur if we tried to copy $TRUSTSTORE_FILE as a replacement for that file (that directory is most likely writable only by root)",
        "patchset_number": 2
      },
