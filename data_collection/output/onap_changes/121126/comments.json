    {
      "id": "b79b7773_d300f89a",
      "file_path": "rest-services/cbs-client/src/main/java/org/onap/dcaegen2/services/sdk/rest/services/cbs/client/impl/CbsClientCommon.java",
      "patchset_number": 7,
      "line": 32,
      "message": "Please try to flatten the logic. Example:\n\n    public static void processEnvironmentVariables(JsonObject jsonObject) {\n        processJsonObject(jsonObject);\n    }\n\n    private static void processJsonObject(JsonObject jsonObject) {\n        for (Entry<String, JsonElement> entry : jsonObject.entrySet()) {\n            processJsonObjectEntry(jsonObject, entry);\n        }\n    }\n\n    private static void processJsonObjectEntry(JsonObject jsonObject, Entry<String, JsonElement> entry) {\n        if (entry.getValue() instanceof JsonObject) {\n            processJsonObject(entry.getValue().getAsJsonObject());\n        } else {\n            processJsonPrimitive(jsonObject, entry);\n        }\n    }\n\n    public static void processJsonPrimitive(JsonObject jsonObject, Entry<String, JsonElement> entry) {\n        Matcher matcher = shellEnvPattern.matcher(entry.getValue().getAsString());\n        if (matcher.find()) {\n            String envName = matcher.group(1);\n            String envValue = System.getenv(envName);\n            if (envValue == null || \"\".equals(envValue)) {\n                throw new EnvironmentParsingException(\"Cannot read \" + envName + \" from environment.\");\n            }\n            jsonObject.addProperty(entry.getKey(), envValue);\n        }\n    }",
      "author": {
        "account_id": 6044,
        "name": "Remigiusz Janeczek",
        "display_name": null,
        "email": "remigiusz.janeczek@nokia.com",
        "username": "rjanecze"
      },
      "updated": "2021-05-14 07:22:07.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
