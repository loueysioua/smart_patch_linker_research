    {
      "id": "9a437d4f_b09bc4c8",
      "file_path": "BRMSGateway/src/main/java/org/onap/policy/brmsInterface/BRMSGateway.java",
      "patchset_number": 3,
      "line": 69,
      "message": "OK I see, no action required, but fyi, if you mark any other \"long lived\" threads in this process as daemon, I think this won't be needed.  This also implies that there is no graceful shut down for this process, other that sending a signal thorugh OS that I will assume will be done by the \"app init.d\" script that does the start stop of the process.",
