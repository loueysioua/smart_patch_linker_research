      "file_path": "bpmn/so-bpmn-infrastructure-common/src/main/java/org/onap/so/bpmn/infrastructure/pnf/delegate/PnfCheckInputs.java",
      "patchset_number": 4,
      "line": 57,
      "message": "Suggestion - extract each validation into separate private methods. This will improve readability and better convey the intent.",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2018-12-10 10:25:23.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
