    },
    {
      "id": "9adffdf1_a3b8d7e5",
      "file_path": "bpmn/so-bpmn-infrastructure-common/src/test/java/org/onap/so/bpmn/infrastructure/pnf/delegate/PnfCheckInputsTest.java",
      "patchset_number": 4,
      "line": 84,
      "message": "Avoid using the \"expected\" keyword for verifying thrown exceptions - this type of error assertion is not thorough enough - detailed information like message/error codes cannot be verified.\nRecommendation: use assertJ to assert the exceptions in a fluent way. This applies to all instances of BpmnErrors tests.",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2018-12-10 10:25:23.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "9adffdf1_231ce7c0",
      "file_path": "bpmn/so-bpmn-infrastructure-common/src/test/java/org/onap/so/bpmn/infrastructure/pnf/delegate/PnfCheckInputsTest.java",
      "patchset_number": 4,
      "line": 84,
      "message": "I found assertJ to break the BPMN Mockito dependency, please be cautious if you plan on re-introducing  it.",
      "author": {
        "account_id": 63,
