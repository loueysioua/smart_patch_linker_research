      "file_path": "bpmn/so-bpmn-infrastructure-common/src/test/java/org/onap/so/bpmn/infrastructure/pnf/delegate/PnfCheckInputsTest.java",
      "patchset_number": 4,
      "line": 43,
      "message": "Suggestion - while nothing wrong with hardcoding UUIDs for testing purposes - as previously mentioned - I'd recommend generating the UUIDs deterministically. This approach would be less prone to errors",
      "author": {
        "account_id": 2815,
        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2018-12-10 10:25:23.000000000",
      "in_reply_to": null,
