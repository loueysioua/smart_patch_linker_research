        "name": "Michal Kabaj",
        "display_name": null,
        "email": "michal.kabaj@nokia.com",
        "username": "kabayashi"
      },
      "updated": "2018-12-10 10:25:23.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
