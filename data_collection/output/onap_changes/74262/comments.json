      "id": "9adffdf1_9e840ed5",
      "file_path": "bpmn/so-bpmn-infrastructure-common/src/test/java/org/onap/so/bpmn/infrastructure/pnf/delegate/PnfCheckInputsTest.java",
      "patchset_number": 1,
      "line": 133,
      "message": "I don't like that action you're testing is performed in separate method. Especially when you pass testedObject via field, not parameter.\n\nI think the best solution would be something like this:\nassertThatThrownBy(() -> testedObject.execute(delegateExecution)).isInstanceOf(Bpmn.class);\n\nAlternatively you can wrtie method assertThatThrowsBpmnError that takes lamba, runs it and checks if correct exception is thrown.",
      "author": {
        "account_id": 2795,
        "name": "Lukasz Biniek",
        "display_name": null,
        "email": "lukasz.biniek@nokia.com",
        "username": "Biniek"
      },
      "updated": "2018-12-06 14:23:05.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
