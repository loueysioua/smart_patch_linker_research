    {
      "id": "eb9e7c23_339e248b",
      "file_path": "kubernetes/uui/components/uui-server/templates/deployment.yaml",
      "patchset_number": 9,
      "line": 71,
      "message": "We transfer the model file from the uui-server component to the uui-nlp component, and load the model file in the uui-nlp component. This requires that we first store the model file in the uui-server component, then send it to the uui-nlp component when using it, and store it in the uui-nlp component, so that we can find the file when loading the model file. When the uui-server component stores files, we use the PVC defined here",
      "author": {
        "account_id": 7640,
        "name": "zhao yehua",
        "display_name": null,
        "email": "zhaoyh6@asiainfo.com",
        "username": "zhaoyh6"
      },
      "updated": "2021-09-26 06:30:24.000000000",
      "in_reply_to": "f0986674_3bd5b12e",
