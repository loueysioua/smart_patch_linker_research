    {
      "id": "0f0de4cd_cab69fe3",
      "file_path": "build/hv-collector-analysis/src/main/kotlin/org/onap/dcae/collectors/veshv/analysis/PublicModifiersInImpl.kt",
      "patchset_number": 4,
      "line": 44,
      "message": "We can add hint for action, e.g. \n\n\"Implementation files cannot have public declarations. Please add `internal` modifier for this element to disallow usage outside of module\"\n\nAlso isn't \"files\" wrong in first sentence - shouldn't be \"Implementation package members\" or maybe \"cannot have public members declarations\"?",
      "author": {
        "account_id": 3701,
        "name": "Filip Krzywka",
        "display_name": null,
        "email": "filip.krzywka@nokia.com",
        "username": "fkrzywka"
      },
      "updated": "2019-04-12 07:52:14.000000000",
