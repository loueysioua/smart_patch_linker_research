    {
      "id": "675bbee6_86f49787",
      "file_path": "build/hv-collector-analysis/src/main/kotlin/org/onap/dcae/collectors/veshv/analysis/PublicModifiersInImpl.kt",
      "patchset_number": 4,
      "line": 50,
      "message": "We could use List<Entity> instead.\n\nThis would result in more detailed inspections (with exact line of missing modifier instead of \"File:1:1\"):\n```\nImplVisitor().also {\n                file.accept(it)\n                if (it.containsPublicDeclarations()) {\n                    for (entity in it.publicDeclarations)\n                        report(CodeSmell(issue, entity, REPORT_MESSAGE))\n                }\n            }\n```",
      "author": {
        "account_id": 3701,
        "name": "Filip Krzywka",
        "display_name": null,
        "email": "filip.krzywka@nokia.com",
        "username": "fkrzywka"
      },
      "updated": "2019-04-12 07:52:14.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
