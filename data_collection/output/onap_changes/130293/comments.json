    },
    {
      "id": "dcb0cae5_3b6be624",
      "file_path": "catalog-be/src/main/java/org/openecomp/sdc/be/components/csar/ServiceCsarInfo.java",
      "patchset_number": 1,
      "line": 277,
      "message": "if an integer or double, etc is input while casting it will throw an error since it's expecting a string but this won't happen with String.valueOf",
