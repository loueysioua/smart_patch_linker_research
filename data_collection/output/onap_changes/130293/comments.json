    {
      "id": "c02cd3c1_97f523a9",
      "file_path": "catalog-be/src/main/java/org/openecomp/sdc/be/components/impl/ServiceImportBusinessLogic.java",
      "patchset_number": 1,
      "line": 362,
      "message": "We shouldnt support changes to existing properties only the addition of properties.",
