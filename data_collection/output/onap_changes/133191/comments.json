    {
      "id": "f25e9b71_b8561ae2",
      "file_path": "docker-compose/docker-compose.yml",
      "patchset_number": 3,
      "line": 127,
      "message": "This causes problems starting up docker-compose from command line, because the default value of CPS_HOME '.' is wrong - CPS home is one level above docker-compose, i.e. '..'\nHowever, the entire line can simply be replaced with:\n  build: initfile\n\nsince docker-compose always looks for files in the same folder as the docker-compose.yml file.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2023-02-15 09:25:11.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
