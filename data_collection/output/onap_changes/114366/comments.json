    {
      "id": "1ac8f729_ab289108",
      "file_path": "kubernetes/a1policymanagement/resources/envsubst/daemon.sh",
      "patchset_number": 10,
      "line": 27,
      "message": "I really don't get it. Why you just don't provide this file inside \"update_files\" directly to tmp as a configmap with execution rights?",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
