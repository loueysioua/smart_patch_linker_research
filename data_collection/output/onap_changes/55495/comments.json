    {
      "id": "5a93c517_59348ffa",
      "file_path": "src/test/java/org/onap/aai/babel/xml/generator/model/TestGeneratorUtil.java",
      "patchset_number": 2,
      "line": 31,
      "message": "as stated in https://google.github.io/styleguide/javaguide.html#s5.2.3-method-names \n\"Underscores may appear in JUnit test method names to separate logical components of the name, with each component written in lowerCamelCase\"\n\nIs there any official tests naming convention in ONAP?",
      "author": {
        "account_id": 3771,
        "name": "Adam Wudzinski",
        "display_name": null,
        "email": "adam.wudzinski@nokia.com",
        "username": "adamwudzinski"
