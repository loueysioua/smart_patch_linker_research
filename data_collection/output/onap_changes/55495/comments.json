    },
    {
      "id": "5a93c517_78993c78",
      "file_path": "src/test/java/org/onap/aai/babel/xml/generator/model/TestGeneratorUtil.java",
      "patchset_number": 2,
      "line": 31,
      "message": "This is more a question of consistency with the other Java code already present in this git repo. I do not know of any Junit test naming conventions for ONAP (other than the previously mentioned https://wiki.onap.org/display/DW/Java+code+style). However, the repos that I have worked on do not tend to favour underscores. We have been phasing out prefixes that simply repeat the test Class name. I do not perceive any value to having a common prefix that simply extends the method name.",
      "author": {
        "account_id": 1313,
        "name": "Mark Leonard",
        "display_name": null,
        "email": "mark.j.leonard@gmail.com",
        "username": "mark.j.leonard"
      },
      "updated": "2018-07-05 13:30:37.000000000",
      "in_reply_to": "5a93c517_59348ffa",
      "unresolved": false
    },
