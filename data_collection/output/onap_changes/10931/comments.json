    {
      "id": "9a437d4f_addb2f1a",
      "file_path": "integrity-monitor/src/main/java/org/onap/policy/common/im/IntegrityMonitor.java",
      "patchset_number": 3,
      "line": 55,
      "message": "Global: This code is executed quite frequently.  Here is how you should treat the log statements:\n - Convert all statements to use the {} parameter insertion format.  This also includes all that have a string msg built before being inserted into the logger statement.\n - Surround all logger.debug statements with a block: if(logger.isDebugEnabled{...}\n - Convert all logger.info statements to logger.debug and surround with isDebugEnabled block.\n\nThis applies to all the classes except the test class.",
      "author": {
        "account_id": 1621,
        "name": "Kevin McKiou",
        "display_name": null,
        "email": "km097d@att.com",
        "username": "km097d"
      },
      "updated": "2017-09-11 17:40:04.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "9a437d4f_edca574e",
      "file_path": "integrity-monitor/src/main/java/org/onap/policy/common/im/IntegrityMonitor.java",
      "patchset_number": 3,
      "line": 550,
      "message": "You should delete the msg and just put the string in logger.debug statement so you can change the format to include the \"dep\" as a parameter with {}.\n\nThis is a global comment everywhere there is a msg defined and then inserted into a logger.error/debug statement.",
      "author": {
        "account_id": 1621,
        "name": "Kevin McKiou",
