      {
        "id": "f3cafa5c0af0a828c33c9345221cc4345eee728d",
        "author": {
          "account_id": 1631,
          "name": "Ojas Dubey",
          "display_name": null,
          "email": "Ojas.Dubey@amdocs.com",
          "username": "ojasdubey"
        },
        "author_role": "REVIEWER",
        "timestamp": "2020-05-06 08:59:30.000000000",
        "message": "Patch Set 1:\n\nCurrently annotations are used only in HEAT onboarded VFs but in future can be used for other use cases in other non heat flows as well to pass some metadata with an input parameter. So I feel that this special handling to prevent packing of this yml might have to be reverted. \n\n@Shiri .. What do you think ?",
        "patchset_number": 1
      },
