    {
      "id": "fb7d2a01_3d0ca392",
      "file_path": "adapters/mso-vnfm-adapter/mso-vnfm-etsi-adapter/src/main/java/org/onap/so/adapters/vnfmadapter/notificationhandling/NotificationHandler.java",
      "patchset_number": 2,
      "line": 174,
      "message": "if VnfTerminatation fails to update AAI, it will not retry it ever correct? how would be recover/try it again then?",
      "author": {
        "account_id": 3237,
        "name": "Waqas Ikram",
        "display_name": null,
        "email": "waqas.ikram@est.tech",
        "username": "waqas.ikram"
