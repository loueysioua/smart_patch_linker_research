    },
    {
      "id": "8354dcc0_34bfefca",
      "file_path": "policy-utils/src/main/java/org/onap/policy/drools/utils/logging/LoggerUtil.java",
      "patchset_number": 1,
      "line": 56,
      "message": "A transaction record is a full blown record, it will be an entry for example for full blown trnasaction, start time, to end time, for example for control loop transaction, ie from ONSET t0 FINAL transaction.\n\nA metric is a single control loop step, ie. aai, guard, appc operation, etc ..\n\nThat's how it works right now.and consistent with the original spec.\n\nWhat is the meaning of these fields now?   Do they capture the same semantics?",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
      "updated": "2020-05-20 18:16:17.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
