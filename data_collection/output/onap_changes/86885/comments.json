    {
      "id": "a3763752_d883f381",
      "file_path": "kubernetes/common/cassandra/templates/statefulset.yaml",
      "patchset_number": 1,
      "line": 51,
      "message": "aai-cassandra was not creating any user.\nBy default cassandra.yaml contains AllowAllAuthenticator as authenticator which allows all the users. AAI was using it with this default behavior only.\nBut SDC creates the asdc_user and we will need this capability.\n\ndocker-entrypoint.sh provides a way to override the config for certain parameters but not for this particular param. Another way (and better) of achieving this could be to modify the docker-entrypoint.sh and mount it using configmap and provide this parameter using env variable.",
      "author": {
        "account_id": 2763,
        "name": "Mahendra Raghuwanshi",
        "display_name": null,
        "email": "mahendra.raghuwanshi@amdocs.com",
        "username": "mahendrr"
      },
      "updated": "2019-05-03 07:14:45.000000000",
      "in_reply_to": "7f7c5cdf_3a743301",
      "unresolved": false
    },
