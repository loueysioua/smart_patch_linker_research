    {
      "id": "676799ac_04de3910",
      "file_path": "docs/content/deployment.rst",
      "patchset_number": 5,
      "line": 141,
      "message": "I'm suggesting adding something like the following:\n\nCps data-updated-event schema v2 used in Jakarta is backward compatible with data-updated-event schema v1 used in Istanbul.\n\nIt means that consumers using the schema v2 can process events generated by producers using the schema v2 or v1.\n\nThis implies that cps temporal (consumer) must be upgraded from Istanbul to Jakarta at the same time or before cps core (producer) is upgraded from Istanbul to Jakarta.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2022-01-12 06:34:50.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "00fde62d_d4bec3a2",
      "file_path": "docs/content/modeling.rst",
      "patchset_number": 5,
      "line": 17,
      "message": "v1 to be removed from the file name.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2022-01-12 06:34:50.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "dae0347e_2d841730",
      "file_path": "docs/content/modeling.rst",
      "patchset_number": 5,
      "line": 24,
      "message": "v2",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2022-01-12 06:34:50.000000000",
