      "unresolved": true
    },
    {
      "id": "5f971ece_d2c4dc5c",
      "file_path": "docs/content/modeling.rst",
      "patchset_number": 5,
      "line": 40,
      "message": "We can maintain an event version table here:\n\n  | Version | Release  | Compatibility Type      | Upgrade First       |\n  |         |          | (with previous version) |                     |\n  |---------|----------|-------------------------|---------------------|\n  | v1      | Istanbul | n/a                     | Any order           |\n  | v2      | Jakarta  | Backward                | Consumer (Temporal) |\n\nwith an explanation about possible compatibility types:\n\n* Backward compatibility means that consumers using the new schema can read data produced with the previous schema.\n* Forward compatibility means that data produced with a new schema can be read by consumers using the previous schema.\n* Full compatibility means that schemas are both backward and forward compatible: old data can be read with the new schema, and new data can also be read with the previous schema.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2022-01-12 06:34:50.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
