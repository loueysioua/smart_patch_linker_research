    {
      "id": "f4416f65_eea2055f",
      "file_path": "common-be/src/main/java/org/openecomp/sdc/be/datatypes/elements/ToscaFunctionJsonDeserializer.java",
      "patchset_number": 6,
      "line": 251,
      "message": "all of this for cover following example\n{ $juel: [ \"Hi, ${arg[0]}\", { get_input: name } ] }\nresult of trimming this expression is\n{ $juel: [ Hi, ${arg[0]}\", { get_input: name } ] }\nbecause no trailing quote , and it will break Download \n\nremoved single quote from matcher to have, at least, one way to separate strings",
      "author": {
        "account_id": 5562,
        "name": "Vasyl Razinkov",
        "display_name": "Vasyl Razinkov",
        "email": "razinkov@hotmail.com",
