      "patchset_number": 3,
      "line": 130,
      "message": "I think copyOf is redundant here, stream collect creates new object and we can get the return stream to be unmodified by using collector \n.collect(Collectors.toUnmodifiableSet())",
      "author": {
        "account_id": 5098,
        "name": "Bartosz Gardziejewski",
        "display_name": null,
        "email": "bartosz.gardziejewski@nokia.com",
