    {
      "id": "db0688d5_cde72f77",
      "file_path": "cps-ri/src/main/java/org/onap/cps/ri/CpsModulePersistenceServiceImpl.java",
      "patchset_number": 2,
      "line": 397,
      "message": "I think it's a bad idea. Premature optimization. I'm not convinced a bulk request here will be more performant at all. Now that we only create one schemaset per moduleSetTag, and we know there are only 20 module-sets at most, this will give no performance benefit, while introducing a ton of complexity & possible bugs.\n\nThe correct way to write high-performance code is to do a simple implementation first, then benchmark and identify bottlenecks e.g. using @Timed metrics.\nOften it may be 1% of the code that will take 99% of the processing time.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2025-02-06 16:44:14.000000000",
      "in_reply_to": "6552c5a6_e4bf59e6",
      "unresolved": true
    },
    {
      "id": "92f3ea31_c4353201",
      "file_path": "cps-ri/src/main/java/org/onap/cps/ri/CpsModulePersistenceServiceImpl.java",
      "patchset_number": 2,
      "line": 397,
      "message": "Plus the proposed solution is incorrect: it does not factor in module revision. It should be:\n\n    findAllByModuleNamesAndRevisions(moduleReferences)\n\nwhich is vastly more complex to implement.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2025-02-06 16:46:41.000000000",
      "in_reply_to": "db0688d5_cde72f77",
      "unresolved": true
    },
