      },
      {
        "id": "f190a7519ffa2fb36fceeaf9358defda8a7b45f6",
        "author": {
          "account_id": 35,
          "name": "Gary Wu",
          "display_name": null,
          "email": "gary.wu@gmail.com",
          "username": "gwu"
        },
        "author_role": "OWNER",
        "timestamp": "2017-05-09 17:46:39.000000000",
        "message": "Patch Set 1:\n\nHmm, ok.  In OPEN-O and OpenDaylight we don't have developers build against staging artifacts; it is assumed that any artifacts with release version labels are final, immutable, and already available from the release repos.   This prevents the issue of an artifact with the same release version label but having different content on different environments due to timing differences in when it was downloaded.\n\nWe'll roll with the \"build against staging\" approach for now, but we may want to reconsider this approach later.",
        "patchset_number": 1
      },
