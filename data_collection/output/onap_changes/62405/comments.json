    {
      "id": "1a76adc5_00eb8c78",
      "file_path": "reference/logging-demo/src/main/resources/logback.xml",
      "patchset_number": 12,
      "line": 31,
      "message": "yes p_tim is just macro that puts out the built in $d (date/time) field - LogTimestamp in the acumos spec - in regards to the name - the p_* names are specific to the inherited logback from porta/sdk - we can call these macro names anything - maybe we should use the spec names and rename LogTimestamp from p_tim (as I see you updated the wiki with p_tim)",
      "author": {
        "account_id": 1077,
        "name": "Michael O'Brien",
        "display_name": null,
        "email": "frank.obrien@amdocs.com",
        "username": "michaelobrien"
      },
