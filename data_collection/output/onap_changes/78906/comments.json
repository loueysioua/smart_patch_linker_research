    {
      "id": "68322425_cab22c32",
      "file_path": "component-json-schemas/dmaap/dcae-cli-v1/dmaap-schema.json",
      "patchset_number": 5,
      "line": 104,
      "message": "The name of this property is taken from Kafka documentation http://kafka.apache.org/documentation/#consumerconfigs . I've tried to keep these names as similar as possible to remove any inconsistencies. So kafka \"bootstrap.servers\" property is mapped here to \"bootstrap_servers\". It does not imply a mechanism of deployment.\n\nHowever, if you think that this will conflict with DCAE naming I can change it to kafka_brokers.",
      "author": {
        "account_id": 2683,
        "name": "Piotr Jaszczyk",
