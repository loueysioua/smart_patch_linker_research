    {
      "id": "06ad89e8_e1cdd4b7",
      "file_path": "component-json-schemas/dmaap/dcae-cli-v1/dmaap-schema.json",
      "patchset_number": 5,
      "line": 82,
      "message": "This should be defined per kafka topic IMO. The assumption that broker credentials will be same across all ONAP deployment is true in a single cluster ONAP deployment. For Dublin, OOM/DCAE (and DMAAP) are adding support for multi-cluster deployment support. Also for HA support, hv-ves will be required to write into multiple DMAAP/kafka cluster hence configuration model should define authentication credential/topic.",
      "author": {
        "account_id": 93,
        "name": "Vijay Venkatesh Kumar",
        "display_name": null,
        "email": "vijayv81@gmail.com",
        "username": "vv770d"
      },
      "updated": "2019-03-18 21:06:08.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
