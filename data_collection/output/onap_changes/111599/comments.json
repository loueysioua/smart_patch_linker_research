    {
      "id": "a7ae9e81_d163ab9d",
      "file_path": "kubernetes/dcaegen2/components/dcae-bootstrap/values.yaml",
      "patchset_number": 7,
      "line": 44,
      "message": "Does this config need a:   cloudifyManagerPassword: \"override me\"",
      "author": {
