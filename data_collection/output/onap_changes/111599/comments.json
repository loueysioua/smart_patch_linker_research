    {
      "id": "612a9317_1dee8fef",
      "file_path": "kubernetes/dcaegen2/components/dcae-bootstrap/values.yaml",
      "patchset_number": 7,
      "line": 44,
      "message": "nope it doesn't. As this component used to create the actual secret I assumed that it is the owner of this password thus if cloudifyManagerPassword is not set our template will just generate one.\n\nFor other components you may see that I've set the policy: required which is typical for \"password consumers\". So in that case they expect that the password has to be given by the parent chart and if it's not they'll just fail the deployment but to allow to lint them I set this to some random value",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2020-09-11 20:06:06.000000000",
      "in_reply_to": "a7ae9e81_d163ab9d",
      "unresolved": true
    },
