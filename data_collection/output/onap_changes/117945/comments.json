    {
      "id": "13f182f2_11e3d18b",
      "file_path": "cps-nf-proxy-rest/src/main/resources/changelog/changelog-master.yaml",
      "patchset_number": 5,
      "line": 3,
      "message": "Why are we enforcing a specific user ? Both the user and the password should be configurable using environment variables or system properties when the script is launched (by the application or maven).",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
