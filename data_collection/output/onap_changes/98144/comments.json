    {
      "id": "942775b0_f68c1c6c",
      "file_path": "tools/performance/cloud/reboot-test-environment.sh",
      "patchset_number": 2,
      "line": 27,
      "message": "You should never hardcode escape sequences like this; as not all terminals use these particular escape sequences. Instead, use the tput command to extract the proper escape sequence for the terminal being used:\n\nYELLOW=$(tput setab 3)\nGREEN=$(tput setab 2)\nCYAN=$(tput setab 6)\nNO_COLOR=$(tput sgr0)",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2019-11-11 19:51:53.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "43a27331_2f22e5bf",
      "file_path": "tools/performance/cloud/reboot-test-environment.sh",
      "patchset_number": 2,
      "line": 35,
      "message": "Note that tput outputs the real escape sequences, rather than backslash character references. So the \"echo -e\" should become \"echo\" instead.",
      "author": {
        "account_id": 105,
        "name": "Tony Hansen",
        "display_name": null,
        "email": "tony@att.com",
        "username": "TonyLHansen"
      },
      "updated": "2019-11-11 19:51:53.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
