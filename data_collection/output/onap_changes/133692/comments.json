    {
      "id": "f499b1f6_5009e872",
      "file_path": "kubernetes/strimzi/templates/pod-monitor.yaml",
      "patchset_number": 3,
      "line": 28,
      "message": "nah, both are different, we need those since there is no possibility to change strimzi cluster name, actually there is, by changing the name of app from example onap-strimzi to your clustername, but since there are hardcoded connection towards onap-strimzi clustername, the change is not possible, with relabeling I could change the clustername in podmonitor so it will not affect strimzi app at all. \n\nDifference between those are: \n\nRelabelings refer to the labels that a target ends up having, this happens when Prometheus discovers your targets (so we often refer to this as “at discovery time”). Targets are scraped and all target labels are added to the metrics scraped from that target.\n\nMetric relabeling is done after the target’s labels have been added to the metrics that were just scraped, and right before they’re inserted into the time series database. We often refer to metric relabeling to be done “at scrape time”.",
      "author": {
        "account_id": 8256,
        "name": "Miroslav Masaryk",
        "display_name": null,
        "email": "miroslav.masaryk@telekom.com",
        "username": "samrim96"
      },
      "updated": "2023-04-03 11:04:09.000000000",
      "in_reply_to": "11c09804_4e6b8511",
      "unresolved": false
    },
