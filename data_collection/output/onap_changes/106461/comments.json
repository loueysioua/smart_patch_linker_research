    {
      "id": "efbd466a_f17b0b28",
      "file_path": "common-logging/src/main/java/org/onap/policy/common/logging/flexlogger/EelfLogger.java",
      "patchset_number": 6,
      "line": 263,
      "message": "seems like it's fine like this - let PolicyLogger deal with the arguments",
      "author": {
