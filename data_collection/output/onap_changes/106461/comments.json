    {
      "id": "fb614a7b_30ba0915",
      "file_path": "common-logging/src/main/java/org/onap/policy/common/logging/flexlogger/EelfLogger.java",
      "patchset_number": 7,
      "line": null,
      "message": "I'm sorry.  This is just getting more complicated than it needs to be, particularly since PolicyLogger already does all of the argument stuff.  Let's just put this class back the way it was and simply add the String/Args methods for info, debug, warn, error, audit, metrics:\n\n  debug(String message, Object[] args) {\n    PolicyLogger.debug(message, args)\n  }",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2020-04-24 19:45:44.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
      "id": "f695536a_e2bf885c",
      "file_path": "common-logging/src/main/java/org/onap/policy/common/logging/flexlogger/Logger4J.java",
      "patchset_number": 6,
      "line": 114,
      "message": "I was totally wrong here.  I was thinking this was \"String, Throwable\", but it was \"Object, Throwable\", so there is no collision.  However, as long as policy-engine still compiles, this may not be needed anyway.  Can you verify that?",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2020-04-24 19:45:44.000000000",
      "in_reply_to": "5dfa3796_8adeca56",
      "unresolved": true
    },
    {
      "id": "6feb31c9_4cd9dbff",
      "file_path": "common-logging/src/main/java/org/onap/policy/common/logging/flexlogger/SystemOutLogger.java",
      "patchset_number": 7,
      "line": 153,
      "message": "don't need \".toString()\"",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
      },
      "updated": "2020-04-24 19:45:44.000000000",
