      "file_path": "participant/participant-impl/participant-impl-http/src/main/java/org/onap/policy/clamp/controlloop/participant/http/main/webclient/ClHttpClient.java",
      "patchset_number": 1,
      "line": 87,
      "message": "I think spring webclient's exchange() method doesn't throw any exception for 4xx and 5xx responses. So I have a try catch here to check the status code and throw exception accordingly.\n\nIf we use retrieve() instead of exchange(), it will throw exception but it filters back only the response body of the http response. So exchange() method was used to verify the status code which gives more handle.",
      "author": {
        "account_id": 6070,
        "name": "Ramesh Murugan Iyer",
        "display_name": null,
        "email": "ramesh.murugan.iyer@est.tech",
        "username": "rameshiyer27"
      },
      "updated": "2021-07-30 15:20:44.000000000",
      "in_reply_to": "78940401_831833cc",
      "unresolved": true
    },
