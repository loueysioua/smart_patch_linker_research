          "username": "yangyan"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-03-15 07:01:52.000000000",
        "message": "Patch Set 1:\n\nFinally block gives us the opportunity to do some cleanup at the end of the exception handling.Use finally can ensure that our resources are cleaned up",
        "patchset_number": 1
      },
      {
        "id": "1d4369a7814c1b7af772d1c08cc2bb73663d7085",
