      "id": "1a9dcd25_a4094397",
      "file_path": "ONAP-PAP-REST/src/main/java/org/onap/policy/pap/xacml/rest/components/PolicyDBDao.java",
      "patchset_number": 4,
      "line": 1936,
      "message": "We have removed a closeQuietly(), that should be OK.",
      "author": {
        "account_id": 2787,
