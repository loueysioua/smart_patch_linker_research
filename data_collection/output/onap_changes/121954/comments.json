    {
      "id": "4eedbdee_2ebac652",
      "file_path": "cps-ri/src/main/resources/changelog/db/changes/01-createCPSTables.yaml",
      "patchset_number": 4,
      "line": 1,
      "message": "As a general guideline liquibase change set files should never been changed once applied:\nhttps://www.liquibase.org/blog/dealing-with-changing-changesets\n\nI'm not sure is change set checksums are calculated on the actual change set configuration only or on the overall file.\n\nCould you please ensure that this change does not impact liquibase change sets ?\nLiquibase script from this branch should not complain about inconsistent checksum when running on a database on which change sets from master branch has been applied.",
      "author": {
        "account_id": 5658,
        "name": "Bruno Sakoto",
        "display_name": null,
        "email": "bruno.sakoto@bell.ca",
        "username": "brusak"
      },
      "updated": "2021-06-18 11:51:34.000000000",
