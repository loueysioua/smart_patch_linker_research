      {
        "id": "cf35ca1de91ee0b16abd4456792a0c73c7271636",
        "author": {
          "account_id": 2041,
          "name": "Shankaranarayanan Puzhavakath Narayanan",
          "display_name": null,
          "email": "snarayanan@research.att.com",
          "username": "snarayanan"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-08-15 15:39:00.000000000",
        "message": "Patch Set 2:\n\nRuoyu, can we please make this switch from HTTP to HTTPS, flag based, from a HAS point of view ?",
        "patchset_number": 2
      },
      {
        "id": "16ad4a42761b3a4e3eb4cfe29e7bdc0147f07cbb",
        "author": {
          "account_id": 2977,
          "name": "Ruoyu Ying",
          "display_name": null,
          "email": "ruoyu.ying@intel.com",
          "username": "Ruoyu"
        },
        "author_role": "OWNER",
        "timestamp": "2019-08-15 23:14:41.000000000",
        "message": "Patch Set 2:\n\n> Patch Set 2:\n> \n> Ruoyu, can we please make this switch from HTTP to HTTPS, flag based, from a HAS point of view ?\n\nHi Shankar, does the flag you mentioned here mean the MUSIC version? Like HAS will switch to Https connection only if we are using new version of MUSIC?",
        "patchset_number": 2
      },
      {
        "id": "09c011eca3884914f1a7f1bb8ca243b461b4aafb",
        "author": {
          "account_id": 2041,
          "name": "Shankaranarayanan Puzhavakath Narayanan",
          "display_name": null,
          "email": "snarayanan@research.att.com",
          "username": "snarayanan"
        },
        "author_role": "REVIEWER",
        "timestamp": "2019-08-16 14:49:42.000000000",
        "message": "Patch Set 2:\n\nThis would be more along the lines of how HAS can choose to work with and without HTTPs interfaces with MUSIC. Ideally we want to decouple this from our dependency on Music versions, since Music should independently support operating under both HTTPs and HTTP modes. But for the moment, we can add a config parameter that says whether we need to use HTTPS or HTTP and can add a note that this config is music version dependent until MUSIC supports both options.",
        "patchset_number": 2
      },
      {
        "id": "866d269354ee60b85958b3819673ffa825fe61cd",
        "author": {
          "account_id": 2977,
          "name": "Ruoyu Ying",
          "display_name": null,
          "email": "ruoyu.ying@intel.com",
          "username": "Ruoyu"
        },
        "author_role": "OWNER",
        "timestamp": "2019-08-19 00:35:59.000000000",
        "message": "Patch Set 2:\n\n> Patch Set 2:\n> \n> This would be more along the lines of how HAS can choose to work with and without HTTPs interfaces with MUSIC. Ideally we want to decouple this from our dependency on Music versions, since Music should independently support operating under both HTTPs and HTTP modes. But for the moment, we can add a config parameter that says whether we need to use HTTPS or HTTP and can add a note that this config is music version dependent until MUSIC supports both options.\n\nThanks Shankar. So ideally here should be an extra parameter explaining this. I'll add it inside both the configuration file and the code in the next patch.",
        "patchset_number": 2
      },
