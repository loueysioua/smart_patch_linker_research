    {
      "id": "b7847c05_0a581d08",
      "file_path": "cps-ri/src/main/java/org/onap/cps/spi/impl/CpsAdminPersistenceServiceImpl.java",
      "patchset_number": 1,
      "line": 185,
      "message": "I'm not sure of the utility of returning the boolean, since it can never be false:\n- If the Dataspace doesn't exist, we get DataspaceNotFoundException.\n- If the Anchor doesn't exist, we get AnchorNotFoundException.\n- If the SchemaSet doesn't exists, we get SchemaSetNotFoundException.\n- If some SQL error occurs in anchorRepository.updateAnchorSchemaSetId, we get a spring DataAccessException.\n- If we make it to line 185, numberOfAnchorUpdated will always be 1, since only one record can match the anchorId.",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
      "updated": "2023-08-15 12:41:54.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
