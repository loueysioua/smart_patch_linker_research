      "id": "ec36662f_24292567",
      "file_path": "kubernetes/common/serviceAccount/Chart.yaml",
      "patchset_number": 11,
      "line": 17,
      "message": "I'm starting to hate helm lack of consequence.\n\nJust to make sure that you realize what the issue here is.\nSo if we name our chart a-b then you cannot simply reference it's values from outside of the chart because .Values.a-b.c doesn't work\n\nbut if you name it aB then .Values.aB.c works but you need to always use nameOverride for this chart (as we do for certInitializer) as otherwise the deployment is going to fail because aB is not a proper DNS name...",
      "author": {
        "account_id": 4965,
        "name": "Krzysztof Opasiak",
        "display_name": null,
        "email": "k.opasiak@samsung.com",
        "username": "kopasiak"
      },
      "updated": "2020-06-09 21:24:15.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
