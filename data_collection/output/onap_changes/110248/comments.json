    {
      "id": "bce86686_8365abab",
      "file_path": "docs/sections/services/pm-mapper/configuration.rst",
      "patchset_number": 2,
      "line": 12,
      "message": "This as a whole could probably do with a little bit of work, in terms of the existing piece and the new addition.\n\nIf I was doing this, I'd probably reword it to something like:\n\nThe PM Mapper performs data reduction, by filtering the PM telemetry data it receives.\nThis filtering information is provided to the service as part of its configuration, and is used to identify desired PM measurements (measType) contained within the data.\n\nThe service can accept an exact match to the measType, or regex(java.util.regex) identifying multiple measTypes.\n\nif a filter is provided, any measurement that does not match the filter, will be ignored and a warning will be logged.",
      "author": {
        "account_id": 4023,
        "name": "Joseph O'Leary",
        "display_name": null,
        "email": "joseph.o.leary@est.tech",
        "username": "JoeOLeary"
      },
      "updated": "2020-07-17 13:13:05.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
    {
