    {
      "id": "9355fbc1_d55ac658",
      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/impl/inventory/sync/ModuleSyncService.java",
      "patchset_number": 10,
      "line": 110,
      "message": "Enhanced readability and modularity by breaking down large methods:\n\n public void syncAndCreateSchemaSetAndAnchor(final YangModelCmHandle yangModelCmHandle) {\n        final String moduleSetTag = yangModelCmHandle.getModuleSetTag();\n        boolean isNewModuleSetTag = Strings.isNotBlank(moduleSetTag);\n        ModuleDelta moduleDelta;\n\n        try {\n            moduleDelta = resolveModuleDelta(yangModelCmHandle, moduleSetTag, isNewModuleSetTag);\n            createSchemaSetAndAnchor(yangModelCmHandle, moduleDelta, isNewModuleSetTag);\n        } finally {\n            if (isNewModuleSetTag) {\n                moduleSetTagsBeingProcessed.remove(moduleSetTag);\n            }\n        }\n    }\n\n    /**\n     * Resolves the module delta for the given CM handle and module set tag.\n     */\n    private ModuleDelta resolveModuleDelta(YangModelCmHandle yangModelCmHandle, String moduleSetTag, boolean isNewModuleSetTag) {\n        if (privateModuleSetCache.containsKey(moduleSetTag)) {\n            return privateModuleSetCache.get(moduleSetTag);\n        }\n        if (isNewModuleSetTag) {\n            if (!moduleSetTagsBeingProcessed.add(moduleSetTag)) {\n                throw new NcmpException(\n                    \"Concurrent processing of module set tag \" + moduleSetTag,\n                    moduleSetTag + \" already being processed for CM handle \" + yangModelCmHandle.getId()\n                );\n            }\n            log.info(\"Processing new module set tag: {}\", moduleSetTag);\n        }\n        return getModuleDelta(yangModelCmHandle, moduleSetTag);\n    }\n\n    /**\n     * Creates SchemaSet and Anchor for the given CM handle.\n     */\n    private void createSchemaSetAndAnchor(YangModelCmHandle yangModelCmHandle, ModuleDelta moduleDelta, boolean isNewModuleSetTag) {\n        final String cmHandleId = yangModelCmHandle.getId();\n        cpsModuleService.createSchemaSetFromModules(\n            NFP_OPERATIONAL_DATASTORE_DATASPACE_NAME,\n            cmHandleId,\n            moduleDelta.newModuleNameToContentMap,\n            moduleDelta.allModuleReferences\n        );\n        cpsAnchorService.createAnchor(NFP_OPERATIONAL_DATASTORE_DATASPACE_NAME, cmHandleId, cmHandleId);\n\n        if (isNewModuleSetTag) {\n            privateModuleSetCache.put(moduleSetTag, new ModuleDelta(moduleDelta.allModuleReferences, NO_NEW_MODULES));\n        }\n    }",
      "author": {
        "account_id": 7957,
        "name": "Sourabh Sourabh",
        "display_name": null,
        "email": "sourabh.sharma.lnf@gmail.com",
        "username": "sourabh_sourabh"
      },
      "updated": "2024-11-19 11:59:48.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
