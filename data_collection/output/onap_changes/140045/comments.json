    {
      "id": "a5a05e17_b9a93cd7",
      "file_path": "cps-service/src/main/java/org/onap/cps/utils/DataMapper.java",
      "patchset_number": 16,
      "line": 127,
      "message": "toDataMaps- Returns a List<Map<String, Object>>, where each entry represents a single DataNode, Each DataNode is individually processed and converted into a Map<String, Object>, with its identifier as the key and its data as the value.\n\ntoDataMapsWithIdentifier- Returns a List<Map<String, List<Map<String, Object>>>>, where data nodes are grouped under their identifier. Instead of treating each DataNode separately, it groups nodes based on their parent identifier",
      "author": {
        "account_id": 7840,
        "name": "Rudrangi Anupriya",
        "display_name": null,
        "email": "ra00745022@techmahindra.com",
