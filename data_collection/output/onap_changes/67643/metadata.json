      {
        "id": "9957b2872ea97d687ee0ff4c47b816931b5425e6",
        "author": {
          "account_id": 1359,
          "name": "Amichai Hemli",
          "display_name": null,
          "email": "amichai.hemli@intl.att.com",
          "username": "ahemli"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-09-23 06:51:54.000000000",
        "message": "Patch Set 4:\n\ncan you please share motivation for this commit endpoint? what is the usage?\nlooks like git related code.",
        "patchset_number": 4
      },
      {
        "id": "4c697d374dfebd379bcbbb76dd8db74d9869d963",
        "author": {
          "account_id": 2731,
          "name": "KK",
          "display_name": null,
          "email": "krzysztof.kurczewski@nokia.com",
          "username": "kurczews"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-09-24 05:48:43.000000000",
        "message": "Patch Set 4: -Code-Review\n\nPurpose of this endpoint is to provide basic information about last commit contained in running VID instance.\n\nSay I want to test if instance running in labs has my changes applied. Instead of executing whole code path I can just send single REST to make sure that my change is applied.\n\nUsing docker tag for this case is not reliable as it can be easily overwritten.\n\nAnd as bonus, it is easy to remove if needed.",
        "patchset_number": 4
      },
      {
        "id": "412a32aff14882ef384991a1208766515d5c239a",
        "author": {
          "account_id": 1359,
          "name": "Amichai Hemli",
          "display_name": null,
          "email": "amichai.hemli@intl.att.com",
          "username": "ahemli"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-09-24 20:39:13.000000000",
        "message": "Patch Set 4:\n\nI would call this endpoint \"/commitInfo\" or \"/codeInfo\" etc. instead of \"/version\".\nWe already have the \"/version\" endpoint to return the build number of vid and the set of features.",
        "patchset_number": 4
      },
      {
