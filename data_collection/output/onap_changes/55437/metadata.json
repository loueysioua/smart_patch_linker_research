      {
        "id": "fb05a199ac4f16067b8fa545d179b2ee5737fa70",
        "author": {
          "account_id": 1991,
          "name": "Sonali Das",
          "display_name": null,
          "email": "sd394g@att.com",
          "username": "sd394g"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-06-28 13:50:49.000000000",
        "message": "Patch Set 2:\n\nHi Jim, the variable declaration for String runningConfig = new String() ; was there for a long time now. As per the new userstory we have reused the same. But owing to your commend we will modify that to String runningConfig ;",
        "patchset_number": 2
      },
      {
        "id": "6fd5bbfe5bfc59c4223720e2db6a96b40c03cb51",
        "author": {
          "account_id": 1991,
          "name": "Sonali Das",
          "display_name": null,
          "email": "sd394g@att.com",
          "username": "sd394g"
        },
        "author_role": "REVIEWER",
        "timestamp": "2018-06-28 15:35:20.000000000",
        "message": "Patch Set 2:\n\nHi Jim, This is my answer to your concern about ConfigComponentAdaptor changes. The logic has been added to make the adapter more complient to NETCONF standard while not breaking the existing functionality which has been tested with various VNFs. As per NETCONF standard  every running config should have <data>..</data> .So any lines with in this two tags will be considered as the running config coming from the VNF . Where as earlier logic was looking for <configuration>...</configuration>. All lines including <configuration>...</configuration> tags are considered as running configuration. In case of some VNFs,it has been found that <configuration>...</configuration> tags are missing in the running config.So logic has been upgraded so that the adapter will consider both <configuration>...</configuration> and <data>..</data> while parsing the running config . It is backward compatible as well as in line with NETCONF standard .",
        "patchset_number": 2
      },
