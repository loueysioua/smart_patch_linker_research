        },
        "author_role": "OWNER",
        "timestamp": "2019-01-18 09:44:25.000000000",
        "message": "Patch Set 1:\n\nI have to delete this git command and set variable to nonsense every time when I am testing the ansible code - which I simply copy elsewhere - and it is annoying to edit this script every time before the image can be build.",
        "patchset_number": 1
