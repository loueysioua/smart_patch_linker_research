    {
      "id": "5c8059e1_110b42db",
      "patchset_number": 1,
      "message": "Please store the postman collection directly as json files. That way, we can see future changes to them in text without needing to download the commit.\n\nIn general, you should avoid storing binary files like ZIP in git, as it isn't optimized for binary, only text. (I had issues on another project with git repo running out of space because of binary files)",
      "author": {
        "account_id": 6742,
        "name": "Daniel Hanrahan",
        "display_name": null,
        "email": "daniel.hanrahan@est.tech",
        "username": "danielhanrahan"
      },
