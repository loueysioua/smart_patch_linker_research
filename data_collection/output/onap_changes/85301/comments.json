    {
      "id": "cf55899e_3f5a3f7a",
      "file_path": "dmaap-sim/src/main/java/org/onap/dmaap/sim/provider/DmaapSimProvider.java",
      "patchset_number": 3,
      "line": 49,
      "message": "change Object to Queue<String>",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
        "username": "jrh3"
