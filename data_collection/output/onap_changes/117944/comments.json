    {
      "id": "e1eacbd6_594d71c9",
      "file_path": "kubernetes/contrib/components/netbox/components/netbox-app/resources/config/startup_scripts/00_users.py",
      "patchset_number": 8,
      "line": 14,
      "message": "The autopep8 rule behind is that a = preceded and appended with a whitespace corespond to a variableassignment.\nFor methods argument such as here, there should be no whitespace.\nThis ways, there is no possible confusion between methods arguments and variable assignments.",
