    {
      "id": "5a93c517_a1a38db0",
      "file_path": "openecomp-be/lib/openecomp-sdc-translator-lib/openecomp-sdc-translator-core/src/main/java/org/openecomp/sdc/translator/services/heattotosca/ConsolidationTypesConnectivity.java",
      "patchset_number": 2,
      "line": 14,
      "message": "In the previous version you used EnumMap. EnumMap is not synchronized. Here you use a synchronized class.\nIs synchronization required?\nIf it is not required, other MultiMaps should be used.\nIf it is required ImmutableSetMultimap looks a better solution , since after initialization the data does not change.",
      "author": {
        "account_id": 2119,
        "name": "Oren Haim Zvi Kleks",
        "display_name": null,
        "email": "orenkleks@hotmail.com",
        "username": "shrek2000"
      },
      "updated": "2018-05-13 04:58:36.000000000",
      "in_reply_to": null,
      "unresolved": false
    },
    {
      "id": "5a93c517_c1a6d9c0",
      "file_path": "openecomp-be/lib/openecomp-sdc-translator-lib/openecomp-sdc-translator-core/src/main/java/org/openecomp/sdc/translator/services/heattotosca/ConsolidationTypesConnectivity.java",
      "patchset_number": 2,
      "line": 73,
      "message": "MultiMap has a function named containsEntry.\nIt will make this code more readable and shorter.\nhttps://google.github.io/guava/releases/21.0/api/docs/com/google/common/collect/Multimap.html#containsEntry-java.lang.Object-java.lang.Object-",
      "author": {
