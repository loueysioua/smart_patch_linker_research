    {
      "id": "59cba0e4_f40e3c39",
      "file_path": "feature-lifecycle/src/main/java/org/onap/policy/drools/lifecycle/LifecycleStateRunning.java",
      "patchset_number": 3,
      "line": 143,
      "message": "I agree with Jim, they should be cumulative. And should be reset only when the PDP engine restarts.\nRegarding increment, it needs to skip the policies which are already deployed. As the PDP is already scanning the list and only deploying the one that is missing.\nMoreover, with the switch to delta policies from PAP, PDPs will only get the one that needs to de deployed. So, in that case you can increment based on the size of the list.",
      "author": {
        "account_id": 3239,
        "name": "Ram Krishna Verma",
        "display_name": null,
        "email": "ramkrishna.verma@gmail.com",
        "username": "ramverma"
      },
      "updated": "2021-02-17 22:26:53.000000000",
      "in_reply_to": "a97eba0c_21f0e5ad",
      "unresolved": true
    },
