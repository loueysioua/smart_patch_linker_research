    {
      "id": "5a93c517_d8942346",
      "file_path": "kubernetes/consul/values.yaml",
      "patchset_number": 10,
      "line": 35,
      "message": "I agree this might look confusing, I tried with \nconsul-server:\n  nameOverride: consul-server\n\ntest complains: \nroot@k8s1:/stage/oomPatch2/kubernetes# helm install consul --namespace onap --name dev --version 2.0.0\nError: parse error in \"consul/templates/deployment.yaml\": template: consul/templates/deployment.yaml:40: bad character U+002D '-'\n\nso I changed to: \nconsulserver:\n  nameOverride: consul-server",
      "author": {
        "account_id": 2541,
        "name": "Jasmine Wen",
        "display_name": null,
        "email": "jasmine.wen@amdocs.com",
        "username": "jasmineWen"
      },
      "updated": "2018-03-29 19:44:46.000000000",
      "in_reply_to": "5a93c517_d8e66316",
      "unresolved": false
    },
    {
      "id": "5a93c517_fbdc7476",
      "file_path": "kubernetes/consul/values.yaml",
      "patchset_number": 10,
      "line": 35,
      "message": "No this has to reference the chart name which, in this case, is consul-server. The issue you are having in the deployment.yam when referencing the chart name can be handled by using the following within your deployment.yaml:  {{ index .Values \"consul-server.nameOverride\" }}. This will ignore the hyphen in the name.",
      "author": {
        "account_id": 127,
        "name": "Mike Elliott",
        "display_name": null,
        "email": "mike.elliott@amdocs.com",
        "username": "melliott"
      },
      "updated": "2018-04-02 13:51:08.000000000",
      "in_reply_to": "5a93c517_d8e66316",
      "unresolved": false
