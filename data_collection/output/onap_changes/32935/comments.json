    {
      "id": "5a93c517_d3da6a4b",
      "file_path": "kubernetes/consul/templates/consul-agent-deployment.yaml",
      "patchset_number": 1,
      "line": 21,
      "message": "The point here is : Once you mount a volume, it overrides the mountPath. \n\n/consul/config/bin/ was the location for kubectl. \nin new consul agent image, if I put kubectl under /consul/config/bin directly, it will be override by later volumeMount of /consul/config; \nSo in new consul agent image, I put kubectl under /consul/bin, and move it around in initContainer.",
      "author": {
        "account_id": 2541,
        "name": "Jasmine Wen",
        "display_name": null,
        "email": "jasmine.wen@amdocs.com",
        "username": "jasmineWen"
      },
      "updated": "2018-02-27 14:21:15.000000000",
      "in_reply_to": "5a93c517_858018f8",
      "unresolved": false
    },
    {
      "id": "5a93c517_93e062fb",
      "file_path": "kubernetes/consul/templates/consul-agent-deployment.yaml",
      "patchset_number": 1,
      "line": 25,
      "message": "That's right, creation of directory can be part of docker image.  but: \nthe created directory could be override by volumeMount; \nthe files inside this directory are not available at the time of image creation.",
      "author": {
        "account_id": 2541,
        "name": "Jasmine Wen",
        "display_name": null,
        "email": "jasmine.wen@amdocs.com",
        "username": "jasmineWen"
      },
