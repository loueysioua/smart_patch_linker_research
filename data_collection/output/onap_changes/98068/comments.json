    {
      "id": "3d697938_b565dd42",
      "file_path": "feature-state-management/src/main/java/org/onap/policy/drools/statemanagement/RepositoryAudit.java",
      "patchset_number": 4,
      "line": 128,
      "message": "perhaps just log repoIndices instead of its size (this is just a suggestion)",
      "author": {
        "account_id": 811,
        "name": "Jim Hahn",
        "display_name": null,
        "email": "jrh3@att.com",
