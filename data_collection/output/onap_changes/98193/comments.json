    {
      "id": "5ec44668_e9cca939",
      "file_path": "ONAP-REST/src/main/java/org/onap/policy/rest/jpa/ActionBodyEntity.java",
      "patchset_number": 1,
      "line": 60,
      "message": "Because if I put in @Data the code coverage drops right down. For POJO classes especially, the generated equals class would have to be unit tested and the openpojo doesn't work on them. I looked at EqualsTester from Guava and while it helps, you still have to put in every possible case of inequeality between objects of the class being tested in the POJO test cases to get 100% code coverage.\n\nhttps://static.javadoc.io/com.google.guava/guava-testlib/21.0/com/google/common/testing/EqualsTester.html",
      "author": {
        "account_id": 2787,
        "name": "Liam Fallon",
        "display_name": null,
        "email": "liam.fallon@est.tech",
        "username": "liamfallon"
      },
      "updated": "2019-11-11 09:00:26.000000000",
      "in_reply_to": "d61b359b_fabd995f",
      "unresolved": false
    },
