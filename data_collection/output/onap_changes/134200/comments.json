    {
      "id": "35a9b78d_5b010ad3",
      "file_path": "cps-ncmp-service/src/main/java/org/onap/cps/ncmp/api/impl/async/BatchRecordFilterStrategy.java",
      "patchset_number": 5,
      "line": 31,
      "message": "You may refactor it to something like below \n\npublic class BatchRecordFilterStrategy {\n\n    /**\n     * Filtering the consumer records based on the eventType header, It returns\n     * boolean, true means filter the consumer record and false means not filter the\n     * consumer record.\n     * \n     * @return boolean value.\n     */\n    @Bean\n    public RecordFilterStrategy<Object, Object> filterByEventType() {\n        return new EventRecordFilterStrategy(\"org.onap.cps.ncmp.events.async.v1.BatchDataResponseEvent\");\n    }\n\n    private class EventRecordFilterStrategy implements RecordFilterStrategy<Object, Object> {\n\n        private final String eventType;\n\n        public EventRecordFilterStrategy(final String eventType) {\n            this.eventType = eventType;\n        }\n\n        @Override\n        public boolean filter(final ConsumerRecord<Object, Object> consumerRecord) {\n            final String headerValue = SerializationUtils\n                    .deserialize(consumerRecord.headers().lastHeader(\"eventType\").value());\n            return eventType.equals(headerValue);\n        }\n\n    }\n}",
      "author": {
        "account_id": 3237,
        "name": "Waqas Ikram",
        "display_name": null,
        "email": "waqas.ikram@est.tech",
        "username": "waqas.ikram"
      },
      "updated": "2023-05-22 09:23:03.000000000",
      "in_reply_to": null,
      "unresolved": true
    },
