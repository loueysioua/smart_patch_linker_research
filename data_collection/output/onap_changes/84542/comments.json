    {
      "id": "3c202ef4_d8f53ecc",
      "file_path": "feature-lifecycle/src/main/java/org/onap/policy/drools/lifecycle/LifecycleStateActive.java",
      "patchset_number": 3,
      "line": 62,
      "message": "Yeah, I think I am going to disallow 2 policies with the same id and different versions to coexist in the same PDPD/controller at the same time.   Note that there's no constraints on those policies being deployed in different PDPDs.   I just think it adds little value, and will be difficult to reason about the state of the system at runtime.   I think it also may make the system less tidy.  Let me know if you have some other thoughts.",
      "author": {
        "account_id": 477,
        "name": "Jorge Hernandez",
        "display_name": null,
        "email": "jorge.hernandez-herrero@att.com",
        "username": "jhh"
      },
