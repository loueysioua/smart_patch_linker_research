        "account_id": 3717,
        "name": "Piotr Darosz",
        "display_name": null,
        "email": "piotr.darosz@nokia.com",
        "username": "darop"
      },
      "updated": "2019-03-11 07:14:34.000000000",
      "in_reply_to": "a81af2e1_410f967d",
      "unresolved": false
    },
    {
