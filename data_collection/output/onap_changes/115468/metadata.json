      {
        "id": "5c9cf99ecdc382b5b9914176ce4e4eda5dc0413f",
        "author": {
          "account_id": 481,
          "name": "Jessica Wagantall",
          "display_name": null,
          "email": "jwagantall@linuxfoundation.org",
          "username": "jwagantall"
        },
        "author_role": "REVIEWER",
        "timestamp": "2020-12-01 18:05:45.000000000",
        "message": "Patch Set 2:\n\nOk.. so I was checking further this request. The committer permissions for a particular repo cannot be adjusted depending of a branch of a repo. What we have internally in the access permissions of a repo is just an \"Owner\" permission for \"refs/*\". We do not support specific permissions for \"refs/heads/<branch>\" for branches in specific. Neither we have support for separate LDAP groups depending on the branch. In case of ONAP, this is not maintainable as we would have to have \"n\" number of groups (for each branch) for each repo (200 repos aprox) which is not easy to maintain internally. \n \n\nYou will need to make this change against the master branch please.",
        "patchset_number": 2
      },
      {
        "id": "261e3d0951f0c59468d1c84848dd97216032f3d2",
        "author": {
          "account_id": 5097,
          "name": "Bartek Grzybowski",
          "display_name": null,
          "email": "b.grzybowski@partner.samsung.com",
          "username": "bgrzybowski"
        },
        "author_role": "REVIEWER",
        "timestamp": "2020-12-02 07:38:53.000000000",
        "message": "Patch Set 2: Code-Review-1\n\n> Patch Set 2:\n> You will need to make this change against the master branch please.\n\nIt's already there, this was just a cherry-pick. Now it's clear why the JJB for info verify accepts just a single branch, thank you for the explanation.\n\nMorgan you can safely abandon this change.",
        "patchset_number": 2
      },
