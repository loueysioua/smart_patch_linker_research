        },
        "author_role": "REVIEWER",
        "timestamp": "2020-12-01 09:11:42.000000000",
        "message": "Patch Set 2:\n\n@Jess\ncould you please help us with this one?",
        "patchset_number": 2
      },
      {
        "id": "343cc3d383517c8c546a0d8faab6293560d05a05",
        "author": {
          "account_id": 481,
          "name": "Jessica Wagantall",
          "display_name": null,
          "email": "jwagantall@linuxfoundation.org",
          "username": "jwagantall"
        },
        "author_role": "REVIEWER",
        "timestamp": "2020-12-01 17:55:05.000000000",
        "message": "Patch Set 2:\n\nI need to check if this is a real limitation and expand the job to accept other branches. \nFor now, I do not have permissions to overwrite a +1 due to the Prolog rules in place. But let me force a verify on this change.. let me see if I can do that.",
        "patchset_number": 2
      },
      {
        "id": "5941dcda11cd5d88714dd4d6a9edb8aa69f6a444",
        "author": {
          "account_id": 481,
          "name": "Jessica Wagantall",
