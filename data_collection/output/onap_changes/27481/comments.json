    {
      "id": "5a93c517_dd6e6cc9",
      "file_path": "ONAP-PAP-REST/src/main/java/org/onap/policy/pap/xacml/rest/XACMLPapServlet.java",
      "patchset_number": 3,
      "line": 271,
      "message": "(Common Modules)IntegrityMonitor requires the properties to be passed to the constructor.  It does not directly read properties from the file system.\n\n(Common Modules) StateManagement does not deal with properties at all. The JPA ElementManagementFactory (which uses DB credentials) is passed to the constructor.\n\nIn ActiveStandbyFeature, the getDroolsPdpsConnector()creates a JpaDroolsPdpsConnector which requires DB credentials to create a JPA ElementManagementFactory.\n\nIn StateManagementFeature, the creation of a DroolsPDPIntegrityMonitor reads the DB credential properties.\n\nThere, of course, is also usage of credentials in JUnit tests, but, I assume that is no issue.",
      "author": {
        "account_id": 1621,
        "name": "Kevin McKiou",
        "display_name": null,
        "email": "km097d@att.com",
        "username": "km097d"
      },
      "updated": "2018-01-09 16:44:09.000000000",
      "in_reply_to": "5a93c517_478e0b30",
      "unresolved": false
    },
